      <data key="d0">AIRBORNE INFECTIOUS AGENTS (PARTICLES)</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Generic airborne infectious particles/agents whose transport and exposure are influenced by ventilation airflow patterns and source-to-exhaust pathways.</data>
      <data key="d3">0.58</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INFECTION RISK TO OCCUPANTS">
      <data key="d0">INFECTION RISK TO OCCUPANTS</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Outcome of interest: likelihood of occupants becoming infected due to airborne exposure in the room; hypothesized to be reducible via optimized airflow pathways.</data>
      <data key="d3">0.62</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="NOSOCOMIAL INFECTIONS (U.S.)">
      <data key="d0">NOSOCOMIAL INFECTIONS (U.S.)</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">Hospital-acquired infections that impose substantial health and economic burden; used as the motivating adverse outcome for improved ventilation-based controls.</data>
      <data key="d3">0.57</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
