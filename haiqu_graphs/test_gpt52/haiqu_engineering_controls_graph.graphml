    <node id="VENTILATION SYSTEM DESIGN">
      <data key="d0">VENTILATION SYSTEM DESIGN</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Engineering control involving the configuration of mechanical ventilation (e.g., supply/exhaust placement and resulting airflow patterns) to manage airborne contaminant transport and reduce infection risk in enclosed clinical spaces.</data>
      <data key="d3">0.88</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2,3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="SITE-SPECIFIC RISK ANALYSIS">
      <data key="d0">SITE-SPECIFIC RISK ANALYSIS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A scientifically based, location-tailored assessment of disease transmission risk used to inform and justify ventilation design choices for infection control and potential cost savings.</data>
      <data key="d3">0.66</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS">
      <data key="d0">COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Modeling approach used to analyze airflow-driven transport mechanisms and particle paths in a mechanically ventilated room and to support a proposed control strategy.</data>
      <data key="d3">0.76</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIR CHANGES PER HOUR (ACH)">
      <data key="d0">AIR CHANGES PER HOUR (ACH)</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Ventilation rate metric commonly used as a dilution proxy for airborne contaminants; discussed as insufficient alone to guarantee improved ventilation effectiveness. | Ventilation rate metric (air changes per hour) used to quantify outdoor air exchange in the commuter bus under different operating conditions (speed, window opening, door opening, and mannequin occupancy).</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b,e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">AIR CHANGES PER HOUR (ACH)</data>
    </node>
    <node id="VENTILATION AIRFLOW RATE (INCREASED)">
      <data key="d0">VENTILATION AIRFLOW RATE (INCREASED)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Operational intervention of increasing supplied/exhausted airflow (often reflected as higher ACH) to dilute airborne contaminant concentrations when the source is constant.</data>
      <data key="d3">0.63</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ISOLATION ROOM">
      <data key="d0">ISOLATION ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Enclosed, mechanically ventilated clinical room intended to limit transmission from infectious sources; the primary setting analyzed for ventilation optimization.</data>
      <data key="d3">0.84</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
