      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">A subtype of influenza A virus detected by the described centrifugal microfluidic system via nucleic acid-based assays.</data>
      <data key="d3">0.9</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_25,ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_60</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
