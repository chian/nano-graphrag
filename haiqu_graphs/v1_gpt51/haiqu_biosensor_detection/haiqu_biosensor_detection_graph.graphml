      <data key="d8">CAS13</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">The CRISPR/Cas13 diagnostic system uses Cas13 as its effector nuclease, responsible for target RNA recognition and subsequent collateral cleavage of single-stranded RNA.</data>
      <data key="d11">0.99</data>
      <data key="d12">1</data>
      <data key="d13">8cd80207-0825-48ce-af82-eed721eee13b_chunk_4</data>
      <data key="d14">8cd80207-0825-48ce-af82-eed721eee13b</data>
    </edge>
