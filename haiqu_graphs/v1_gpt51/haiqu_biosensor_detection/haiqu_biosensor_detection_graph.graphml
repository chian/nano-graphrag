      <data key="d7">TRACE DUPLEX ASSAYS</data>
      <data key="d8">J2L TARGET AMPLICON</data>
      <data key="d9">DETECTS</data>
      <data key="d10">TRACE duplex assays DETECTS the J2L target amplicon via Cas12b in the second temperature stage, once the J2L gRNA is no longer sequestered by the ssDNA inhibitor.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_34</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
