      <data key="d0">PFAGO-BASED DETECTION OF SARS-COV-2</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A nucleic acid detection assay using Pyrococcus furiosus Argonaute (PfAgo) to detect SARS-CoV-2 RNA, as reported by Wang et al. in Biosensors and Bioelectronics (2021).</data>
      <data key="d3">0.95</data>
      <data key="d4">8cd80207-0825-48ce-af82-eed721eee13b_chunk_56,8cd80207-0825-48ce-af82-eed721eee13b_chunk_57</data>
      <data key="d5">8cd80207-0825-48ce-af82-eed721eee13b</data>
    </node>
