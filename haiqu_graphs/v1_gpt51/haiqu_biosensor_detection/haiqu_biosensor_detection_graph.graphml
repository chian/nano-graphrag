      <data key="d7">TRACE ASSAY</data>
      <data key="d8">POST-HOC TIME-TO-POSITIVITY ANALYSIS</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">A post-hoc analysis based on a limited number of clinical specimens was used to estimate the time required for TRACE to achieve positive results, informing but potentially misrepresenting clinical performance.</data>
      <data key="d11">0.7</data>
      <data key="d12">3</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_36</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
    <edge source="TRACE ASSAY" target="TRACE COST PER TEST ($3.8)">
      <data key="d7">TRACE ASSAY</data>
      <data key="d8">TRACE COST PER TEST ($3.8)</data>
      <data key="d9">HAS_SPECIFICITY</data>
      <data key="d10">TRACE has an estimated cost of $3.8 per test, approximately half that of qPCR, contributing to its affordability.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_36</data>
