      <data key="d9">DETECTS</data>
      <data key="d10">The capacitive biosensor detects avian (H5N1) influenza in aerosol samples by measuring changes in total capacitance upon binding of H5N1 to surface capture probes.</data>
      <data key="d11">0.98</data>
      <data key="d12">1</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_51</data>
