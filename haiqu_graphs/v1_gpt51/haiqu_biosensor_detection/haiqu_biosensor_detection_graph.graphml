    <node id="PAPER-BASED SYNTHETIC GENE NETWORKS (CELL 2014)">
      <data key="d0">PAPER-BASED SYNTHETIC GENE NETWORKS (CELL 2014)</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A paper-based synthetic gene network platform that embeds cell-free gene circuits on paper substrates for low-cost, portable biosensing.</data>
      <data key="d3">0.78</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_111</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="RAPID, LOW-COST DETECTION OF ZIKA VIRUS USING PROGRAMMABLE BIOMOLECULAR COMPONENTS (CELL 2016)">
      <data key="d0">RAPID, LOW-COST DETECTION OF ZIKA VIRUS USING PROGRAMMABLE BIOMOLECULAR COMPONENTS (CELL 2016)</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A paper-based, cell-free synthetic biology platform using programmable biomolecular components for rapid, low-cost detection of Zika virus.</data>
      <data key="d3">0.9</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_111</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="LOW-COST PAPER-BASED SYNTHETIC BIOLOGY PLATFORM FOR ANALYZING GUT MICROBIOTA AND HOST BIOMARKERS (NAT. COMMUN. 2018)">
      <data key="d0">LOW-COST PAPER-BASED SYNTHETIC BIOLOGY PLATFORM FOR ANALYZING GUT MICROBIOTA AND HOST BIOMARKERS (NAT. COMMUN. 2018)</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
