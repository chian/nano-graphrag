      <data key="d0">PORTABLE SYSTEM FOR SPORE-BASED WHOLE-CELL BIOSENSING OF ARSENITE AND ZINC IN A CENTRIFUGAL COMPACT DISK MICROFLUIDIC PLATFORM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A portable centrifugal compact disk microfluidic platform integrating spore-based genetically engineered whole-cell biosensors to detect arsenite and zinc, designed for long-term functional stability under elevated temperature and varying humidity.</data>
      <data key="d3">0.9</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_34</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="B. SUBTILIS SPORE PVA LIVING MATERIAL BIOSENSOR">
      <data key="d0">B. SUBTILIS SPORE PVA LIVING MATERIAL BIOSENSOR</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A shelf-stable living material polymer device containing Bacillus subtilis spores encapsulated in a PVA matrix for continuous sensing of small-molecule analytes, storable at room temperature without loss of function.</data>
      <data key="d3">0.86</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_35</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="YEAST BIOPAD PAPER-BASED BIOSENSOR">
      <data key="d0">YEAST BIOPAD PAPER-BASED BIOSENSOR</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A whole-cell yeast paper-based biosensor (BioPAD) that integrates hydrogel encapsulation with a paper device to detect small-molecule analytes such as doxycycline, remaining viable for at least 6 months at 4 °C and 56 days at 37 °C.</data>
      <data key="d3">0.9</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_35</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="PAPER-AND-TAPE PHAGE/BACTERIA AMPLIFICATION PLATFORM">
      <data key="d0">PAPER-AND-TAPE PHAGE/BACTERIA AMPLIFICATION PLATFORM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A portable, self-contained paper-and-tape device with a PDMS membrane for amplification of bacteriophages or bacteria, designed to be easily constructed and integrated with biosensing platforms.</data>
      <data key="d3">0.78</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_35</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="BACTERIOPHAGE AND BACTERIAL CULTURE AMPLIFICATION">
      <data key="d0">BACTERIOPHAGE AND BACTERIAL CULTURE AMPLIFICATION</data>
      <data key="d1">AMPLIFICATION_METHOD</data>
      <data key="d2">Biological amplification of signal via growth and replication of bacteriophages or bacteria within a portable paper-and-tape device to increase detectable analyte or reporter output.</data>
      <data key="d3">0.7</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_35</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="INGESTIBLE MICRO-BIO-ELECTRONIC DEVICE (IMBED) WITH ENGINEERED PROBIOTIC E. COLI NISSLE 1917">
      <data key="d0">INGESTIBLE MICRO-BIO-ELECTRONIC DEVICE (IMBED) WITH ENGINEERED PROBIOTIC E. COLI NISSLE 1917</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An ingestible bio-electronic biosensor platform integrating engineered probiotic E. coli Nissle 1917 with semiconductor microelectronics for in situ gastrointestinal biomarker detection via a bioluminescent circuit that communicates with an external device.</data>
      <data key="d3">0.95</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_36</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="QUANTITATIVE PORTABLE CMOS LAB-ON-CHIP PLATFORM WITH ISFET-BASED NUCLEIC ACID AMPLIFICATION SENSING">
      <data key="d0">QUANTITATIVE PORTABLE CMOS LAB-ON-CHIP PLATFORM WITH ISFET-BASED NUCLEIC ACID AMPLIFICATION SENSING</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A portable CMOS lab-on-chip biosensor platform that couples nucleic acid amplification-based sensing with ion-sensitive field-effect transistors (ISFETs) for chemical-to-electronic detection of Plasmodium falciparum and differentiation of artemisinin-resistant parasites.</data>
      <data key="d3">0.95</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_36</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="PLASMODIUM FALCIPARUM">
      <data key="d0">PLASMODIUM FALCIPARUM</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">The most common malaria-causing parasite worldwide, detected by the CMOS lab-on-chip ISFET-based biosensor platform and further characterized for artemisinin resistance.</data>
      <data key="d3">0.8</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_36</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="HYBRID SEMICONDUCTOR-BASED CMOS LAB-ON-CHIP PLATFORM FOR PLASMODIUM FALCIPARUM DIAGNOSIS AND ARTEMISININ-RESISTANCE DETECTION">
      <data key="d0">HYBRID SEMICONDUCTOR-BASED CMOS LAB-ON-CHIP PLATFORM FOR PLASMODIUM FALCIPARUM DIAGNOSIS AND ARTEMISININ-RESISTANCE DETECTION</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A CMOS Lab-on-Chip biosensing platform that quantitatively and rapidly diagnoses Plasmodium falciparum malaria and differentiates parasites resistant to artemisinin, enabling more specific treatment.</data>
      <data key="d3">0.9</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_37</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="MICROELECTRONIC PLATFORM INTERFACED WITH POPULATION CONTROL GENETIC CIRCUIT">
      <data key="d0">MICROELECTRONIC PLATFORM INTERFACED WITH POPULATION CONTROL GENETIC CIRCUIT</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A biosensing platform that interfaces cells engineered with a population control genetic circuit to microelectronics, using cell lysis-mediated impedance measurements to sense circuit output without optical readout.</data>
      <data key="d3">0.8</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_37</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="CELL-FREE BIOSENSING PLATFORM BASED ON CRUDE EXTRACTS FOR CFE">
      <data key="d0">CELL-FREE BIOSENSING PLATFORM BASED ON CRUDE EXTRACTS FOR CFE</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A cell-free biosensing platform using crude extracts to support cell-free gene expression, enabling activation of complex gene expression cascades and metabolic pathways for sensitive and specific detection.</data>
      <data key="d3">0.8</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_37</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="FREEZE-DRIED E. COLI CELL-FREE BIOSENSOR FOR CYANURIC ACID DETECTION">
      <data key="d0">FREEZE-DRIED E. COLI CELL-FREE BIOSENSOR FOR CYANURIC ACID DETECTION</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A field-deployable freeze-dried E. coli cell-free biosensor that detects the environmental toxin cyanuric acid in water by coupling E. coli gene expression machinery with a non-native Pseudomonas transcriptional regulator and hybrid Pseudomonas–E. coli promoters.</data>
      <data key="d3">0.95</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_37</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="CYANURIC ACID (CYA)">
      <data key="d0">CYANURIC ACID (CYA)</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">An environmental toxin (not a pathogen) detected in water by the described cell-free biosensor; included here as the primary target analyte of the biosensing platform, though it is a chemical contaminant rather than a biological pathogen.</data>
      <data key="d3">0.4</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_37</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="PSEUDOMONAS–E. COLI PROMOTERS IN FREEZE-DRIED E. COLI CELL-FREE SYSTEM">
      <data key="d0">PSEUDOMONAS–E. COLI PROMOTERS IN FREEZE-DRIED E. COLI CELL-FREE SYSTEM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A cell-free transcriptional biosensing setup using Pseudomonas–E. coli promoters that functions in a freeze-dried E. coli extract, rehydrated with water samples and read out by fluorescence within about an hour.</data>
      <data key="d3">0.6</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_38</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="SILVERMAN ET AL. MODULAR ATRAZINE BIOSENSOR PLATFORM">
      <data key="d0">SILVERMAN ET AL. MODULAR ATRAZINE BIOSENSOR PLATFORM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A modular cell-free biosensor platform that detects organic molecules by coupling metabolic conversion of target molecules with transcription-factor-based sensing, demonstrated for efficient atrazine detection and multiplexed sensing in a single mixture using multiple extracts and reporter plasmids.</data>
      <data key="d3">0.9</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_38</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="VOYVODIC ET AL. MODULAR METABOLIC TRANSDUCER CELL-FREE BIOSENSOR PLATFORM">
      <data key="d0">VOYVODIC ET AL. MODULAR METABOLIC TRANSDUCER CELL-FREE BIOSENSOR PLATFORM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A plug-and-play cell-free biosensor platform that uses synthetic metabolic cascades as transducers coupled to transcription factor-based sensing to expand the range of detectable chemicals, functioning in complex matrices such as commercial beverages and human urine.</data>
      <data key="d3">0.9</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_38</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="ATRAZINE">
      <data key="d0">ATRAZINE</data>
      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">An organic herbicide used in the Silverman et al. platform as the target analyte whose presence is converted via metabolic processing into a signal detectable by a transcription-factor-based cell-free biosensor.</data>
      <data key="d3">0.5</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_38,4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_109</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="FLUORESCENT READOUT SIGNAL">
      <data key="d0">FLUORESCENT READOUT SIGNAL</data>
      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">The fluorescence-based output used by the freeze-dried cell-free biosensor systems, enabling visual or instrumental detection of target analytes within approximately one hour after rehydration. | A fluorescence-based output generated by RNA aptamers in vitro, used as the readout for certain cell-free biosensing platforms.</data>
      <data key="d3">0.7</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_38</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
      <data key="d6">FLUORESCENT REPORTER SIGNAL</data>
    </node>
    <node id="COMPLEX SAMPLE MATRICES (COMMERCIAL BEVERAGES AND HUMAN URINE)">
      <data key="d0">COMPLEX SAMPLE MATRICES (COMMERCIAL BEVERAGES AND HUMAN URINE)</data>
      <data key="d1">SAMPLE_PREP_STEP</data>
      <data key="d2">Use of minimally processed complex samples, such as commercial beverages and human urine, for input into the Voyvodic et al. cell-free biosensor platform, requiring only dilution as a preparation step.</data>
      <data key="d3">0.6</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_38</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="SAMPLE DILUTION FOR COMPLEX MATRICES">
      <data key="d0">SAMPLE DILUTION FOR COMPLEX MATRICES</data>
      <data key="d1">SAMPLE_PREP_STEP</data>
      <data key="d2">A simple sample preparation step in which complex solutions like beverages or urine are diluted to allow proper functioning of the modular cell-free biosensor platforms.</data>
      <data key="d3">0.6</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_38</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="MCNERNEY ET AL. POINT-OF-CARE BIOMARKER QUANTIFICATION PLATFORM">
      <data key="d0">MCNERNEY ET AL. POINT-OF-CARE BIOMARKER QUANTIFICATION PLATFORM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A point-of-care biosensing platform that uses patients’ own blood samples to generate sample-specific calibration curves with transcription factor- and toehold switch-based sensors in an equipment-free format.</data>
      <data key="d3">0.86</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_39</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="GRÄWE ET AL. PAPER-BASED CELL-FREE HEAVY-METAL SENSING PLATFORM">
      <data key="d0">GRÄWE ET AL. PAPER-BASED CELL-FREE HEAVY-METAL SENSING PLATFORM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A paper-based, cell-free biosensor system using allosteric transcription factors in a cell-free protein synthesis system to detect heavy-metal ions in water, with freeze-dried reagents rehydrated by the sample.</data>
      <data key="d3">0.88</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_39</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="SMARTPHONE CAMERA WITH DUAL LIGHT FILTER READOUT">
      <data key="d0">SMARTPHONE CAMERA WITH DUAL LIGHT FILTER READOUT</data>
      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">An optical reporter readout configuration where the biosensor signal on paper is quantified using a smartphone camera combined with a dual light filter system.</data>
      <data key="d3">0.7</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_39</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="PARDEE ET AL. PAPER-BASED TOEHOLD SWITCH EBOLA MRNA DIAGNOSTIC">
      <data key="d0">PARDEE ET AL. PAPER-BASED TOEHOLD SWITCH EBOLA MRNA DIAGNOSTIC</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A paper-based, freeze-dried cell-free genetic circuit platform using orthogonal toehold switches to discriminate between mRNA from different Ebola virus strains, stable at room temperature for over one year.</data>
      <data key="d3">0.92</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_39</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="CAS13A-BASED NUCLEIC ACID DETECTION PLATFORM">
      <data key="d0">CAS13A-BASED NUCLEIC ACID DETECTION PLATFORM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A CRISPR-Cas13a nucleic acid detection system developed by Gootenberg et al. that harnesses the ssRNA trans-cleavage activity of Cas13a to achieve specific, high-sensitivity enzymatic reporting of target nucleic acids.</data>
      <data key="d3">0.85</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_40</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="SHERLOCKV2">
      <data key="d0">SHERLOCKV2</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An updated, multiplexed SHERLOCK platform that integrates orthogonal Cas13 and Cas12 enzymes and couples Cas13 with the type III effector nuclease Csm6 to boost sensitivity, incorporating a lateral flow readout for user-friendly, point-of-care diagnostics.</data>
      <data key="d3">0.96</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_41</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="HUDSON">
      <data key="d0">HUDSON</data>
      <data key="d1">SAMPLE_PREP_STEP</data>
      <data key="d2">Heating Unextracted Diagnostic Samples to Obliterate Nucleases (HUDSON), a sample preparation protocol that uses heat and chemical treatment to inactivate nucleases and release nucleic acids directly from patient samples, enabling instrument-free CRISPR-based diagnostics when paired with SHERLOCK.</data>
      <data key="d3">0.9</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_41</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="HOLMES">
      <data key="d0">HOLMES</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">The one-hour low-cost multipurpose highly efficient system (HOLMES), a CRISPR-Cas12a-based nucleic acid detection platform that exploits Cas12a’s DNA-targeting and collateral (trans) ssDNA cleavage activity for portable, field-ready biosensing.</data>
      <data key="d3">0.9</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_41,4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="PATHOGENIC BACTERIA">
      <data key="d0">PATHOGENIC BACTERIA</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Bacterial pathogens whose nucleic acids are detectable by SHERLOCK at attomolar levels; several clinically important species can be transmitted via air or droplets.</data>
      <data key="d3">0.7</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_41</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="ATTOMOLAR LEVELS">
      <data key="d0">ATTOMOLAR LEVELS</data>
      <data key="d1">LIMIT_OF_DETECTION</data>
      <data key="d2">An extremely low concentration regime (~10^-18 M) representing the reported sensitivity at which SHERLOCK can detect viral and bacterial nucleic acids.</data>
      <data key="d3">0.85</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_41</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="PORTABLE CRISPR-CAS12 BIOSENSING PLATFORMS">
      <data key="d0">PORTABLE CRISPR-CAS12 BIOSENSING PLATFORMS</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A class of portable, field-ready diagnostic systems that use Cas12 effectors with cis and trans ssDNA cleavage activity to detect nucleic acids in low-infrastructure settings.</data>
      <data key="d3">0.82</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_41</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="DETECTR LATERAL FLOW ASSAY">
      <data key="d0">DETECTR LATERAL FLOW ASSAY</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An implementation of the CRISPR–Cas12-based DETECTR platform as a lateral flow assay for rapid, point-of-care detection of SARS-CoV-2 from respiratory swab RNA extracts within about 40 minutes.</data>
      <data key="d3">0.99</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42,4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_114</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="ONE-POT CRISPR-CAS12A-BASED ASSAY">
      <data key="d0">ONE-POT CRISPR-CAS12A-BASED ASSAY</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An all-in-one dual CRISPR-Cas12a assay that couples two CRISPR RNAs in a single reaction without PAM limitations, enabling ultrasensitive and visual detection of SARS-CoV-2 within about 20 minutes.</data>
      <data key="d3">0.9</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="TWO CRISPR RNAS">
      <data key="d0">TWO CRISPR RNAS</data>
      <data key="d1">GUIDE_RNA</data>
      <data key="d2">A pair of CRISPR RNAs used in the dual CRISPR-Cas12a assay to guide Cas12a to SARS-CoV-2 target sequences without protospacer adjacent motif limitations, improving sensitivity.</data>
      <data key="d3">0.7</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="A FEW COPIES OF THE VIRUS">
      <data key="d0">A FEW COPIES OF THE VIRUS</data>
      <data key="d1">LIMIT_OF_DETECTION</data>
      <data key="d2">An ultrasensitive detection threshold described as the ability to detect as low as a few copies of SARS-CoV-2 within 20 minutes in the dual CRISPR-Cas12a assay.</data>
      <data key="d3">0.8</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="ATTOMOLAR DETECTION OF TARGET DNA">
      <data key="d0">ATTOMOLAR DETECTION OF TARGET DNA</data>
      <data key="d1">LIMIT_OF_DETECTION</data>
      <data key="d2">An attomolar-level limit of detection for target DNA achieved by the HOLMES Cas12a-based detection system.</data>
      <data key="d3">0.75</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
