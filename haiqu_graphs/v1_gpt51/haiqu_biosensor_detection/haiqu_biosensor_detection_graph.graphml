      <data key="d8">CAS EFFECTERS</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">TRACE employs CRISPR-Cas effector enzymes whose activity is thermally regulated to enable asynchronous separation of amplification and detection phases.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_8</data>
