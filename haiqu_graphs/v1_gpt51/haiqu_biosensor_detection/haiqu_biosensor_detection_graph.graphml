      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An electrochemical immunosensor platform that uses an array of gold nanoparticle-modified carbon electrodes to detect the coronavirus associated with Middle East respiratory syndrome (MERS-CoV) via antigen–antibody binding and electrochemical readout.</data>
      <data key="d3">0.88</data>
      <data key="d4">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_351</data>
