    <node id="ZIKA VIRUS (ZIKV)">
      <data key="d0">ZIKA VIRUS (ZIKV)</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Zika virus (ZIKV) is a mosquito-borne flavivirus referenced as the target pathogen for molecular detection assays, including assay optimization and RT-LAMP-based rapid detection in mosquito samples.</data>
      <data key="d3">0.9</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_45</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
