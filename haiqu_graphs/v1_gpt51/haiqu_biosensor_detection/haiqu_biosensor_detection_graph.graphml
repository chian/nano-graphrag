    </edge>
    <edge source="CRISPR-BASED DIAGNOSTICS (GENERAL)" target="CRISPR-CAS13A">
      <data key="d7">CRISPR-BASED DIAGNOSTICS (GENERAL)</data>
      <data key="d8">CRISPR-CAS12A</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">General CRISPR-based diagnostic platforms can incorporate Cas12a as the effector nuclease for DNA-targeted nucleic acid detection.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">8cd80207-0825-48ce-af82-eed721eee13b_chunk_50</data>
      <data key="d14">8cd80207-0825-48ce-af82-eed721eee13b</data>
    </edge>
