      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A CRISPR-Cas12a diagnostic platform in which crRNA activity is controlled by light, enhancing robustness and temporal control of detection.</data>
      <data key="d3">0.8</data>
      <data key="d4">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_30</data>
      <data key="d5">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </node>
    <node id="MULTIPLEXED AND PORTABLE NUCLEIC ACID DETECTION PLATFORM WITH CAS13, CAS12A, AND CSM6">
      <data key="d0">MULTIPLEXED AND PORTABLE NUCLEIC ACID DETECTION PLATFORM WITH CAS13, CAS12A, AND CSM6</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A portable CRISPR-based platform that enables multiplexed nucleic acid detection using Cas13, Cas12a, and Csm6 effectors. | A multiplexed, portable CRISPR-based nucleic acid detection platform that combines Cas13, Cas12a, and Csm6 effectors to enable sensitive and field-deployable detection of diverse nucleic acid targets.</data>
      <data key="d3">0.96</data>
      <data key="d4">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_30,6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_58</data>
      <data key="d5">6f94756d-fd42-4a77-b6b1-d9dc6901591d,4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
      <data key="d6">MULTIPLEXED AND PORTABLE NUCLEIC ACID DETECTION PLATFORM WITH CAS13, CAS12A, AND CSM6</data>
    </node>
    <node id="CRRNA">
      <data key="d0">CRRNA</data>
      <data key="d1">GUIDE_RNA</data>
      <data key="d2">CRISPR RNA guides that direct Cas12a to target sequences; in some platforms their activity is photocontrolled.</data>
      <data key="d3">0.8</data>
      <data key="d4">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_30,6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_57,6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_62</data>
      <data key="d5">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </node>
