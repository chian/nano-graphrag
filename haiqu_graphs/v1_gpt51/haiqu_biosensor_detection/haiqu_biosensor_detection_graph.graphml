      <data key="d9">PRODUCES_SIGNAL</data>
      <data key="d10">TRACE duplex assays PRODUCES_SIGNAL reporter signal in the second stage, which reflects activation of Cas12b and detection of the J2L target amplicon once the J2L gRNA is released from ssDNA inhibition.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_34</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
