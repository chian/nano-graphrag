      <data key="d0">RECTAL SWAB DIRECT SAMPLE</data>
      <data key="d1">ASSAY_RUN</data>
      <data key="d2">Assay condition in which the rectal swab is used directly in the ANCA method without prior dilution in transport media, enabling more sensitive detection of KPC-producing bacteria.</data>
      <data key="d3">0.86</data>
      <data key="d4">8cd80207-0825-48ce-af82-eed721eee13b_chunk_29</data>
      <data key="d5">8cd80207-0825-48ce-af82-eed721eee13b</data>
    </node>
