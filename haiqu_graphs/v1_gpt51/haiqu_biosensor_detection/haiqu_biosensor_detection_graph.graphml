      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The one-pot RT-RPA–Cas12a platform is implemented within enclosed cartridges that integrate amplification and detection, demonstrating its suitability for miniaturized, contamination-resistant operation.</data>
