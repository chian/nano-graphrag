    </edge>
    <edge source="LATERAL-FLOW FORMATS" target="VIRAL CONCENTRATIONS DURING EARLY INFECTION BELOW 10³ COPIES ML⁻¹ IN WATER AND AEROSOLS">
      <data key="d7">LATERAL-FLOW FORMATS</data>
      <data key="d8">VIRAL CONCENTRATIONS DURING EARLY INFECTION BELOW 10³ COPIES ML⁻¹ IN WATER AND AEROSOLS</data>
      <data key="d9">HAS_LOD</data>
      <data key="d10">Conventional lateral-flow devices struggle to detect viral concentrations below 10³ copies mL⁻¹, indicating an insufficient limit of detection for early infection levels.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_39</data>
      <data key="d14">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b</data>
    </edge>
    <edge source="IMPEDANCE-BASED BIOSENSORS" target="VIRAL CONCENTRATIONS DURING EARLY INFECTION BELOW 10³ COPIES ML⁻¹ IN WATER AND AEROSOLS">
      <data key="d7">IMPEDANCE-BASED BIOSENSORS</data>
