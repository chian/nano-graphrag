      <data key="d0">RT-LAMP AMPLIFICATION</data>
      <data key="d1">AMPLIFICATION_METHOD</data>
      <data key="d2">A reverse-transcription loop-mediated isothermal amplification method used on-chip in the instrument-free microfluidic platform for Zika virus detection.</data>
      <data key="d3">0.9</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_24</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
