    <node id="THERMUS THERMOPHILUS ARGONAUTE RARE NUCLEIC ACID ENRICHMENT ASSAY">
      <data key="d0">THERMUS THERMOPHILUS ARGONAUTE RARE NUCLEIC ACID ENRICHMENT ASSAY</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An assay that uses Thermus thermophilus Argonaute (TtAgo) to specifically enrich rare nucleic acid fractions for applications in cancer diagnostics, as reported by Song et al. in Nucleic Acids Research (2020).</data>
      <data key="d3">0.8</data>
      <data key="d4">8cd80207-0825-48ce-af82-eed721eee13b_chunk_56</data>
      <data key="d5">8cd80207-0825-48ce-af82-eed721eee13b</data>
    </node>
