      <data key="d9">HAS_LOD</data>
      <data key="d10">Impedance-based biosensors are described as capable of detecting viruses at concentrations in the early-infection regime below 10³ copies mL⁻¹ in water and aerosols.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_39</data>
      <data key="d14">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b</data>
    </edge>
