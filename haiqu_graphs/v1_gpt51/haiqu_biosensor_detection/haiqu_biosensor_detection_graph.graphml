      <data key="d0">PHAGE-MEDIATED MIRNA COUNTING PLATFORM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A phage-mediated biosensor that enables naked-eye counting of miRNA molecules at attomolar concentrations in a Petri dish, as reported by Zhou et al. (Nat. Mater. 14, 1058–1064, 2015).</data>
      <data key="d3">0.75</data>
      <data key="d4">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_82</data>
      <data key="d5">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </node>
