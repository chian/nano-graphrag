      <data key="d7">TRACE DUPLEX ASSAYS</data>
      <data key="d8">SIGNAL PRODUCED IN THE FIRST ASSAY STAGE</data>
      <data key="d9">PRODUCES_SIGNAL</data>
      <data key="d10">TRACE duplex assays PRODUCES_SIGNAL a signal in the first assay stage that exclusively reflects Cas12a recognition of the RNase P target, due to Cas12a’s binding criteria and suppression of Cas12b activity.</data>
      <data key="d11">0.96</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_34</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
