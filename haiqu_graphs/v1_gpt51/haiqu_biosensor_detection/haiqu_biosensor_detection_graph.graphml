      <data key="d0">VIRUS EXTRACTION AND PURIFICATION</data>
      <data key="d1">SAMPLE_PREP_STEP</data>
      <data key="d2">An automated on-chip sample preparation step in the integrated influenza A microfluidic system, using magnetic microbeads to extract and purify viral material prior to RT-PCR amplification.</data>
      <data key="d3">0.88</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_24</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
