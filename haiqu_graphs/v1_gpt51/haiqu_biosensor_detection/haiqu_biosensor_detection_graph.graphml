      <data key="d9">USES_AMPLIFICATION</data>
      <data key="d10">The TRACE assay can operate with multienzyme isothermal rapid amplification as an RPA analog, indicating flexibility in the choice of isothermal amplification systems.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_14</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
