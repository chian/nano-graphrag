      <data key="d8">DISTINCT TARGET AMPLICONS</data>
      <data key="d9">USES_AMPLIFICATION</data>
      <data key="d10">TRACE duplex assays USES_AMPLIFICATION products in the form of distinct target amplicons, which are then differentially recognized by Cas12a and Cas12b across two temperature stages to achieve duplex detection.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_34</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
