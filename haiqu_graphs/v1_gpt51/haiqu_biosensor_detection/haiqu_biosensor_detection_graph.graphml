      <data key="d0">37°C INCUBATION USING LOW-COST HANDWARMER</data>
      <data key="d1">SAMPLE_PREP_STEP</data>
      <data key="d2">A low-cost incubation method that maintains biosensing reactions at 37°C using a handwarmer, enabling operation without powered incubators.</data>
      <data key="d3">0.7</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_44</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
