      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Carbon nanotube (CNT) based FET nanocircuit platform used for amplification-free detection of DNA length via enzyme functionalization.</data>
      <data key="d3">0.8</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_18</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
    <node id="GRAPHENE-BASED FET SENSOR WITH CRISPR/CAS9">
