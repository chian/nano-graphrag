      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Electrochemical DNA sensing platform designed for reusability by regenerating the working electrode surface using switchable or looped capture probes and washing-based dehybridization steps, reducing nucleic acid testing cost.</data>
      <data key="d3">0.75</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_17</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
