      <data key="d9">USES_VARIANT</data>
      <data key="d10">The HOLMESv2 nucleic acid detection platform is described as CRISPR-Cas12b-assisted, indicating that Cas12b is the effector enzyme used.</data>
      <data key="d11">0.99</data>
      <data key="d12">1</data>
      <data key="d13">8cd80207-0825-48ce-af82-eed721eee13b_chunk_49</data>
