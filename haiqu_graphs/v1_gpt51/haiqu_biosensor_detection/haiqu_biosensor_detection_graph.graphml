      <data key="d0">HIGH SENSITIVITY AND SPECIFICITY PROFILE FOR MICRORNA SERUM DETECTION</data>
      <data key="d1">SPECIFICITY_PROFILE</data>
      <data key="d2">Performance profile describing high sensitivity and specificity achieved for direct electrochemical detection of microRNAs in serum samples.</data>
      <data key="d3">0.75</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_17</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
