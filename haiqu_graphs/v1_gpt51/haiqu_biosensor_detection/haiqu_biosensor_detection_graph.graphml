      <data key="d8">CAS12A</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">The DETECTR lateral flow assay is a Cas12a-based implementation that relies on Cas12a collateral cleavage to generate a lateral flow signal. | The DETECTR lateral flow assay uses Cas12a as the core CRISPR effector, leveraging its collateral cleavage of reporter molecules to produce a lateral-flow signal.</data>
      <data key="d11">0.97</data>
      <data key="d12">1</data>
      <data key="d13">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d14">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </edge>
    <edge source="DETECTR LATERAL FLOW ASSAY" target="SARS-COV-2">
      <data key="d7">DETECTR LATERAL FLOW ASSAY</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">DETECTS</data>
      <data key="d10">The DETECTR lateral flow assay is applied to identify SARS-CoV-2 from respiratory swab RNA extracts as a point-of-care diagnostic. | The DETECTR lateral flow assay detects SARS-CoV-2 by recognizing its specific nucleic acid sequences and producing a visual lateral-flow readout.</data>
      <data key="d11">0.99</data>
      <data key="d12">1</data>
      <data key="d13">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d14">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </edge>
