    <edge source="TRACE DUPLEX ASSAYS" target="J2L GRNA">
      <data key="d7">TRACE DUPLEX ASSAYS</data>
      <data key="d8">J2L GRNA</data>
      <data key="d9">USES_GUIDE</data>
      <data key="d10">TRACE duplex assays USES_GUIDE the Cas12b-specific J2L gRNA to direct Cas12b to the J2L target amplicon; its sequestration by an ssDNA inhibitor in the first stage provides temporal control of Cas12b activation.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_34</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
