      <data key="d9">DETECTS</data>
      <data key="d10">The PMMA microfluidic aptasensor detects H5N1 by targeting and quantifying H5N1-specific DNA sequences.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_51</data>
