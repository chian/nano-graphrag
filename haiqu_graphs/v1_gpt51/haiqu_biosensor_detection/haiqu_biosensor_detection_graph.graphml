      <data key="d8">BENCH VALIDATION WITH SYNTHETIC REPLICATE SAMPLES</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">Performance characteristics of the TRACE assay, including sensitivity, linear range, and detection reliability at ≥5 copies/test, were established using synthetic replicate samples spiked with MPXV DNA.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_14</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
