      <data key="d7">TRACE DUPLEX ASSAY</data>
      <data key="d8">MPXV J2L</data>
      <data key="d9">DETECTS</data>
      <data key="d10">The assay specifically targets the MPXV J2L gene region, with its presence reported as the ΔF2 fluorescent signal during the 64 °C second stage.</data>
      <data key="d11">0.94</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_25</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
