      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A handheld lateral flow strip device designed for rapid DNA extraction from Staphylococcus aureus cells spiked into various sample matrices, serving as a low-complexity sample preparation and detection platform.</data>
      <data key="d3">0.7</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_48</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
    <node id="REAL-TIME RT-LAMP ASSAY FOR RAPID DETECTION OF WEST NILE VIRUS">
      <data key="d0">REAL-TIME RT-LAMP ASSAY FOR RAPID DETECTION OF WEST NILE VIRUS</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A real-time reverse transcription LAMP assay configured for rapid detection of West Nile virus RNA, integrating isothermal amplification with real-time readout.</data>
      <data key="d3">0.6</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_48</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
