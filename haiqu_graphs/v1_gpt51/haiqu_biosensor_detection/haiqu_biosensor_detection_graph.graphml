    <node id="SEMICONDUCTOR QUANTUM DOTS IN ELISA">
      <data key="d0">SEMICONDUCTOR QUANTUM DOTS IN ELISA</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Use of semiconductor quantum dots (QDs) as fluorescent markers in ELISA to replace traditional enzyme markers, providing higher photostability, quantum efficiency, narrower spectra, and improved sensitivity, stability, and multiplexing.</data>
      <data key="d3">0.85</data>
      <data key="d4">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_83</data>
      <data key="d5">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </node>
