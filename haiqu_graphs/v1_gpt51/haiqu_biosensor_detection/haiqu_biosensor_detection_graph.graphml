      <data key="d0">TRACE ASSAY ANALYTICAL AND CLINICAL VALIDATION</data>
      <data key="d1">ASSAY_VALIDATION</data>
      <data key="d2">The analytical and clinical validation program for the TRACE assay, including systematic optimization of one-pot reaction parameters and performance characterization.</data>
      <data key="d3">0.8</data>
      <data key="d4">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_13</data>
      <data key="d5">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </node>
    <node id="SSRNA BLOCKER 1-S14">
      <data key="d0">SSRNA BLOCKER 1-S14</data>
      <data key="d1">GUIDE_RNA</data>
      <data key="d2">A single-stranded RNA blocker (1-S14) used in the TRACE assay, mixed with gRNA at a 1:4 gRNA:ssRNA ratio to modulate Cas12b activity and improve signal-to-noise; designed with an annealing temperature ~15 °C below the Cas12b reaction temperature.</data>
      <data key="d3">0.8</data>
      <data key="d4">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_14</data>
      <data key="d5">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </node>
    <node id="FUSION GRNA WITH APPENDED SSRNA BLOCKING SEQUENCE">
      <data key="d0">FUSION GRNA WITH APPENDED SSRNA BLOCKING SEQUENCE</data>
      <data key="d1">GUIDE_RNA</data>
      <data key="d2">A gRNA design in which the ssRNA blocking sequence is appended to the gRNA; it showed complex, suboptimal behavior and was excluded from subsequent TRACE assay studies.</data>
      <data key="d3">0.55</data>
      <data key="d4">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_14</data>
      <data key="d5">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </node>
    <node id="MULTIENZYME ISOTHERMAL RAPID AMPLIFICATION">
      <data key="d0">MULTIENZYME ISOTHERMAL RAPID AMPLIFICATION</data>
      <data key="d1">AMPLIFICATION_METHOD</data>
      <data key="d2">An RPA-analog multienzyme isothermal rapid amplification system that is compatible with the TRACE assay as an alternative isothermal amplification chemistry.</data>
      <data key="d3">0.65</data>
      <data key="d4">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_14</data>
      <data key="d5">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </node>
    <node id="RECOMBINASE-AIDED AMPLIFICATION">
      <data key="d0">RECOMBINASE-AIDED AMPLIFICATION</data>
      <data key="d1">AMPLIFICATION_METHOD</data>
      <data key="d2">A recombinase-based isothermal amplification method, analogous to RPA, that is also compatible with the TRACE assay for pre-amplifying target DNA.</data>
      <data key="d3">0.7</data>
      <data key="d4">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_14,6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_15</data>
      <data key="d5">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </node>
