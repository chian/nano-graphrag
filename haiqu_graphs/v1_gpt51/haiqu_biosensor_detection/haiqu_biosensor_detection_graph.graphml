      <data key="d8">NAA</data>
      <data key="d9">USES_AMPLIFICATION</data>
      <data key="d10">Two-step CRISPR assays employ a dedicated nucleic acid amplification step that is separated from the CRISPR detection step, preventing Cas12a from depleting amplification products during the amplification phase.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_6</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
