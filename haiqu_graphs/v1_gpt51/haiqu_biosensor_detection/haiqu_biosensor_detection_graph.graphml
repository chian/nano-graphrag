      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A CRISPR-based detection strategy optimized to reduce interference from target amplification, improving speed and sensitivity.</data>
      <data key="d3">0.8</data>
      <data key="d4">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_30</data>
      <data key="d5">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </node>
    <node id="PHOTOCONTROLLED CRRNA ACTIVATION ENABLES ROBUST CRISPR-CAS12A DIAGNOSTICS">
