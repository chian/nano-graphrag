      <data key="d9">HAS_LOD</data>
      <data key="d10">The capacitive biosensor has a defined limit of detection for H5N1 that is used as a threshold to interpret normalized ΔC% signals and classify samples as positive or negative.</data>
      <data key="d11">0.93</data>
      <data key="d12">1</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_51</data>
