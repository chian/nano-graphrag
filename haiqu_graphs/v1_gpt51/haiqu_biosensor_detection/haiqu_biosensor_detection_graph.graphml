      <data key="d0">LAB-IN/ON-AN-X (LIONX) SYSTEMS</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An integrated diagnostic platform (lab-in/on-an-X, LionX) used for testing processes for diagnosis of COVID-19, encompassing sample handling, nucleic-acid processing, and signal readout.</data>
      <data key="d3">0.9</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_3</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
