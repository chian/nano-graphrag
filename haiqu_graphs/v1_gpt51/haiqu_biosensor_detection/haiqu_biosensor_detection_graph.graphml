      <data key="d8">CRISPR-CAS12A</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">The contamination-free SARS-CoV-2 visual assay uses CRISPR-Cas12a as the detection enzyme, leveraging its collateral cleavage activity to generate a visible readout in a closed-tube format.</data>
      <data key="d11">0.98</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_4</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
