      <data key="d2">Methicillin-resistant Staphylococcus aureus (MRSA), a drug-resistant Staphylococcus aureus strain that can be transmitted via aerosols or droplets and is a target pathogen for nanoparticle-based detection.</data>
      <data key="d3">0.9</data>
      <data key="d4">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_83,f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_401</data>
      <data key="d5">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </node>
    <node id="STAPHYLOCOCCUS AUREUS">
