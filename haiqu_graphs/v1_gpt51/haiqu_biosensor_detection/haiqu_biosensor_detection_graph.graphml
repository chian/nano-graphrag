    <edge source="BENCH VALIDATION WITH SPIKED LIQUID SAMPLES" target="MINIATURIZED 3D PRINTED SPR BIOSENSOR">
      <data key="d7">BENCH VALIDATION WITH SPIKED LIQUID SAMPLES</data>
      <data key="d8">MINIATURIZED 3D PRINTED SPR BIOSENSOR</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The analytical performance of the SPR biosensor, including limit of detection and specificity, was established through bench validation using PBS-diluted culture medium spiked with H5N1 and non-target influenza subtypes.</data>
      <data key="d11">0.65</data>
      <data key="d12">2</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_54</data>
      <data key="d14">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b</data>
