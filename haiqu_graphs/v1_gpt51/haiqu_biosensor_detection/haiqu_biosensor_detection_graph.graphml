    <node id="AMPLIFICATION-FREE DETECTION OF SARS-COV-2 WITH CRISPR-CAS13A AND MOBILE PHONE MICROSCOPY">
      <data key="d0">AMPLIFICATION-FREE DETECTION OF SARS-COV-2 WITH CRISPR-CAS13A AND MOBILE PHONE MICROSCOPY</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A CRISPR-Cas13a-based nucleic acid detection platform that directly detects SARS-CoV-2 RNA without nucleic acid amplification, using mobile phone-based fluorescence microscopy as the readout.</data>
