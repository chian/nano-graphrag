      <data key="d0">RT-LAMP ASSAY FOR RAPID DETECTION OF SARS-COV-2</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An RT-LAMP-based assay specifically configured for rapid detection of SARS-CoV-2 RNA, suitable for near-patient or point-of-care testing. | An RT-LAMP-based assay platform designed for rapid detection of HIV-1 RNA, combining reverse transcription with loop-mediated isothermal amplification for nucleic acid detection.</data>
      <data key="d3">0.9</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_48</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
      <data key="d6">RT-LAMP ASSAY FOR RAPID DETECTION OF HIV-1</data>
    </node>
    <node id="COMPARATIVE STUDY OF ISOTHERMAL NUCLEIC ACID AMPLIFICATION METHODS FOR SARS-COV-2 DETECTION AT POINT OF CARE">
      <data key="d0">COMPARATIVE STUDY OF ISOTHERMAL NUCLEIC ACID AMPLIFICATION METHODS FOR SARS-COV-2 DETECTION AT POINT OF CARE</data>
      <data key="d1">ASSAY_VALIDATION</data>
      <data key="d2">A comparative validation study that evaluates different isothermal nucleic acid amplification methods for detecting SARS-CoV-2 at the point of care, characterizing their relative performance.</data>
      <data key="d3">0.8</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_48</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
