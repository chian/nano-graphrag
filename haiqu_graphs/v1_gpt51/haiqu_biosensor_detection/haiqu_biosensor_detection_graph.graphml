      <data key="d8">TWO CRISPR RNAS</data>
      <data key="d9">USES_GUIDE</data>
      <data key="d10">The dual CRISPR-Cas12a assay couples two CRISPR RNAs in a single reaction, using them as guide RNAs to direct Cas12a to SARS-CoV-2 target sequences without PAM limitations.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d14">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </edge>
