      <data key="d8">INFLUENZA A H3N2 VIRUS</data>
      <data key="d9">DETECTS</data>
      <data key="d10">The portable centrifugal microfluidic system is implemented to detect influenza A H3N2 virus by performing on-chip nucleic acid extraction, amplification, and detection of viral RNA.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_25</data>
