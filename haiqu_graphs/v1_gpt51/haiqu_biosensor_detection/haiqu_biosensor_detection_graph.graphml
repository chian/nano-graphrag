      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A biosensing platform that uses in vitro transcription of fluorescence-activated RNA aptamers to generate a fluorescent readout for detection outside the lab.</data>
      <data key="d3">0.78</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_44</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
