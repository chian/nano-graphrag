      <data key="d0">FLUORIDE 2 PPM EPA LIMIT</data>
      <data key="d1">LIMIT_OF_DETECTION</data>
      <data key="d2">Approximate detection threshold of the riboswitch-based fluoride sensor, around 2 ppm, corresponding to the EPA regulatory limit for fluoride in drinking water.</data>
      <data key="d3">0.76</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_43</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="FLUORESCENCE-ACTIVATED RNA APTAMER BIOSENSING PLATFORM">
