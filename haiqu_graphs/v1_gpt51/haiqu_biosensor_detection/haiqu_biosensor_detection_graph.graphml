      <data key="d0">SMARTPHONE-BASED BIOSENSING SYSTEMS</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Biosensing systems that incorporate smartphone-based analysis to provide low-cost, portable, and efficient diagnostics for health and hazard detection, analogous to other reported smartphone-enabled biosensing devices.</data>
      <data key="d3">0.5</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_47</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
