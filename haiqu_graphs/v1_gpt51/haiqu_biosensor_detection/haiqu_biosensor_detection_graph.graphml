    </node>
    <node id="COLLOIDAL GOLD IMMUNOCHROMATOGRAPHIC ASSAY FOR SARS-COV-2 ANTIBODIES (CGICA)">
      <data key="d0">COLLOIDAL GOLD IMMUNOCHROMATOGRAPHIC ASSAY FOR SARS-COV-2 ANTIBODIES (CGICA)</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A colloidal gold immunochromatographic assay based on a dual-antigen sandwich principle using AuNPs, designed to rapidly detect both IgM and IgG antibodies against SARS-CoV-2 in human blood with high sensitivity and specificity.</data>
      <data key="d3">0.86</data>
      <data key="d4">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_84</data>
