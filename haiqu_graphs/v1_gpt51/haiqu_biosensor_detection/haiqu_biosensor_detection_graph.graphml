      <data key="d3">0.82</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_111</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="MULTIPLEXED ELECTROCHEMICAL GENE-CIRCUIT-BASED SENSOR INTERFACE">
      <data key="d0">MULTIPLEXED ELECTROCHEMICAL GENE-CIRCUIT-BASED SENSOR INTERFACE</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A multiplexed electrochemical interface that couples gene circuits to electrochemical readouts for biosensing applications, enabling simultaneous detection of multiple targets.</data>
      <data key="d3">0.7</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_112</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="MULTIPLEXED AND PORTABLE CAS13/CAS12A/CSM6 NUCLEIC ACID DETECTION PLATFORM">
      <data key="d0">MULTIPLEXED AND PORTABLE CAS13/CAS12A/CSM6 NUCLEIC ACID DETECTION PLATFORM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A portable, multiplexed nucleic acid detection platform that integrates Cas13, Cas12a, and Csm6 effectors to enable flexible and sensitive detection of diverse nucleic acid targets.</data>
      <data key="d3">0.98</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_112</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="FIELD-DEPLOYABLE VIRAL DIAGNOSTICS USING CRISPR-CAS13">
      <data key="d0">FIELD-DEPLOYABLE VIRAL DIAGNOSTICS USING CRISPR-CAS13</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A CRISPR-Cas13-based diagnostic platform designed for field-deployable viral detection, leveraging Cas13’s RNA-targeting and collateral cleavage activity for sensitive viral nucleic acid detection.</data>
      <data key="d3">0.9</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_113</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="CRISPR-CAS12A CIS- AND TRANS-CLEAVAGE ACTIVITY ASSAY">
      <data key="d0">CRISPR-CAS12A CIS- AND TRANS-CLEAVAGE ACTIVITY ASSAY</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An assay platform that characterizes and exploits the cis- and trans-cleavage activities of CRISPR-Cas12a on single-stranded DNA for nucleic acid detection applications.</data>
      <data key="d3">0.8</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_113</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="CAS12A TARGET-BINDING DNASE ACTIVITY ASSAY">
      <data key="d0">CAS12A TARGET-BINDING DNASE ACTIVITY ASSAY</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An experimental Cas12a-based detection system characterized by Chen et al., in which target binding unleashes indiscriminate single-stranded DNase activity that can be harnessed for nucleic acid detection.</data>
      <data key="d3">0.82</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_114</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <edge source="PAC-MAN" target="CAS13D">
      <data key="d7">PAC-MAN</data>
      <data key="d8">CAS13D</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">The PAC-MAN antiviral platform employs the Cas13d effector as its CRISPR enzyme to mediate RNA-targeted cleavage of viral genomes.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_75</data>
      <data key="d14">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </edge>
    <edge source="PAC-MAN" target="CRISPR RNAS (CRRNA) TARGETING CONSERVED VIRAL REGIONS">
      <data key="d7">PAC-MAN</data>
      <data key="d8">CRISPR RNAS (CRRNA) TARGETING CONSERVED VIRAL REGIONS</data>
      <data key="d9">USES_GUIDE</data>
      <data key="d10">The PAC-MAN platform uses designed crRNAs that target conserved viral genome regions to guide Cas13d to specific viral RNA sequences.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_75</data>
      <data key="d14">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </edge>
    <edge source="PAC-MAN" target="H1N1 IAV">
      <data key="d7">PAC-MAN</data>
      <data key="d8">H1N1 IAV</data>
      <data key="d9">DETECTS</data>
      <data key="d10">Within the PAC-MAN platform, Cas13d guided by crRNAs recognizes and cleaves H1N1 IAV RNA in respiratory epithelial cells, functionally detecting and suppressing this influenza A virus.</data>
      <data key="d11">0.85</data>
      <data key="d12">2</data>
      <data key="d13">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_75</data>
      <data key="d14">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </edge>
    <edge source="PAC-MAN" target="SARS-COV-2">
      <data key="d7">PAC-MAN</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">DETECTS</data>
      <data key="d10">The PAC-MAN system detects and targets SARS-CoV-2 RNA, including multiple variants, via Cas13d and conserved-region-targeting crRNAs, leading to broad-spectrum inhibition.</data>
      <data key="d11">0.9</data>
      <data key="d12">2</data>
      <data key="d13">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_75</data>
      <data key="d14">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </edge>
    <edge source="PAC-MAN" target="ENDEMIC HUMAN CORONAVIRUS STRAINS">
      <data key="d7">PAC-MAN</data>
      <data key="d8">ENDEMIC HUMAN CORONAVIRUS STRAINS</data>
      <data key="d9">DETECTS</data>
      <data key="d10">PAC-MAN detects and cleaves RNA from multiple endemic human coronavirus strains, reducing viral titers by more than 99% through Cas13d–crRNA-mediated targeting.</data>
      <data key="d11">0.85</data>
      <data key="d12">2</data>
      <data key="d13">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_75</data>
      <data key="d14">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </edge>
    <edge source="CAS13D" target="CRISPR RNAS (CRRNA) TARGETING CONSERVED VIRAL REGIONS">
      <data key="d7">CAS13D</data>
      <data key="d8">CRISPR RNAS (CRRNA) TARGETING CONSERVED VIRAL REGIONS</data>
      <data key="d9">USES_GUIDE</data>
      <data key="d10">Cas13d in the PAC-MAN system is directed by specific crRNAs that recognize conserved viral RNA regions, enabling sequence-specific cleavage.</data>
      <data key="d11">0.9</data>
      <data key="d12">2</data>
      <data key="d13">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_75</data>
      <data key="d14">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </edge>
    <edge source="CAS12A" target="SARS-COV-2">
      <data key="d7">CAS12A</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">DETECTS</data>
      <data key="d10">Cas12a-based CRISPR diagnostic configurations are used to detect SARS-CoV-2 by recognizing specific viral DNA targets or cDNA derived from viral RNA, triggering collateral cleavage for signal generation. | In the study by Lu et al., Cas12a-based CRISPR assays using suboptimal protospacer adjacent motifs are applied to detect SARS-CoV-2 RNA with high speed and sensitivity. | Cas12a, as a specific Cas12-family nuclease, is used in CRISPR diagnostic platforms that target SARS-CoV-2, leveraging its collateral DNase activity upon binding viral nucleic acid sequences.</data>
      <data key="d11">0.88</data>
      <data key="d12">2</data>
      <data key="d13">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_85</data>
      <data key="d14">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a,de3c3a3b-6855-4b40-bff9-eef9df2e0d4b</data>
    </edge>
    <edge source="CAS12A" target="GUIDE RNA">
      <data key="d7">CAS12A</data>
      <data key="d8">GUIDE RNA</data>
      <data key="d9">USES_GUIDE</data>
      <data key="d10">Cas12a requires a complementary guide RNA–target gene duplex to activate its trans-cleavage activity, making the guide RNA essential for sequence-specific function in the assay.</data>
      <data key="d11">0.88</data>
      <data key="d12">2</data>
      <data key="d13">8b626067-a7f3-4d8f-bbf1-8f50269e849c_chunk_208</data>
      <data key="d14">8b626067-a7f3-4d8f-bbf1-8f50269e849c</data>
    </edge>
    <edge source="CAS12A" target="NUCLEIC ACID AMPLIFICATION">
      <data key="d7">CAS12A</data>
      <data key="d8">NAA</data>
      <data key="d9">USES_AMPLIFICATION</data>
      <data key="d10">In one-pot CRISPR–NAA formats, Cas12a-based detection relies on amplicons generated by NAA, but its cleavage activity can consume these amplicons during amplification, reducing NAA efficiency and assay performance.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_6</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
    <edge source="CAS12A" target="GRNAS WITH SUBOPTIMAL OR MISSING PROTOSPACER ADJACENT MOTIF RECOGNITION SEQUENCES">
      <data key="d7">CAS12A</data>
      <data key="d8">GRNAS WITH SUBOPTIMAL OR MISSING PROTOSPACER ADJACENT MOTIF RECOGNITION SEQUENCES</data>
      <data key="d9">USES_GUIDE</data>
      <data key="d10">Cas12a is programmed with gRNAs that have suboptimal or missing PAM recognition sequences to intentionally reduce its cleavage efficiency, thereby limiting amplicon depletion during NAA while maintaining detectable CRISPR activity.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_6</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
    <edge source="CAS12A" target="MODIFIED GRNAS WITH PHOTODEGRADABLE MOLECULAR LOCKS">
      <data key="d7">CAS12A</data>
      <data key="d8">MODIFIED GRNAS WITH PHOTODEGRADABLE MOLECULAR LOCKS</data>
      <data key="d9">USES_GUIDE</data>
      <data key="d10">Cas12a can be paired with modified gRNAs containing photodegradable molecular locks that initially block target recognition; upon light exposure, the locks are removed, allowing controlled onset of Cas12a activity after sufficient amplification.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_6</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
    <edge source="CAS12A" target="ΔF1 SIGNAL">
      <data key="d7">CAS12A</data>
      <data key="d8">ΔF1 SIGNAL</data>
      <data key="d9">PRODUCES_SIGNAL</data>
      <data key="d10">Cas12a, when active at 37 °C with its gRNA, generates the RNase P–specific ΔF1 fluorescent signal in the TRACE duplex assay.</data>
      <data key="d11">0.9</data>
      <data key="d12">2</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_25</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
    <edge source="CAS12A" target="RNASE P GRNA">
      <data key="d7">CAS12A</data>
      <data key="d8">RNASE P GRNA</data>
      <data key="d9">USES_GUIDE</data>
      <data key="d10">Cas12a USES_GUIDE the RNase P gRNA because this guide uniquely satisfies Cas12a binding criteria in the TRACE duplex assay, enabling specific recognition of the RNase P target in the first stage. | Cas12a forms a ribonucleoprotein complex with the RNase P gRNA in the TRACE duplex assay to recognize the RNase P gene and trigger collateral cleavage of the fluorescent reporter.</data>
      <data key="d11">0.95</data>
      <data key="d12">2</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_34</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
    <edge source="CAS12A" target="RNASE P TARGET">
      <data key="d7">CAS12A</data>
      <data key="d8">RNASE P TARGET</data>
      <data key="d9">DETECTS</data>
      <data key="d10">Cas12a DETECTS the RNase P target in the first stage of the TRACE duplex assay when directed by the RNase P gRNA, generating the stage-1 reporter signal.</data>
      <data key="d11">0.9</data>
      <data key="d12">2</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_34</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
    <edge source="CAS12A" target="SIGNAL PRODUCED IN THE FIRST ASSAY STAGE">
      <data key="d7">CAS12A</data>
      <data key="d8">SIGNAL PRODUCED IN THE FIRST ASSAY STAGE</data>
      <data key="d9">PRODUCES_SIGNAL</data>
      <data key="d10">Cas12a PRODUCES_SIGNAL the reporter signal observed in the first assay stage upon recognition and cleavage of the RNase P target, with no contribution from Cas12b due to its inhibition.</data>
      <data key="d11">0.9</data>
      <data key="d12">2</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_34</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
    <edge source="CAS12A" target="J2L GRNA">
      <data key="d7">CAS12A</data>
      <data key="d8">J2L GRNA</data>
      <data key="d9">USES_GUIDE</data>
      <data key="d10">Cas12a is paired with the J2L gRNA in the duplex assay to recognize the J2L gene target and contribute to the dual-target fluorescence signal.</data>
      <data key="d11">0.84</data>
      <data key="d12">2</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_45</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
    <edge source="CAS12A" target="FLUORESCENCE">
      <data key="d7">CAS12A</data>
      <data key="d8">FLUORESCENCE</data>
      <data key="d9">PRODUCES_SIGNAL</data>
      <data key="d10">Activated Cas12a exhibits collateral trans-cleavage of fluorescently labeled reporter oligonucleotides, directly producing a fluorescence signal that serves as the assay readout.</data>
      <data key="d11">0.94</data>
      <data key="d12">2</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_28</data>
      <data key="d14">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b</data>
    </edge>
    <edge source="CAS12A" target="PAPER-BASED LATERAL FLOW STRIPS">
      <data key="d7">CAS12A</data>
      <data key="d8">PAPER-BASED LATERAL FLOW STRIPS</data>
      <data key="d9">PRODUCES_SIGNAL</data>
      <data key="d10">Cas12a-mediated cleavage of labeled reporters can be translated into a visible signal on lateral flow strips, where the presence or absence of bands reflects Cas12a activity and thus target detection.</data>
      <data key="d11">0.88</data>
      <data key="d12">2</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_28</data>
      <data key="d14">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b</data>
    </edge>
    <edge source="CAS12A" target="SMARTPHONE-INTEGRATED READOUTS">
      <data key="d7">CAS12A</data>
      <data key="d8">SMARTPHONE-INTEGRATED READOUTS</data>
      <data key="d9">PRODUCES_SIGNAL</data>
      <data key="d10">The collateral cleavage activity of Cas12a on reporter molecules generates optical or colorimetric changes that can be captured by smartphone cameras or sensors for quantitative readout.</data>
      <data key="d11">0.86</data>
      <data key="d12">2</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_28</data>
      <data key="d14">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b</data>
    </edge>
    <edge source="CRISPR-CAS-BASED NANOPROBES FOR VIRAL GENE DETECTION" target="CAS13">
      <data key="d7">CRISPR-CAS-BASED NANOPROBES FOR VIRAL GENE DETECTION</data>
      <data key="d8">CAS13</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">The CRISPR-Cas-based nanoprobes incorporate Cas13 to recognize and cleave target viral RNA sequences for gene detection.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_81</data>
      <data key="d14">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </edge>
    <edge source="CRISPR-CAS-BASED NANOPROBES FOR VIRAL GENE DETECTION" target="CAS12A">
      <data key="d7">CRISPR-CAS-BASED NANOPROBES FOR VIRAL GENE DETECTION</data>
      <data key="d8">CAS12A</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">The CRISPR-Cas-based nanoprobes use Cas12a as a DNA-targeting effector to detect viral DNA or DNA copies of viral genomes.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_81</data>
      <data key="d14">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </edge>
    <edge source="CRISPR-CAS-BASED NANOPROBES FOR VIRAL GENE DETECTION" target="CSM6">
      <data key="d7">CRISPR-CAS-BASED NANOPROBES FOR VIRAL GENE DETECTION</data>
      <data key="d8">CSM6</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">The CRISPR-Cas-based nanoprobes employ Csm6 as an auxiliary CRISPR-associated RNase to amplify the detection signal downstream of Cas13 or Cas12a activation.</data>
      <data key="d11">0.85</data>
