      <data key="d0">VIRUS EXTRACTION AND WASHING</data>
      <data key="d1">SAMPLE_PREP_STEP</data>
      <data key="d2">A magnetic microbead-based extraction and washing step in the integrated influenza A microfluidic system that captures and cleans viral particles or nucleic acids before amplification.</data>
      <data key="d3">0.8</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_24</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
