      <data key="d8">RESPIRATORY SWAB RNA EXTRACTS</data>
      <data key="d9">REQUIRES_PREP</data>
      <data key="d10">The DETECTR lateral flow assay operates on RNA extracted from respiratory swabs, requiring this extraction step before CRISPR-based detection.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d14">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </edge>
