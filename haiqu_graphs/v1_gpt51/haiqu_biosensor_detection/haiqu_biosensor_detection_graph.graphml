      <data key="d8">QPCR</data>
      <data key="d9">OUTPERFORMS</data>
      <data key="d10">TRACE outperforms qPCR in terms of cost per test and turnaround time while maintaining comparable diagnostic accuracy.</data>
      <data key="d11">0.85</data>
