      <data key="d0">COLORIMETRIC REPORTER SIGNAL</data>
      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">A color change-based output that is easier to detect by the naked eye than fluorescence, used as an alternative readout in some biosensing platforms.</data>
      <data key="d3">0.6</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_44</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
