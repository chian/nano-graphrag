      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An origami-style microfluidic paper-based analytical device (mPAD) that performs on-chip DNA extraction and processing using passive capillary flow and paper folding.</data>
      <data key="d3">0.7</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_26</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
