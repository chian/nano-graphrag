      <data key="d9">USES_AMPLIFICATION</data>
      <data key="d10">The contamination-free SARS-CoV-2 visual assay incorporates a nucleic acid amplification reaction in conjunction with Cas12a detection to achieve sufficient sensitivity for point-of-care diagnostics in a sealed system.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_4</data>
