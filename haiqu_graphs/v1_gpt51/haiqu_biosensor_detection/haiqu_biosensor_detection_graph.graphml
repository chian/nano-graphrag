    <edge source="MASKLESS, LASER-PATTERNED PMMA MICROFLUIDIC APTASENSOR WITH INTEGRATED ELECTRODES" target="FE₃O₄@TMU-8 NANOCOMPOSITE REDOX-RECYCLING AMPLIFICATION">
      <data key="d7">MASKLESS, LASER-PATTERNED PMMA MICROFLUIDIC APTASENSOR WITH INTEGRATED ELECTRODES</data>
      <data key="d8">FE₃O₄@TMU-8 NANOCOMPOSITE REDOX-RECYCLING AMPLIFICATION</data>
      <data key="d9">USES_AMPLIFICATION</data>
      <data key="d10">The PMMA microfluidic aptasensor employs an Fe₃O₄@TMU-8 nanocomposite-based redox-recycling amplification method to catalyze RuHex redox cycling and enhance the electrochemical detection signal.</data>
      <data key="d11">0.92</data>
      <data key="d12">1</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_51</data>
