      <data key="d7">TRACE DUPLEX ASSAYS</data>
      <data key="d8">REPORTER SIGNAL</data>
      <data key="d9">PRODUCES_SIGNAL</data>
      <data key="d10">TRACE duplex assays PRODUCES_SIGNAL a reporter signal whose timing (first versus second stage) encodes which Cas effector and corresponding target amplicon has been recognized.</data>
      <data key="d11">0.96</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_34</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
