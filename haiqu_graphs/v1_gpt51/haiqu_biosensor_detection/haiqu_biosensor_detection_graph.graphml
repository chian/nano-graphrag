      <data key="d3">0.8</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_29</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
    <node id="KEYCHAIN-MOUNTED UV LIGHT">
      <data key="d0">KEYCHAIN-MOUNTED UV LIGHT</data>
      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">A portable UV excitation source used to visualize the fluorescent signal produced by isothermal amplification in the self-heating cartridge.</data>
      <data key="d3">0.6</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_29</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
