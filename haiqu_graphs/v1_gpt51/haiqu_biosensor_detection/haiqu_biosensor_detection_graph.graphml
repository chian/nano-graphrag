      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">Optical reporter output based on fluorescence used by synthetic biosensors for hazard detection and remote monitoring. | Optical reporter output based on bioluminescence used by biosensors for remote detection via drones or satellite-based luminescence sensors.</data>
      <data key="d3">0.82</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_51</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
      <data key="d6">LUMINESCENCE REPORTER SIGNAL</data>
    </node>
