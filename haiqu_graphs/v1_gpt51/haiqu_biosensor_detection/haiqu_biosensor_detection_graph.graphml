      <data key="d8">CAS12A</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">The one-pot RT-RPA–Cas12a platform employs Cas12a as its core CRISPR effector nuclease, leveraging its target-activated collateral DNase activity for signal generation in a single-tube assay.</data>
      <data key="d11">0.98</data>
      <data key="d12">1</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_37</data>
