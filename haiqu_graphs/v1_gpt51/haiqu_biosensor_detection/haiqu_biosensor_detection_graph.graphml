      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A colorimetric biosensor platform in which oligonucleotide-capped gold nanoparticles aggregate, producing a visible color change for SARS-CoV-2 detection.</data>
      <data key="d3">0.95</data>
      <data key="d4">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_82</data>
      <data key="d5">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
