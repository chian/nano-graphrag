      <data key="d8">SMARTPHONE CONNECTIVITY</data>
      <data key="d9">PRODUCES_SIGNAL</data>
      <data key="d10">The TRACE system uses smartphone connectivity to enable real-time data analysis and support on-site epidemic surveillance.</data>
      <data key="d11">0.75</data>
      <data key="d12">2</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_36</data>
