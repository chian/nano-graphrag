    <node id="HIGH ANALYTICAL SENSITIVITY DOWN TO 4,500 IU/ML ON HCV RNA-POSITIVE SAMPLES">
      <data key="d0">HIGH ANALYTICAL SENSITIVITY DOWN TO 4,500 IU/ML ON HCV RNA-POSITIVE SAMPLES</data>
      <data key="d1">ASSAY_VALIDATION</data>
      <data key="d2">Analytical performance characterization of the lab-in-a-cartridge qRT-PCR system, demonstrating sensitivity to 4,500 IU/mL on HCV RNA-positive samples.</data>
      <data key="d3">0.9</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_29</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
    <node id="HIGH CORRELATION WITH LABORATORY-BASED VIRAL QUANTIFICATION AND BENCHTOP PCR">
