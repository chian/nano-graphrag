      <data key="d0">RIBOSWITCH-BASED FLUORIDE SENSOR</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Cell-free riboswitch-based biosensor for colorimetric detection of fluoride contamination in groundwater samples, capable of detecting concentrations around 2 ppm (the EPA limit).</data>
      <data key="d3">0.82</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_43</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="ROSALIND CELL-FREE BIOSENSING SYSTEM">
      <data key="d0">ROSALIND CELL-FREE BIOSENSING SYSTEM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">RNA Output Sensors Activated by Ligand Induction (ROSALIND), a rapid, shelf-stable cell-free biosensing platform that uses allosteric regulation of in vitro transcription of fluorescence-activated RNA aptamers to detect a wide range of water contaminants.</data>
      <data key="d3">0.9</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_43</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="FLUORESCENCE-ACTIVATED RNA APTAMER SIGNAL">
      <data key="d0">FLUORESCENCE-ACTIVATED RNA APTAMER SIGNAL</data>
      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">Fluorescent reporter signal generated by RNA aptamers transcribed in vitro in response to ligand binding in the ROSALIND biosensing platform.</data>
      <data key="d3">0.7</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_43</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="COLORIMETRIC SIGNAL">
      <data key="d0">COLORIMETRIC SIGNAL</data>
      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">Visually detectable color change used as the readout for several cell-free biosensors, including endocrine disruptor and fluoride detection platforms.</data>
      <data key="d3">0.65</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_43</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
