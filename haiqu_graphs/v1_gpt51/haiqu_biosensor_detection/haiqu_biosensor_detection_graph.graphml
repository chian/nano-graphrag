      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Field-effect transistor (FET) based biosensor platform where capture DNA probes are immobilized on a semiconductor channel and target nucleic acids are detected via changes in electric current.</data>
      <data key="d3">0.9</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_18</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
