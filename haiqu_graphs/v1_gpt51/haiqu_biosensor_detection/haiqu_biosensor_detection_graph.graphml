    <edge source="TRACE ASSAY" target="TRACE F18 SIGNAL">
      <data key="d7">TRACE ASSAY</data>
      <data key="d8">TRACE SIGNAL</data>
      <data key="d9">PRODUCES_SIGNAL</data>
      <data key="d10">When MPXV nucleic acid is present, the TRACE assay produces a quantifiable TRACE signal (including F18 at 18 minutes), which is used to determine positivity and to correlate with qPCR Ct values.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_16</data>
