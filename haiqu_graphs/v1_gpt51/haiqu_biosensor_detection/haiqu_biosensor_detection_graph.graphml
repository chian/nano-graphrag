      <data key="d0">POLYMER MICROFLUIDICS</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Microfluidic platforms fabricated from polymer materials, mentioned as another class of user-friendly biosensing devices suitable for integration with multi-step sampling and processing workflows.</data>
      <data key="d3">0.5</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_47</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
