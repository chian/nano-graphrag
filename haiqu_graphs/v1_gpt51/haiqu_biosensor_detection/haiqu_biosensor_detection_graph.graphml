      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An Argonaute-based biosensing platform enabling visual, rebuilding-free detection of foodborne pathogenic bacteria, reported in Journal of Hazardous Materials 454, 131485 (2023).</data>
      <data key="d3">0.85</data>
      <data key="d4">8cd80207-0825-48ce-af82-eed721eee13b_chunk_57</data>
      <data key="d5">8cd80207-0825-48ce-af82-eed721eee13b</data>
    </node>
