      <data key="d7">TRACE ASSAY</data>
      <data key="d8">CRISPR/CAS12B</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">TRACE uses the Cas12b CRISPR effector as a temperature-activated detection enzyme that recognizes amplified targets and cleaves reporter probes during the high-temperature stage.</data>
      <data key="d11">0.97</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_9</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
