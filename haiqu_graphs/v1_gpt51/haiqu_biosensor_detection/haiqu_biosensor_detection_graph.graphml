      <data key="d7">AIRBORNE BIOSENSOR DATA</data>
      <data key="d8">HIGHLY PATHOGENIC AVIAN INFLUENZA</data>
      <data key="d9">DETECTS</data>
      <data key="d10">The airborne biosensor component contributes environmental detection capability for signatures associated with highly pathogenic avian influenza in air samples as part of continuous monitoring.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_68</data>
