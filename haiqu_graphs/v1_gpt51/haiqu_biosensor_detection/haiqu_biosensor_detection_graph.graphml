      <data key="d9">DETECTS</data>
      <data key="d10">The capacitive airborne biosensor reports H5N1 within approximately 5 minutes, indicating rapid airborne detection of this influenza subtype in environmental air samples.</data>
      <data key="d11">0.9</data>
      <data key="d12">2</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_42</data>
