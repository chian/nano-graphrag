      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An Argonaute protein used as the core nuclease in the ANCA method, forming Ago/guide DNA complexes that cleave reporter strands and drive the positive feedback amplification circuit.</data>
      <data key="d3">0.9</data>
      <data key="d4">8cd80207-0825-48ce-af82-eed721eee13b_chunk_15,8cd80207-0825-48ce-af82-eed721eee13b_chunk_38</data>
