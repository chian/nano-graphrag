      <data key="d8">DAAPCAS12B</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">The CRISPR detection step employs the dAapCas12b nuclease as its effector enzyme to mediate target recognition and signal generation.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_38</data>
