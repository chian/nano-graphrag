      <data key="d7">TRACE ASSAY</data>
      <data key="d8">NUCLEIC ACID EXTRACTS</data>
      <data key="d9">REQUIRES_PREP</data>
      <data key="d10">The TRACE assay is performed on nucleic acid extracts derived from clinical specimens, indicating that nucleic acid extraction is a required sample preparation step before detection.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_16</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
