      <data key="d0">BIOCOMPATIBLE HYDROGEL-BASED WEARABLE SENSORS</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Biocompatible hydrogel-based biosensing platforms designed to be worn on the body to continuously monitor health-related parameters and biomarkers in field conditions. | Biocompatible hydrogel-based biosensing platforms designed for implantation in the body to enable continuous, long-term monitoring of physiological signals and biomarkers.</data>
      <data key="d3">0.85</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_49</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
      <data key="d6">BIOCOMPATIBLE HYDROGEL-BASED IMPLANTABLE SENSORS</data>
    </node>
    <node id="CELLULAR DETECTORS FOR REAL-TIME BIOMARKER DETECTION">
      <data key="d0">CELLULAR DETECTORS FOR REAL-TIME BIOMARKER DETECTION</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Biosensing platforms based on living cells engineered to detect and report on specific biomarkers in real time, enabling proactive monitoring of health and safety issues.</data>
      <data key="d3">0.8</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_49</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
