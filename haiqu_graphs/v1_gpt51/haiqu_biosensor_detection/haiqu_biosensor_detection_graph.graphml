      <data key="d0">MPXV DNA</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Monkeypox virus DNA, specifically the nucleic acid target detected by the TRACE assay in synthetic samples, including the J2L gene region.</data>
      <data key="d3">0.8</data>
      <data key="d4">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_14</data>
      <data key="d5">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </node>
    <node id="J2L GENE">
      <data key="d0">J2L GENE</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">A specific gene of MPXV used as the primary nucleic acid target in the TRACE assay; limits of detection are reported in J2L gene copies per test.</data>
      <data key="d3">0.9</data>
      <data key="d4">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_14,6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_46</data>
      <data key="d5">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </node>
