      <data key="d9">HAS_LOD</data>
      <data key="d10">The dual CRISPR-Cas12a assay is reported to detect as low as a few copies of SARS-CoV-2, indicating a very low limit of detection.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d14">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </edge>
