      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Diagnostic biosensing tests that can be seamlessly integrated with continuous health monitoring platforms to provide combined real-time sensing and diagnostic capabilities.</data>
      <data key="d3">0.7</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_49</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="CELL-FREE BIOSENSOR PLATFORM">
      <data key="d0">CELL-FREE BIOSENSOR PLATFORM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Biosensing systems based on cell-free gene expression or biochemical reactions, engineered for fluorescence or luminescence outputs and suitable for austere, long-duration field deployment.</data>
      <data key="d3">0.86</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_51</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
