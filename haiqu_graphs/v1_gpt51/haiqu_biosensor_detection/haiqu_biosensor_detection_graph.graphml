      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">The real-time quantitative signal corresponding to glucose concentration in interstitial fluid, monitored by the microneedle skin patch biosensor.</data>
      <data key="d3">0.88</data>
      <data key="d4">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_526</data>
      <data key="d5">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
