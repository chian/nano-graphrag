      <data key="d0">LYOPHILIZATION FOR SHELF STABILITY</data>
      <data key="d1">SAMPLE_PREP_STEP</data>
      <data key="d2">A sample and reagent preparation step in which biosensing components are freeze-dried to enable shelf stability for at least 2.5 months.</data>
      <data key="d3">0.75</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_44</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
