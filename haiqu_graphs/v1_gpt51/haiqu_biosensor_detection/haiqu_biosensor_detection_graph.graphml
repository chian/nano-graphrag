      <data key="d1">SAMPLE_PREP_STEP</data>
      <data key="d2">An incubation approach that uses a patient’s own body heat to reach approximately 37°C for running biosensing reactions in the field.</data>
      <data key="d3">0.68</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_44</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="SINGLE-GUIDE RNA">
      <data key="d0">SINGLE-GUIDE RNA</data>
      <data key="d1">GUIDE_RNA</data>
      <data key="d2">The guide RNA component used in the CRISPR-chip platform to direct dCas9 to specific target nucleic acid sequences for sequence-specific electrical detection.</data>
      <data key="d3">0.7</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_47</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
