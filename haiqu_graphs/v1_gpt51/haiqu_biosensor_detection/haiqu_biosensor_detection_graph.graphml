    <node id="EVALUATION OF LAMP ASSAYS AS RAPID DIAGNOSTICS FOR COVID-19">
      <data key="d0">EVALUATION OF LAMP ASSAYS AS RAPID DIAGNOSTICS FOR COVID-19</data>
      <data key="d1">ASSAY_VALIDATION</data>
      <data key="d2">An analysis discussing and evaluating LAMP assays as rapid diagnostics for COVID-19, providing performance and feasibility insights for LAMP-based detection of SARS-CoV-2 infection.</data>
      <data key="d3">0.7</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_48</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
    <node id="COVID-19 TESTING PROGRAM, PUBLIC HEALTH ONTARIO">
      <data key="d0">COVID-19 TESTING PROGRAM, PUBLIC HEALTH ONTARIO</data>
      <data key="d1">ASSAY_VALIDATION</data>
      <data key="d2">The COVID-19 testing program and associated laboratory service documentation from Public Health Ontario, providing institutional guidance and validation context for SARS-CoV-2 diagnostic assays.</data>
      <data key="d3">0.5</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_48</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
