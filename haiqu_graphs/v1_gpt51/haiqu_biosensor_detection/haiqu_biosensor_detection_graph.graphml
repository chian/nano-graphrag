      <data key="d8">H5 SUBTYPE AVIAN INFLUENZA VIRUS</data>
      <data key="d9">DETECTS</data>
      <data key="d10">The assay is designed for on-site and visual detection of H5 subtype avian influenza virus in poultry-related samples, serving as a rapid confirmatory test.</data>
      <data key="d11">0.96</data>
      <data key="d12">1</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_36</data>
      <data key="d14">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b</data>
    </edge>
