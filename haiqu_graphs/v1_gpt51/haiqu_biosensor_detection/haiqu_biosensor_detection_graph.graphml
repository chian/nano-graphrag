      <data key="d0">ENZYMATICALLY GENERATED CDS QUANTUM DOTS ON MICROSPHERES</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A microbead QD-ELISA platform where CdS quantum dots are enzymatically generated and immobilized on microspheres for electrochemical and fluorescence detection of superoxide dismutase 2, achieving detection limits at least three orders of magnitude better than previous assays.</data>
      <data key="d3">0.9</data>
      <data key="d4">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_83</data>
      <data key="d5">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </node>
