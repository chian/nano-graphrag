      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A point-of-use, cell-free biosensor that uses a riboswitch to detect environmental fluoride, designed for deployment in low-resource settings.</data>
      <data key="d3">0.8</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_44</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
