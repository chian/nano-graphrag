      <data key="d8">SSRNA GRNA INHIBITOR</data>
      <data key="d9">USES_GUIDE</data>
      <data key="d10">TRACE uses an ssRNA gRNA inhibitor as a guide-RNA-based regulatory element to modulate Cas effector activity in a temperature-dependent manner, contributing to temporal segregation of amplification and CRISPR detection.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_8</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
