      <data key="d0">COLORIMETRIC DNA DETECTION</data>
      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">A colorimetric readout used in the instrument-free microfluidic platform for Zika virus detection to visually indicate the presence of amplified target DNA.</data>
      <data key="d3">0.85</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_24</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
