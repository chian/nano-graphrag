      <data key="d7">TRACE DUPLEX ASSAYS</data>
      <data key="d8">RNASE P TARGET</data>
      <data key="d9">DETECTS</data>
      <data key="d10">TRACE duplex assays DETECTS the RNase P target via Cas12a in the first temperature stage, with reporter signal in that stage exclusively reflecting recognition of this target.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_34</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
