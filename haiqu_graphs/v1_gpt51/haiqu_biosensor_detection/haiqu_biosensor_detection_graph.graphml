      <data key="d0">PHAGE-BASED NANOPARTICLE SPR VIRUS DETECTION SYSTEM</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A virus detection platform using nanoparticles based on phage technology to enhance surface plasmon resonance (SPR) signals for improved viral sensing.</data>
      <data key="d3">0.8</data>
      <data key="d4">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_82</data>
      <data key="d5">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </node>
