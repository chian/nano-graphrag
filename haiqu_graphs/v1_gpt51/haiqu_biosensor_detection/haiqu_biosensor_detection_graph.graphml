      <data key="d9">HAS_SPECIFICITY</data>
      <data key="d10">Specificity testing of the TRACE assay showed no detectable cross-reactivity with other orthopoxviruses or clinically similar pathogens, indicating high analytical specificity for MPXV.</data>
      <data key="d11">0.94</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_14</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
