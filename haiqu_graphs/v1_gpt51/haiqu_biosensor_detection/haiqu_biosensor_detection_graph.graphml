      <data key="d7">TRACE ASSAY</data>
      <data key="d8">POLY T REPORTER</data>
      <data key="d9">PRODUCES_SIGNAL</data>
      <data key="d10">The TRACE assay generates its measurable signal via cleavage of a poly T reporter oligonucleotide by activated Cas12b, producing a fluorescent readout optimized for signal-to-noise.</data>
      <data key="d11">0.92</data>
      <data key="d12">1</data>
