      <data key="d0">ONE-POT AND MULTIPLEX ASSAY WORKFLOWS</data>
      <data key="d1">ASSAY_RUN</data>
      <data key="d2">Streamlined diagnostic workflows in which amplification and CRISPR detection occur in a single reaction and multiple targets are detected simultaneously, reducing contamination risk and enabling quality control.</data>
      <data key="d3">0.6</data>
      <data key="d4">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_29</data>
      <data key="d5">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </node>
