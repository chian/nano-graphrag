      <data key="d8">SARS-COV-2</data>
      <data key="d9">DETECTS</data>
      <data key="d10">The dual CRISPR-Cas12a assay is designed for ultrasensitive and visual detection of SARS-CoV-2, achieving detection within approximately 20 minutes.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d14">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </edge>
