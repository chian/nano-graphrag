      <data key="d8">RUHEX ELECTROCHEMICAL SIGNAL</data>
      <data key="d9">PRODUCES_SIGNAL</data>
      <data key="d10">The chip produces an electrochemical reporter signal based on catalytic redox-recycling of RuHex bound to the nucleic-acid phosphate backbone, with current magnitude modulated by target hybridization.</data>
      <data key="d11">0.93</data>
