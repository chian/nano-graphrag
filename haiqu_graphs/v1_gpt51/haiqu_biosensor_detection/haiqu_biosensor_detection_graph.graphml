      <data key="d7">TRACE ASSAY</data>
      <data key="d8">LYOPHILIZATION PERFORMANCE</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The TRACE assay formulations are specifically evaluated for lyophilization performance, which validates whether the assay maintains functionality after freeze-drying and thus supports its robustness for storage and deployment.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_43</data>
