      <data key="d1">SAMPLE_PREP_STEP</data>
      <data key="d2">Post-assay washing-based dehybridization procedure used to remove hybridized nucleic acids from the working electrode surface, enabling regeneration and reuse of electrochemical DNA sensors.</data>
      <data key="d3">0.7</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_17</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
