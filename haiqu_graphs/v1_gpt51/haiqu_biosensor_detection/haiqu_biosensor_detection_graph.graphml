      <data key="d7">CAPACITIVE AIRBORNE BIOSENSOR</data>
      <data key="d8">H5N1 AVIAN INFLUENZA VIRUS</data>
      <data key="d9">DETECTS</data>
      <data key="d10">The capacitive airborne biosensor detects H5N1 avian influenza virus directly in aerosols, reporting its presence within approximately 5 minutes as part of a real-time environmental biosecurity layer.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_42</data>
