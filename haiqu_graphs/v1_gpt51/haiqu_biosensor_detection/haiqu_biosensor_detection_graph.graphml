      <data key="d0">ARGONAUTE-INTEGRATED ISOTHERMAL AMPLIFICATION</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A rapid, portable, multiplex nucleic acid detection platform that integrates Argonaute proteins with isothermal amplification to detect SARS-CoV-2 and influenza viruses, reported in Biosensors and Bioelectronics 207, 114169 (2022).</data>
      <data key="d3">0.9</data>
      <data key="d4">8cd80207-0825-48ce-af82-eed721eee13b_chunk_57</data>
      <data key="d5">8cd80207-0825-48ce-af82-eed721eee13b</data>
    </node>
