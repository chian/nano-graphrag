      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">An integrated paper-based nucleic acid testing device capable of on-chip DNA extraction, LAMP amplification, and lateral flow colorimetric detection, demonstrated for rapid testing of human papillomavirus in crude cervical specimens for cervical cancer diagnosis.</data>
      <data key="d3">0.9</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_26</data>
