      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Electronic nucleic acid sensor based on semiconductor field-effect transistor architecture, where capture DNA probes are immobilized on the semiconductor surface and binding events modulate electronic properties.</data>
      <data key="d3">0.8</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_17</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
