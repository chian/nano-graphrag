      <data key="d9">USES_AMPLIFICATION</data>
      <data key="d10">Photodegradable-lock gRNAs are deployed in one-pot CRISPR–NAA systems so that nucleic acid amplification can proceed with minimal interference from Cas12a until light activation triggers Cas12a-mediated detection.</data>
      <data key="d11">0.7</data>
      <data key="d12">2</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_6</data>
