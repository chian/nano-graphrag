      <data key="d8">SARS-COV-2</data>
      <data key="d9">DETECTS</data>
      <data key="d10">The centrifugal microfluidic platform is being adapted for detection of SARS-CoV-2, using its integrated nucleic acid testing workflow to provide rapid viral RNA detection with a 30–40 minute turnaround time.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_25</data>
      <data key="d14">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </edge>
    <edge source="PORTABLE CENTRIFUGAL MICROFLUIDIC SYSTEM" target="BIND-WASH-ELUTE PROTOCOL ON SILICA-COATED MAGNETIC BEADS">
