      <data key="d7">TRACE ASSAY</data>
      <data key="d8">99.5% DIAGNOSTIC ACCURACY</data>
      <data key="d9">HAS_SPECIFICITY</data>
      <data key="d10">The TRACE assay is reported to maintain approximately 99.5% diagnostic accuracy in comparison to qPCR.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_36</data>
