      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A lateral flow nanoparticle fluorescence immunoassay that detects total antibodies against SARS-CoV-2, offering performance comparable to ELISA while providing shorter and simpler manual handling than conventional lateral flow immunoassays.</data>
      <data key="d3">0.88</data>
      <data key="d4">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_84</data>
      <data key="d5">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </node>
    <node id="CARBON QUANTUM DOT-BASED PAPER IMMUNOASSAY PLATFORM FOR HIV ANTIGEN">
