      <data key="d8">CAS12A</data>
      <data key="d9">USES_VARIANT</data>
      <data key="d10">One-pot CRISPR–NAA assays employ Cas12a as the effector nuclease to detect amplified targets within the same reaction where amplification occurs, creating competition between amplification and Cas12a-mediated target cleavage.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
