      <data key="d8">HPAI</data>
      <data key="d9">DETECTS</data>
      <data key="d10">RT-qPCR sampling functions as a higher-tier confirmatory molecular diagnostic for HPAI, performed after a positive on-site CRISPR assay to validate infection status with greater analytical rigor.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">de3c3a3b-6855-4b40-bff9-eef9df2e0d4b_chunk_66</data>
