    <edge source="SINGLE-SHOT SERS SENSOR WITH MACHINE LEARNING" target="APPROXIMATELY 97% ACCURACY CLASSIFICATION OF MULTIPLE RESPIRATORY VIRUSES IN PATIENT SWAB SAMPLES">
      <data key="d7">SINGLE-SHOT SERS SENSOR WITH MACHINE LEARNING</data>
      <data key="d8">APPROXIMATELY 97% ACCURACY CLASSIFICATION OF MULTIPLE RESPIRATORY VIRUSES IN PATIENT SWAB SAMPLES</data>
      <data key="d9">VALIDATED_BY</data>
