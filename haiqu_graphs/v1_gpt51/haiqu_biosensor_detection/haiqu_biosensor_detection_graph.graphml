      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A set of three biosensing platforms that are lyophilizable and shelf-stable for at least 2.5 months, designed for deployment in low-resource, outside-the-lab environments.</data>
      <data key="d3">0.82</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_44</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
