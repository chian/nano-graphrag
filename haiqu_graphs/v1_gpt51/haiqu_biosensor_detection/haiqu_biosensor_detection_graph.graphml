      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Electrochemical DNA biosensor that uses a capture DNA-modified gold working electrode to detect hepatitis A virus cDNA via direct hybridization, with a reported LOD of 6.94 fg/mL.</data>
      <data key="d3">0.9</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_17</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
