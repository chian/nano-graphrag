      <data key="d0">3D-PRINTED HANDHELD VISUALIZATION DEVICE</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A 3D-printed handheld device coupled to fluorescence-based biosensing platforms to improve visualization of fluorescent signals in field settings.</data>
      <data key="d3">0.6</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_44</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
