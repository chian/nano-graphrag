      <data key="d0">RESPIRATORY SWAB RNA EXTRACTS</data>
      <data key="d1">SAMPLE_PREP_STEP</data>
      <data key="d2">RNA extracted from respiratory swab specimens, used as the prepared input material for the DETECTR lateral flow assay to identify SARS-CoV-2.</data>
      <data key="d3">0.8</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="STORE-BOUGHT HAND WARMER AS THE INCUBATOR">
      <data key="d0">STORE-BOUGHT HAND WARMER AS THE INCUBATOR</data>
      <data key="d1">SAMPLE_PREP_STEP</data>
      <data key="d2">A simple, low-cost heat source used as an incubator to maintain reaction temperature for the dual CRISPR-Cas12a assay, enabling low-infrastructure operation.</data>
      <data key="d3">0.6</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="VISUAL BY EYE WITH THE AID OF AN LED LIGHT">
      <data key="d0">VISUAL BY EYE WITH THE AID OF AN LED LIGHT</data>
      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">A visually readable fluorescence-like signal produced by the dual CRISPR-Cas12a assay, observable by eye under LED illumination, indicating the presence of SARS-CoV-2.</data>
      <data key="d3">0.8</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="QUENCHED SSDNA REPORTER">
      <data key="d0">QUENCHED SSDNA REPORTER</data>
      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">A quenched single-stranded DNA reporter that is cleaved by Cas12a collateral activity in the HOLMES assay, generating a detectable fluorescence signal proportional to target DNA.</data>
      <data key="d3">0.7</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_42</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
    <node id="CELL-FREE PROTEIN SYNTHESIS ENDOCRINE DISRUPTOR BIOSENSOR">
      <data key="d0">CELL-FREE PROTEIN SYNTHESIS ENDOCRINE DISRUPTOR BIOSENSOR</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Portable colorimetric detection platform using cell-free protein synthesis of an allosterically activated fusion protein to sense hTRβ-specific endocrine-disrupting chemicals.</data>
      <data key="d3">0.78</data>
      <data key="d4">4b595dc6-a258-44ed-89fc-c349fc64a77f_chunk_43</data>
      <data key="d5">4b595dc6-a258-44ed-89fc-c349fc64a77f</data>
    </node>
