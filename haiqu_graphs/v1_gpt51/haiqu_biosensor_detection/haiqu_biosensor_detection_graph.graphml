      <data key="d0">FLUORESCENT SIGNAL READOUT</data>
      <data key="d1">REPORTER_SIGNAL</data>
      <data key="d2">A fluorescence-based reporter signal generated and monitored during nucleic-acid amplification, used as the measurable readout indicating presence of target viral nucleic acid.</data>
      <data key="d3">0.9</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_3,ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_11</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
    </node>
    <node id="COMMERCIAL RT-PCR KITS FOR COVID-19 TESTING">
      <data key="d0">COMMERCIAL RT-PCR KITS FOR COVID-19 TESTING</data>
      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">Regulatorily approved diagnostic kits that implement RT-PCR-based nucleic-acid amplification workflows to detect SARS-CoV-2 in patient specimens for COVID-19 testing.</data>
      <data key="d3">0.9</data>
      <data key="d4">ed45ef2f-ad29-4058-8b09-5fed00b411a1_chunk_3</data>
      <data key="d5">ed45ef2f-ad29-4058-8b09-5fed00b411a1</data>
