      <data key="d8">GRNA</data>
      <data key="d9">USES_GUIDE</data>
      <data key="d10">The assay relies on guide RNAs that complex with Cas12a and Cas12b to direct sequence-specific recognition of RNase P and MPXV J2L targets in a duplex format.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_25</data>
      <data key="d14">6f94756d-fd42-4a77-b6b1-d9dc6901591d</data>
    </edge>
