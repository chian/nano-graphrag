      <data key="d1">BIOSENSOR_PLATFORM</data>
      <data key="d2">A biosensing approach that uses gold nanoparticles as biomarkers to track viral infections, enabling visual or optical readout of infection status.</data>
      <data key="d3">0.7</data>
      <data key="d4">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a_chunk_82</data>
      <data key="d5">f2b3cfad-751c-4e9d-a9ef-77be12b8fc1a</data>
    </node>
