      <data key="d8">RNASE P GENE</data>
      <data key="d9">DETECTS</data>
      <data key="d10">The TRACE duplex assay detects the human RNase P gene as a host internal control, generating the ΔF1 fluorescent signal during the first 37 °C stage.</data>
      <data key="d11">0.92</data>
      <data key="d12">1</data>
      <data key="d13">6f94756d-fd42-4a77-b6b1-d9dc6901591d_chunk_25</data>
