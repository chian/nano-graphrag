  <graph edgedefault="directed">
    <node id="VENTILATION SYSTEM DESIGN">
      <data key="d0">VENTILATION SYSTEM DESIGN</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">An engineered room ventilation strategy proposed for controlling airborne infectious contaminants in healthcare spaces. The text describes optimizing the design through scientific and site-specific risk assessment to reduce infection risk in an isolation room without necessarily increasing total airflow.</data>
      <data key="d3">0.96</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2,3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="UNINTERRUPTED CONTAMINANT SOURCE-TO-EXHAUST PATH">
      <data key="d0">UNINTERRUPTED CONTAMINANT SOURCE-TO-EXHAUST PATH</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A proposed airflow-organization strategy in which the path from contaminant source to exhaust is kept as direct and uninterrupted as possible. The abstract identifies this path as a dominant factor affecting contaminant transmission and control in enclosed mechanically ventilated rooms.</data>
      <data key="d3">0.92</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INCREASED VENTILATION AIRFLOW RATE">
      <data key="d0">INCREASED VENTILATION AIRFLOW RATE</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A ventilation intervention that increases airflow to improve dilution of contaminant concentrations. The text states that higher airflow can dilute contaminants when the source is constant, but does not necessarily improve ventilation effectiveness.</data>
      <data key="d3">0.82</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIR CHANGES PER HOUR (ACH)">
      <data key="d0">AIR CHANGES PER HOUR (ACH)</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">A ventilation rate metric representing how often room air is replaced or diluted per hour. The abstract notes that many infectious-particle transmission studies have focused primarily on ACH as a dilution factor.</data>
      <data key="d3">0.84</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE INFECTIOUS DISEASE AGENTS">
      <data key="d0">AIRBORNE INFECTIOUS DISEASE AGENTS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Airborne infectious contaminants or particles whose transport mechanisms, particle paths, and control strategies are examined in the study.</data>
      <data key="d3">0.91</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ISOLATION ROOM">
      <data key="d0">ISOLATION ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">An enclosed, mechanically ventilated healthcare room used as the main example setting for optimizing ventilation design to reduce airborne infection risk to occupants.</data>
      <data key="d3">0.89</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS">
      <data key="d0">COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A modeling-based analysis used to examine contaminant transport mechanisms, particle paths, and potential control strategies for airborne infectious disease agents in a mechanically ventilated room.</data>
      <data key="d3">0.88</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2,3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="SITE-SPECIFIC RISK ANALYSIS">
      <data key="d0">SITE-SPECIFIC RISK ANALYSIS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A scientific assessment approach used to determine ventilation-system design needs for a particular site or room. The text frames this analysis as a basis for optimizing design and achieving long-term cost savings.</data>
      <data key="d3">0.78</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION EFFECTIVENESS">
      <data key="d0">VENTILATION EFFECTIVENESS</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">A performance measure describing how effectively ventilation controls or removes contaminants, distinct from simply increasing airflow or dilution rate. The text emphasizes that increasing airflow does not necessarily increase ventilation effectiveness.</data>
      <data key="d3">0.81</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="DILUTION OF CONTAMINANT CONCENTRATIONS">
      <data key="d0">DILUTION OF CONTAMINANT CONCENTRATIONS</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">A ventilation performance effect in which contaminant concentrations are lowered by increased airflow. The abstract distinguishes dilution from broader ventilation effectiveness.</data>
      <data key="d3">0.74</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="OCCUPANT INFECTION RISK">
      <data key="d0">OCCUPANT INFECTION RISK</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">The adverse outcome risk that occupants of an isolation room may become infected after exposure to airborne infectious agents. The paper aims to reduce this risk through optimized ventilation design.</data>
      <data key="d3">0.86</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="NOSOCOMIAL INFECTIONS">
      <data key="d0">NOSOCOMIAL INFECTIONS</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">Healthcare-associated infections discussed as a major cost burden in the United States. The abstract estimates their annual cost at $4 billion to $5 billion.</data>
      <data key="d3">0.76</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ANNUAL U.S. COST OF NOSOCOMIAL INFECTIONS">
      <data key="d0">ANNUAL U.S. COST OF NOSOCOMIAL INFECTIONS</data>
      <data key="d1">COST_PROXY</data>
      <data key="d2">The estimated financial burden of nosocomial infections in the United States, stated in the abstract as $4 billion to $5 billion annually.</data>
      <data key="d3">0.73</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="UNINTERRUPTED SOURCE-TO-EXHAUST AIRFLOW PATH">
      <data key="d0">UNINTERRUPTED SOURCE-TO-EXHAUST AIRFLOW PATH</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">The hypothesized path principle in which contaminants travel directly from the contaminant source toward the exhaust without being disrupted by competing air streams. The text identifies this pathway as the dominant factor affecting contaminant transmission and control.</data>
      <data key="d3">0.94</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRFLOW PATHWAYS">
      <data key="d0">AIRFLOW PATHWAYS</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">The spatial routes followed by air and airborne contaminants in patient rooms. Airflow pathways are highlighted as important for bioaerosol containment and removal and for determining whether contaminants are carried toward exhaust or dispersed into occupied areas.</data>
      <data key="d3">0.86</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CEILING-VENTILATED MOCK AIRBORNE INFECTION ISOLATION ROOM">
      <data key="d0">CEILING-VENTILATED MOCK AIRBORNE INFECTION ISOLATION ROOM</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A ceiling-ventilated isolation-room configuration referenced in a similar article as an engineered ventilation approach for reducing hospital-acquired influenza transmission to health care workers.</data>
      <data key="d3">0.7</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="NEGATIVE-PRESSURE VENTILATION">
      <data key="d0">NEGATIVE-PRESSURE VENTILATION</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A ventilation strategy associated with negative-pressurized isolation rooms, using pressure gradients and directed airflow to support airborne contaminant containment in clinical spaces.</data>
      <data key="d3">0.68</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIR CHANGE RATE (ACH)">
      <data key="d0">AIR CHANGE RATE (ACH)</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">A ventilation flow-rate metric indicating air changes per hour. The text contrasts ACH with ventilation system design and suggests that airflow-path design may be more important than ACH alone. | Ventilation-rate metric measured in the route bus; ACH increased with bus speed, increased with more open windows, and varied by fan configuration.</data>
      <data key="d3">0.93</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b,e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">AIR EXCHANGE RATES (ACH)</data>
    </node>
    <node id="HIGHER VENTILATION FLOW RATE">
      <data key="d0">HIGHER VENTILATION FLOW RATE</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">A higher airflow or ventilation-rate condition under which the protective effect of moving farther from the patient is reported to be more pronounced.</data>
      <data key="d3">0.77</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INCREASED DISTANCE FROM CONTAMINANT SOURCE">
      <data key="d0">INCREASED DISTANCE FROM CONTAMINANT SOURCE</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">A spatial exposure parameter representing greater separation from the contaminant source, identified as a secondary factor that generally reduces infection risk in a transient coughing situation.</data>
      <data key="d3">0.84</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION RATE">
      <data key="d0">VENTILATION RATE</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">The amount of ventilation supplied or exhausted from a room. Similar-article content links ventilation rate with airflow pathways for bioaerosol containment and removal in patient rooms.</data>
      <data key="d3">0.73</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE CONTAMINANTS">
      <data key="d0">AIRBORNE CONTAMINANTS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Airborne contaminant particles or pathogen-containing aerosols whose transport, transmission, and removal are affected by ventilation design, source-to-exhaust airflow path, distance, and flow rate.</data>
      <data key="d3">0.88</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="BIOAEROSOL">
      <data key="d0">BIOAEROSOL</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Airborne biological particles referenced in a similar article on patient-room ventilation rates and airflow pathways for bioaerosol containment and removal.</data>
      <data key="d3">0.69</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="HOSPITAL-ACQUIRED INFLUENZA">
      <data key="d0">HOSPITAL-ACQUIRED INFLUENZA</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">A respiratory infection mentioned in a similar article evaluating a ceiling-ventilated mock airborne infection isolation room for preventing transmission to health care workers.</data>
      <data key="d3">0.67</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="RECENTLY IDENTIFIED ORGANISMS">
      <data key="d0">RECENTLY IDENTIFIED ORGANISMS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Organisms for which the exact mode of transmission remains uncertain. The text notes that future research is needed to determine their transmission modes.</data>
      <data key="d3">0.55</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CONTAMINANT TRANSMISSION AND EXPOSURE">
      <data key="d0">CONTAMINANT TRANSMISSION AND EXPOSURE</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">An outcome measure describing the extent to which airborne contaminants are transmitted through or controlled within the room environment.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INFECTION RISK IN A TRANSIENT COUGHING SITUATION">
      <data key="d0">INFECTION RISK IN A TRANSIENT COUGHING SITUATION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">A risk outcome for short-duration cough-generated exposure. The text states that infection risk generally decreases as one moves farther away from the patient, especially under higher flow rates.</data>
      <data key="d3">0.88</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="BIOAEROSOL SPREAD OR AIRBORNE BURDEN">
      <data key="d0">BIOAEROSOL SPREAD OR AIRBORNE BURDEN</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">An effectiveness outcome representing the amount or spread of bioaerosol in patient-room air. Ventilation rates and airflow pathways are relevant because they can contain or remove bioaerosols.</data>
      <data key="d3">0.71</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="HOSPITAL-ACQUIRED INFLUENZA TRANSMISSION RISK TO HEALTH CARE WORKERS">
      <data key="d0">HOSPITAL-ACQUIRED INFLUENZA TRANSMISSION RISK TO HEALTH CARE WORKERS</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">An effectiveness outcome from a similar article, referring to the risk of influenza transmission to health care workers in an airborne infection isolation-room context.</data>
      <data key="d3">0.66</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="PATIENT ROOM">
      <data key="d0">PATIENT ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">The clinical room environment identified in the keywords and similar-article titles where ventilation system design, ACH, airflow pathways, contaminant control, and infection-risk reduction are evaluated.</data>
      <data key="d3">0.87</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE INFECTION ISOLATION ROOM">
      <data key="d0">AIRBORNE INFECTION ISOLATION ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">A specialized hospital room type referenced in a similar article on ceiling ventilation and hospital-acquired influenza transmission prevention.</data>
      <data key="d3">0.71</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="NEGATIVE-PRESSURIZED ISOLATION ROOM">
      <data key="d0">NEGATIVE-PRESSURIZED ISOLATION ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">An isolation-room environment referenced in a similar article evaluating ventilation performance for emergency department use.</data>
      <data key="d3">0.93</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3,3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="EMERGENCY DEPARTMENT">
      <data key="d0">EMERGENCY DEPARTMENT</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">A hospital care area referenced in a similar article evaluating a negative-pressurized isolation room intended for emergency department settings.</data>
      <data key="d3">0.62</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="THIS STUDY">
      <data key="d0">THIS STUDY</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">The primary study summarized in the text, providing evidence that source-to-exhaust airflow path, ventilation system design, distance from source, and flow rate influence contaminant transmission and infection risk.</data>
      <data key="d3">0.91</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ASSESSING EFFECTIVENESS OF CEILING-VENTILATED MOCK AIRBORNE INFECTION ISOLATION ROOM IN PREVENTING HOSPITAL-ACQUIRED INFLUENZA TRANSMISSION TO HEALTH CARE WORKERS">
      <data key="d0">ASSESSING EFFECTIVENESS OF CEILING-VENTILATED MOCK AIRBORNE INFECTION ISOLATION ROOM IN PREVENTING HOSPITAL-ACQUIRED INFLUENZA TRANSMISSION TO HEALTH CARE WORKERS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A similar article evaluating whether a ceiling-ventilated mock airborne infection isolation room can reduce hospital-acquired influenza transmission risk to health care workers.</data>
