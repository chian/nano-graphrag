      <data key="d8">SARS-COV-2</data>
      <data key="d9">TARGETS</data>
      <data key="d10">Exhaust fan operation targets airborne SARS-CoV-2 by increasing air exchange and reducing viral aerosol concentration in the bus.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
