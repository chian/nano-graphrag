      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A standard jointly published by ASHRAE and ASHE specifying ventilation requirements for health care facilities to ensure proper air quality and infection control.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="RISK MANAGEMENT GUIDANCE FOR HEALTH, SAFETY AND ENVIRONMENTAL SECURITY UNDER EXTRAORDINARY INCIDENTS">
      <data key="d0">RISK MANAGEMENT GUIDANCE FOR HEALTH, SAFETY AND ENVIRONMENTAL SECURITY UNDER EXTRAORDINARY INCIDENTS</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Guidance document by ASHRAE outlining risk management strategies for maintaining health, safety, and environmental security during extraordinary incidents, including ventilation and environmental controls.</data>
      <data key="d3">0.7</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CLIPBOARD">
      <data key="d0">CLIPBOARD</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A feature in PubMed that allows users to temporarily save and manage selected search results for later use.</data>
      <data key="d3">0.6</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_0</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
