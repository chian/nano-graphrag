    </node>
    <node id="FUNGI IN INDOOR AIR">
      <data key="d0">FUNGI IN INDOOR AIR</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Fungal species present in the indoor air of critical hospital areas, representing a biological contamination risk.</data>
      <data key="d3">0.7</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CRITICAL HOSPITAL AREAS">
      <data key="d0">CRITICAL HOSPITAL AREAS</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Hospital zones with high vulnerability to airborne contamination, requiring stringent air quality control.</data>
      <data key="d3">0.85</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ASHRAE HANDBOOK-FUNDAMENTALS">
      <data key="d0">ASHRAE HANDBOOK-FUNDAMENTALS</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A comprehensive guide published by ASHRAE providing fundamental principles and guidelines for heating, refrigerating, and air-conditioning engineering, including ventilation standards relevant to health and safety.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ASHRAE/ASHE STANDARD 170-2008">
