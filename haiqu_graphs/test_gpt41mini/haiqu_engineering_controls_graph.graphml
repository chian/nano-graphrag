    <node id="WINDOWS OPEN">
      <data key="d0">WINDOWS OPEN</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Opening windows on a bus to increase natural ventilation and air exchange rate (ACH), thereby reducing airborne SARS-CoV-2 exposure by enhancing dilution and removal of infectious aerosols. | The condition where bus windows are open, enhancing natural ventilation and affecting exposure to airborne particles.</data>
      <data key="d3">0.9</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">WINDOW OPEN</data>
    </node>
    <node id="EXHAUST FAN OPERATION">
      <data key="d0">EXHAUST FAN OPERATION</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Use of exhaust fans in a bus to mechanically increase air exchange by expelling indoor air, reducing airborne SARS-CoV-2 concentration and infection risk.</data>
