  <graph edgedefault="directed">
    <node id="HTTPS PROTOCOL">
      <data key="d0">HTTPS PROTOCOL</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A security protocol that ensures encrypted and secure transmission of information between the user and the official website. | A security protocol ensuring encrypted and secure transmission of data between users and official websites.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_0</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b,e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">HTTPS PROTOCOL</data>
    </node>
    <node id=".GOV DOMAIN">
      <data key="d0">.GOV DOMAIN</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A domain suffix indicating an official federal government website, used to verify authenticity before sharing sensitive information.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_0</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION SYSTEM DESIGN">
      <data key="d0">VENTILATION SYSTEM DESIGN</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">An engineering control involving the design and optimization of ventilation systems to reduce airborne pathogen exposure by managing airflow patterns and contaminant transport paths, especially in isolation rooms. It aims to reduce infection risk without necessarily increasing ventilation airflow rate, focusing on maintaining an uninterrupted path between contaminant source and exhaust.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2,3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIR CHANGES PER HOUR">
      <data key="d0">AIR CHANGES PER HOUR</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">A quantitative parameter representing the number of times the air within a defined space is replaced per hour. ACH provides a dilution factor for airborne infectious agents but does not necessarily improve ventilation effectiveness or contaminant control.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ISOLATION ROOM">
      <data key="d0">ISOLATION ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">A clinical area designed to isolate patients with infectious diseases to prevent airborne transmission. It is the primary deployment zone for ventilation system design controls aimed at reducing airborne pathogen exposure.</data>
      <data key="d3">0.85</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE INFECTIOUS DISEASE AGENTS">
      <data key="d0">AIRBORNE INFECTIOUS DISEASE AGENTS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Pathogens transmitted via airborne particles that cause infectious diseases. These agents are the target of ventilation system design controls to reduce their concentration and transmission risk in clinical settings.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COMPUTATIONAL FLUID DYNAMICS ANALYSIS">
      <data key="d0">COMPUTATIONAL FLUID DYNAMICS ANALYSIS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A computational modeling study used to examine transport mechanisms, particle paths, and control strategies for reducing airborne infectious disease agents in ventilated spaces.</data>
      <data key="d3">0.75</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION EFFECTIVENESS">
      <data key="d0">VENTILATION EFFECTIVENESS</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">A measure of how effectively a ventilation system controls contaminant transport and reduces exposure to airborne infectious agents, distinct from air changes per hour.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIR CHANGE RATE (ACH)">
      <data key="d0">AIR CHANGE RATE (ACH)</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">A quantitative parameter representing the number of times the air within a defined space is replaced per hour; influences dilution and removal of airborne pathogens, though its effect on infection risk reduction may be secondary to ventilation system design conformity to airflow path principles.</data>
      <data key="d3">0.75</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="PATIENT ROOM">
      <data key="d0">PATIENT ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">A clinical area where patients are housed and where airborne infection control measures such as ventilation system design and air change rates are implemented to reduce pathogen transmission risk.</data>
      <data key="d3">0.65</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="DISTANCE FROM CONTAMINANT SOURCE">
      <data key="d0">DISTANCE FROM CONTAMINANT SOURCE</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">A spatial factor representing the physical separation between individuals and the contaminant source; increasing this distance generally reduces infection risk, especially in transient exposure scenarios such as coughing, with a more pronounced effect under higher airflow rates.</data>
      <data key="d3">0.7</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CONTAMINANT SOURCE">
      <data key="d0">CONTAMINANT SOURCE</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">The origin point of airborne infectious agents or contaminants, such as a patient emitting pathogens through coughing, which serves as the starting point for transmission pathways targeted by ventilation and infection control measures.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRFLOW PATH">
      <data key="d0">AIRFLOW PATH</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">The designed or natural path of air movement between the contaminant source and exhaust; maintaining an uninterrupted airflow path is critical for effective contaminant removal and infection risk reduction.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="NEGATIVE-PRESSURIZED ISOLATION ROOM">
      <data key="d0">NEGATIVE-PRESSURIZED ISOLATION ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">A hospital isolation room designed with negative pressure ventilation to prevent airborne pathogen spread, evaluated for ventilation performance in emergency departments.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION PERFORMANCE EVALUATION">
      <data key="d0">VENTILATION PERFORMANCE EVALUATION</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A study assessing the effectiveness of ventilation systems in a negative-pressurized isolation room for emergency departments.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="FOLIC ACID SUPPLEMENTATION">
      <data key="d0">FOLIC ACID SUPPLEMENTATION</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">The use of folic acid supplements among people taking antifolate antimalarial drugs to assess its impact on malaria susceptibility and severity.</data>
      <data key="d3">0.7</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="MALARIA SUSCEPTIBILITY AND SEVERITY">
      <data key="d0">MALARIA SUSCEPTIBILITY AND SEVERITY</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">The susceptibility to and severity of malaria infection, particularly in individuals taking antifolate antimalarial drugs in endemic areas.</data>
      <data key="d3">0.7</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="HUMAN RESPONSES TO VENTILATION">
      <data key="d0">HUMAN RESPONSES TO VENTILATION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Summary of physiological and health-related human responses to different ventilation conditions.</data>
      <data key="d3">0.6</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COUGH DROPLETS FROM COVID-19 PATIENT">
      <data key="d0">COUGH DROPLETS FROM COVID-19 PATIENT</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Respiratory droplets emitted by COVID-19 patients, studied for behavior under different ventilation configurations in hospital isolation rooms.</data>
      <data key="d3">0.85</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION CONFIGURATIONS">
      <data key="d0">VENTILATION CONFIGURATIONS</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Different ventilation system setups in hospital isolation rooms aimed at controlling airborne pathogen transmission.</data>
      <data key="d3">0.85</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="TRANSMISSIBILITY AND TRANSMISSION OF RESPIRATORY VIRUSES">
      <data key="d0">TRANSMISSIBILITY AND TRANSMISSION OF RESPIRATORY VIRUSES</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Review of factors influencing how respiratory viruses spread and transmit between hosts.</data>
      <data key="d3">0.75</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION STRATEGIES">
      <data key="d0">VENTILATION STRATEGIES</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Numerical investigation of ventilation methods to mitigate airborne dispersion of MERS-CoV in inpatient wards, focusing on airflow management to reduce pathogen spread.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="MERS-COV">
      <data key="d0">MERS-COV</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Middle East Respiratory Syndrome Coronavirus, a virus transmitted via airborne particles, posing infection risks in hospital settings.</data>
      <data key="d3">1.0</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INPATIENT WARDS">
      <data key="d0">INPATIENT WARDS</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Hospital areas where patients are admitted and treated, critical zones for controlling airborne pathogen transmission.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="PERSONAL PROTECTIVE EQUIPMENT (PPE)">
