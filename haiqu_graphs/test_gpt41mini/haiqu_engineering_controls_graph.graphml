    </edge>
    <edge source="ACH" target="92% REDUCTION INFECTION RISK">
      <data key="d7">ACH</data>
      <data key="d8">92% REDUCTION INFECTION RISK</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Higher ACH achieved by opening windows correlates with a 92% reduction in infection risk, showing the critical role of ventilation rate in airborne SARS-CoV-2 control. | Increased ACH from exhaust fan operation contributes to a 35% reduction in infection risk, highlighting the importance of mechanical ventilation in pathogen mitigation.</data>
      <data key="d11">0.9</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
