      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Protective gear used by healthcare workers, especially surgeons, to reduce exposure to COVID-19 and other airborne pathogens.</data>
      <data key="d3">0.95</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
