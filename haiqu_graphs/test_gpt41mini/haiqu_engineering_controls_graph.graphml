      <data key="d8">ROUTE BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Ventilation fan operational modes (exhaust or supply) are applied in the route bus to influence air exchange rates and infection risk.</data>
      <data key="d11">0.75</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
