      <data key="d7">EXHAUST FAN OPERATION</data>
      <data key="d8">35% REDUCTION INFECTION RISK</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Exhaust fan operation reduces average SARS-CoV-2 infection risk by 35% in a moving bus with windows closed, indicating moderate ventilation benefit.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="AIR CONDITIONING (AC) UNIT WITH PREFILTER" target="ROUTE BUS">
      <data key="d7">AIR CONDITIONING (AC) UNIT WITH PREFILTER</data>
      <data key="d8">ROUTE BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">The AC unit equipped with a prefilter is used in the route bus to trap particles and reduce airborne SARS-CoV-2 spread through filtration of recirculated air.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
