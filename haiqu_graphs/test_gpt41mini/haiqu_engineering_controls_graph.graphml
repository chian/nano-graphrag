    <edge source="WINDOWS OPEN" target="ROUTE BUS">
      <data key="d7">WINDOWS OPEN</data>
      <data key="d8">ROUTE BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Opening windows is deployed as a natural ventilation control measure in the route bus environment to increase air exchange and reduce airborne SARS-CoV-2 exposure.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS OPEN" target="ACH">
      <data key="d7">WINDOWS OPEN</data>
      <data key="d8">ACH</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Opening windows increases the air changes per hour (ACH) in the bus, enhancing ventilation effectiveness by increasing dilution and removal of airborne SARS-CoV-2 aerosols.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS OPEN" target="SARS-COV-2">
      <data key="d7">WINDOWS OPEN</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">TARGETS</data>
      <data key="d10">Opening windows targets airborne SARS-CoV-2 by increasing ventilation and reducing the concentration of infectious aerosols in the bus environment.</data>
      <data key="d11">1.0</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS OPEN" target="92% REDUCTION INFECTION RISK">
      <data key="d7">WINDOWS OPEN</data>
      <data key="d8">92% REDUCTION INFECTION RISK</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Opening windows reduces average SARS-CoV-2 infection risk by 92% in a moving bus compared to windows closed, demonstrating high ventilation effectiveness.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS OPEN" target="NORMALIZED EXPOSURE DATA">
      <data key="d7">WINDOW OPEN</data>
      <data key="d8">NORMALIZED EXPOSURE DATA</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Opening windows reduces normalized exposure to airborne particles by increasing natural ventilation in the bus.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="EXHAUST FAN OPERATION" target="ROUTE BUS">
      <data key="d7">EXHAUST FAN OPERATION</data>
      <data key="d8">ROUTE BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Exhaust fans are operated in the route bus to mechanically increase air exchange rate and reduce airborne SARS-CoV-2 infection risk.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="EXHAUST FAN OPERATION" target="ACH">
      <data key="d7">EXHAUST FAN OPERATION</data>
      <data key="d8">ACH</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Operating exhaust fans increases ACH by mechanically expelling indoor air, thereby improving ventilation and reducing airborne SARS-CoV-2 concentration.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
