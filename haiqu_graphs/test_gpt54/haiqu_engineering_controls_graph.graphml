      <data key="d8">MODIFIED WELLS-RILEY EQUATION CALCULATIONS</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The reported infection-risk benefit of window-opening was estimated using modified Wells-Riley equation calculations.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
