      <data key="d8">AIR EXCHANGE RATES (ACH)</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Window-opening affected ACH, with higher ACH observed when more windows were open and depending on window placement.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
