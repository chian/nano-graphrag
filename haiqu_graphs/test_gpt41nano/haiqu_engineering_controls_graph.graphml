      <data key="d7">VENTILATION SYSTEM DESIGN</data>
      <data key="d8">AIR STREAM</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">The design of the ventilation system determines the airflow patterns, which can be manipulated to interrupt transmission pathways.</data>
      <data key="d11">0.7</data>
      <data key="d12">2</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
