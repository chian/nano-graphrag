      <data key="d8">INFECTION RISK</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Proper ventilation design can reduce infection risk by controlling airflow pathways and removing airborne pathogens.</data>
      <data key="d11">0.9</data>
      <data key="d12">3</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
