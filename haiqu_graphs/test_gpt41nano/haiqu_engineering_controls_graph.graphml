      <data key="d8">ACH</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">The ventilation system design influences the air change rate (ACH), a key operational parameter affecting contaminant removal.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
