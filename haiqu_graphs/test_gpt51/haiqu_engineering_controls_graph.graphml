      <data key="d8">VENTILATION</data>
      <data key="d9">COMPLEMENTS</data>
      <data key="d10">The review on respiratory virus transmission provides biological and epidemiological context that complements engineering knowledge about ventilation in mitigating airborne spread.</data>
      <data key="d11">0.6</data>
      <data key="d12">2</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION STRATEGIES" target="INPATIENT WARDS">
      <data key="d7">VENTILATION STRATEGIES</data>
      <data key="d8">INPATIENT WARDS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Ventilation strategies are modeled and implemented specifically in inpatient wards to influence airflow and reduce airborne dispersion of pathogens in these clinical spaces.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION STRATEGIES" target="MERS-COV">
      <data key="d7">VENTILATION STRATEGIES</data>
      <data key="d8">MERS-COV</data>
      <data key="d9">TARGETS</data>
      <data key="d10">The ventilation strategies are designed and evaluated with the explicit aim of mitigating airborne dispersion of MERS-CoV within inpatient wards.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION STRATEGIES" target="HOSPITAL LIFT">
      <data key="d7">VENTILATION STRATEGIES</data>
      <data key="d8">HOSPITAL LIFT</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Different ventilation strategies are implemented and evaluated within the hospital lift to assess their impact on CO2 accumulation and droplet dispersion from a cough.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="THE AIR WE BREATHE: NUMERICAL INVESTIGATION OF VENTILATION STRATEGIES TO MITIGATE AIRBORNE DISPERSION OF MERS-COV IN INPATIENT WARDS" target="VENTILATION STRATEGIES">
