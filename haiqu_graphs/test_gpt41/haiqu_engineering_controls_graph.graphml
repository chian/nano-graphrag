      <data key="d7">HEPA FILTRATION</data>
      <data key="d8">FUNGI</data>
      <data key="d9">REDUCES</data>
      <data key="d10">HEPA filtration reduces the concentration of airborne fungi in hospital environments, especially in critical care areas.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
