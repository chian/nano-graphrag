    <edge source="WINDOW OPENING" target="AIR CHANGE RATE (ACH)">
      <data key="d7">WINDOW OPENING</data>
      <data key="d8">AIR EXCHANGE RATE (ACH)</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Window opening increases the air exchange rate (ACH) in the bus, with more windows open resulting in higher ACH.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOW OPENING" target="SARS-COV-2">
      <data key="d7">WINDOW OPENING</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">TARGETS</data>
      <data key="d10">Window opening targets airborne SARS-CoV-2 by increasing ventilation and diluting infectious aerosols.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOW OPENING" target="92% REDUCTION INFECTION RISK (WINDOWS OPEN VS CLOSED)">
      <data key="d7">WINDOW OPENING</data>
      <data key="d8">92% REDUCTION INFECTION RISK (WINDOWS OPEN VS CLOSED)</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Opening windows reduces average infection risk for SARS-CoV-2 by 92% compared to windows closed, as shown by quantitative modeling.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOW OPENING" target="VENTILATION FANS (EXHAUST MODE)">
      <data key="d7">WINDOW OPENING</data>
      <data key="d8">VENTILATION FANS (EXHAUST MODE)</data>
      <data key="d9">COMPLEMENTS</data>
      <data key="d10">Window opening and exhaust fan operation together can provide greater air exchange and infection risk reduction than either alone, especially when used in combination.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="VENTILATION FANS (EXHAUST MODE)" target="ROUTE BUS">
      <data key="d7">VENTILATION FANS (EXHAUST MODE)</data>
      <data key="d8">ROUTE BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Exhaust mode operation of ventilation fans is applied in the route bus to enhance air removal and lower pathogen concentration.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="VENTILATION FANS (EXHAUST MODE)" target="AIR CHANGE RATE (ACH)">
      <data key="d7">VENTILATION FANS (EXHAUST MODE)</data>
      <data key="d8">AIR EXCHANGE RATE (ACH)</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Exhaust mode operation of ventilation fans increases the air exchange rate (ACH), more than doubling it compared to supply mode.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="VENTILATION FANS (EXHAUST MODE)" target="SARS-COV-2">
      <data key="d7">VENTILATION FANS (EXHAUST MODE)</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">TARGETS</data>
      <data key="d10">Exhaust mode ventilation fans target airborne SARS-CoV-2 by removing contaminated air from the bus.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="VENTILATION FANS (EXHAUST MODE)" target="35% REDUCTION INFECTION RISK (EXHAUST FAN OPERATION, WINDOWS CLOSED)">
      <data key="d7">VENTILATION FANS (EXHAUST MODE)</data>
      <data key="d8">35% REDUCTION INFECTION RISK (EXHAUST FAN OPERATION, WINDOWS CLOSED)</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Exhaust fan operation with windows closed reduces average infection risk for SARS-CoV-2 by 35%.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="AIR CONDITIONING UNIT WITH PREFILTER" target="ROUTE BUS">
      <data key="d7">AIR CONDITIONING UNIT WITH PREFILTER</data>
      <data key="d8">ROUTE BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">The AC unit with a prefilter is used in the route bus to trap airborne particles and reduce their spread.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="AIR CONDITIONING UNIT WITH PREFILTER" target="PARTICLES">
      <data key="d7">AIR CONDITIONING UNIT WITH PREFILTER</data>
      <data key="d8">PARTICLES</data>
      <data key="d9">REDUCES</data>
      <data key="d10">The AC unit with prefilter reduces the spread rate of particles by trapping them, lowering their concentration compared to CO2.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="AIR CONDITIONING UNIT WITH PREFILTER" target="SARS-COV-2">
      <data key="d7">AIR CONDITIONING UNIT WITH PREFILTER</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">TARGETS</data>
      <data key="d10">The AC unit with prefilter targets airborne SARS-CoV-2 by trapping particles that may carry the virus.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MODIFIED WELLS-RILEY EQUATION" target="92% REDUCTION INFECTION RISK (WINDOWS OPEN VS CLOSED)">
      <data key="d7">MODIFIED WELLS-RILEY EQUATION</data>
      <data key="d8">92% REDUCTION INFECTION RISK (WINDOWS OPEN VS CLOSED)</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The 92% reduction in infection risk due to window opening is validated by calculations using a modified Wells-Riley equation.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MODIFIED WELLS-RILEY EQUATION" target="35% REDUCTION INFECTION RISK (EXHAUST FAN OPERATION, WINDOWS CLOSED)">
      <data key="d7">MODIFIED WELLS-RILEY EQUATION</data>
      <data key="d8">35% REDUCTION INFECTION RISK (EXHAUST FAN OPERATION, WINDOWS CLOSED)</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The 35% reduction in infection risk due to exhaust fan operation is validated by calculations using a modified Wells-Riley equation.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="CO2" target="AIR CHANGE RATE (ACH)">
      <data key="d7">CO2</data>
      <data key="d8">AIR EXCHANGE RATE (ACH)</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">CO2 spread rate is used to infer air exchange rate (ACH) in the bus, serving as a tracer for ventilation effectiveness.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="CO2" target="CO2 INHALATION VOLUME">
      <data key="d7">CO2</data>
      <data key="d8">CO2 INHALATION VOLUME</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">CO2 is emitted and inhaled in the bus, with inhalation volume measured as a proxy for exposure to rebreathed air and airborne pathogens.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="CO2" target="BUS">
      <data key="d7">CO2</data>
      <data key="d8">BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">CO2 is used as a tracer gas in the bus to simulate exhaled breath and track air mixing and exposure risk.</data>
      <data key="d11">0.75</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="CO2" target="NORMALIZED EXPOSURE DATA">
      <data key="d7">CO2</data>
      <data key="d8">NORMALIZED EXPOSURE DATA</data>
      <data key="d9">TARGETS</data>
      <data key="d10">CO2 concentration is used as a proxy target for normalized exposure data, reflecting the effectiveness of ventilation controls in reducing exhaled breath exposure.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="CO2" target="PARTICLES">
      <data key="d7">CO2</data>
      <data key="d8">PARTICLES</data>
      <data key="d9">COMPLEMENTS</data>
      <data key="d10">CO2 and particles are complementary proxies for assessing airborne exposure and ventilation effectiveness in the bus environment.</data>
      <data key="d11">0.8</data>
      <data key="d12">3</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="PARTICLES" target="AIR CHANGE RATE (ACH)">
      <data key="d7">PARTICLES</data>
      <data key="d8">AIR EXCHANGE RATE (ACH)</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Particle spread rate is used to evaluate air exchange rate (ACH) and effectiveness of filtration and ventilation controls.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="PARTICLES" target="NORMALIZED EXPOSURE DATA">
      <data key="d7">PARTICLES</data>
      <data key="d8">NORMALIZED EXPOSURE DATA</data>
      <data key="d9">TARGETS</data>
      <data key="d10">Airborne particle concentration is a direct target for normalized exposure data, used to assess the risk of infection and the effectiveness of ventilation strategies.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="BUS WINDOW OPENING" target="COMMUTER BUS">
      <data key="d7">BUS WINDOW OPENING</data>
      <data key="d8">COMMUTER BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Bus window opening is implemented as an engineering control in the commuter bus to improve ventilation and reduce airborne pathogen exposure.</data>
      <data key="d11">1.0</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="BUS WINDOW OPENING" target="ACH">
      <data key="d7">BUS WINDOW OPENING</data>
      <data key="d8">ACH</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">The effectiveness of bus window opening is measured by the resulting increase in Air Changes per Hour (ACH), quantifying the improvement in ventilation rate.</data>
      <data key="d11">1.0</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="BUS WINDOW OPENING" target="CO2 EMISSION SYSTEM">
      <data key="d7">BUS WINDOW OPENING</data>
      <data key="d8">CO2 EMISSION SYSTEM</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The impact of bus window opening on ventilation is validated by monitoring CO2 decay using the CO2 emission system, providing experimental evidence for air exchange rates.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="BUS WINDOW OPENING" target="PARTICLE EMISSION SYSTEM">
      <data key="d7">BUS WINDOW OPENING</data>
      <data key="d8">PARTICLE EMISSION SYSTEM</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The reduction in airborne particle concentration due to bus window opening is validated by the particle emission system, which simulates pathogen dispersion and measures control performance.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="BUS WINDOW OPENING" target="AIRBORNE PATHOGEN">
      <data key="d7">BUS WINDOW OPENING</data>
      <data key="d8">AIRBORNE PATHOGEN</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Opening bus windows reduces the concentration and transmission risk of airborne pathogens by increasing ventilation and air exchange.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="ACH" target="CO2 EMISSION SYSTEM">
      <data key="d7">ACH</data>
      <data key="d8">CO2 EMISSION SYSTEM</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">ACH measurements are validated by the CO2 emission system, which tracks CO2 decay to determine air exchange rates, ensuring accurate quantification of ventilation effectiveness.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="ACH" target="PARTICLE EMISSION SYSTEM">
      <data key="d7">ACH</data>
      <data key="d8">PARTICLE EMISSION SYSTEM</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">ACH is further validated by the particle emission system, which measures the clearance of airborne particles, correlating air exchange rates with reduction in simulated pathogen concentration.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="ACH" target="AIRBORNE PATHOGEN">
      <data key="d7">ACH</data>
      <data key="d8">AIRBORNE PATHOGEN</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Higher ACH rates are associated with reduced airborne pathogen concentrations, lowering the risk of transmission in the bus environment.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MANNEQUINS" target="COMMUTER BUS">
      <data key="d7">MANNEQUINS</data>
      <data key="d8">COMMUTER BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Mannequins are placed in the commuter bus to simulate passenger occupancy and its effect on ventilation and air flow during experimental studies.</data>
      <data key="d11">0.7</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MANNEQUINS" target="ACH">
      <data key="d7">MANNEQUINS</data>
      <data key="d8">ACH</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The presence of mannequins is used to validate ACH measurements under different occupancy scenarios, reflecting real-world passenger effects on ventilation.</data>
      <data key="d11">0.7</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MANNEQUINS" target="STATIONARY TESTS">
      <data key="d7">MANNEQUINS</data>
      <data key="d8">STATIONARY TESTS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Mannequins are used in stationary tests to simulate human occupancy and exhalation, enabling measurement of CO2 inhalation volume and exposure risk.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="OPEN WINDOWS" target="BUS">
      <data key="d7">OPEN WINDOWS</data>
      <data key="d8">BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Opening windows is implemented as a ventilation control in the bus to increase air exchange and reduce airborne pathogen risk. Effectiveness depends on window position and number.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="OPEN WINDOWS" target="ACH IN THE BUS">
      <data key="d7">OPEN WINDOWS</data>
      <data key="d8">ACH IN THE BUS</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">The number and configuration of open windows directly determine the ACH achieved in the bus, with more or optimally placed windows resulting in higher ACH.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="OPEN WINDOWS" target="VENTILATION FAN OPERATION">
      <data key="d7">OPEN WINDOWS</data>
      <data key="d8">VENTILATION FAN OPERATION</data>
      <data key="d9">COMPLEMENTS</data>
      <data key="d10">Combining open windows with ventilation fan operation provides greater ACH and air mixing than either control alone, enhancing overall ventilation effectiveness.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="VENTILATION FAN OPERATION" target="BUS">
      <data key="d7">VENTILATION FAN OPERATION</data>
      <data key="d8">BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Mechanical ventilation fans are operated within the bus to enhance air movement and increase ACH, supplementing or replacing natural ventilation.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="VENTILATION FAN OPERATION" target="ACH IN THE BUS">
      <data key="d7">VENTILATION FAN OPERATION</data>
      <data key="d8">ACH IN THE BUS</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Operation of ventilation fans increases the ACH in the bus, with different fan settings (front, rear, both) producing varying rates of air exchange.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="ACH IN THE BUS" target="CO2 INHALATION VOLUME">
      <data key="d7">ACH IN THE BUS</data>
      <data key="d8">CO2 INHALATION VOLUME</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Higher ACH in the bus reduces the inhalation volume of CO2 (and by proxy, airborne pathogens), indicating more effective dilution and removal of exhaled air.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="STATIONARY TESTS" target="OPEN WINDOWS">
      <data key="d7">STATIONARY TESTS</data>
      <data key="d8">OPEN WINDOWS</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">Stationary tests in the car barn validate the effectiveness of open windows in increasing ACH and reducing CO2 inhalation volume under controlled conditions.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="STATIONARY TESTS" target="VENTILATION FAN OPERATION">
      <data key="d7">STATIONARY TESTS</data>
      <data key="d8">VENTILATION FAN OPERATION</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">Stationary tests provide evidence for the impact of ventilation fan operation on ACH and air mixing in the bus.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MOVING TESTS" target="OPEN WINDOWS">
      <data key="d7">MOVING TESTS</data>
      <data key="d8">OPEN WINDOWS</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">Moving tests outdoors at Tsukuba validate the real-world effectiveness of open windows for ventilation under dynamic conditions.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MOVING TESTS" target="VENTILATION FAN OPERATION">
      <data key="d7">MOVING TESTS</data>
      <data key="d8">VENTILATION FAN OPERATION</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">Moving tests assess the effectiveness of ventilation fan operation in increasing ACH during bus operation.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS OPEN" target="BUS">
      <data key="d7">WINDOWS OPEN</data>
      <data key="d8">BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Opening windows is implemented as a ventilation control in the bus environment to increase air exchange and reduce airborne pathogen exposure. This relationship directly links the intervention to the setting where transmission risk is being mitigated.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS OPEN" target="NORMALIZED EXPOSURE DATA">
      <data key="d7">WINDOWS OPEN</data>
      <data key="d8">NORMALIZED EXPOSURE DATA</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Opening windows reduces normalized exposure data in the bus, demonstrating the effectiveness of natural ventilation in lowering airborne particle and CO2 concentrations.</data>
      <data key="d11">0.9</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS CLOSED" target="BUS">
      <data key="d7">WINDOWS CLOSED</data>
      <data key="d8">BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Keeping windows closed is a scenario applied in the bus to represent minimal ventilation and higher risk of airborne pathogen accumulation.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS CLOSED" target="NORMALIZED EXPOSURE DATA">
      <data key="d7">WINDOWS CLOSED</data>
      <data key="d8">NORMALIZED EXPOSURE DATA</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Keeping windows closed is associated with the highest normalized exposure data, indicating minimal reduction in airborne pathogen risk. It serves as a negative control for evaluating other interventions.</data>
      <data key="d11">0.7</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="AC ON" target="BUS">
      <data key="d7">AC ON</data>
      <data key="d8">BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">The air conditioning system is operated in the bus to modify airflow and potentially reduce airborne pathogen concentration. The effectiveness depends on system design and operational parameters.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="AC ON" target="NORMALIZED EXPOSURE DATA">
      <data key="d7">AC ON</data>
      <data key="d8">NORMALIZED EXPOSURE DATA</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Operating the AC system reduces normalized exposure data by increasing air mixing and potentially filtering airborne particles, depending on system design.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="AC OFF" target="BUS">
      <data key="d7">AC OFF</data>
      <data key="d8">BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">The air conditioning system is turned off in the bus, resulting in no mechanical air mixing or filtration from the AC system.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="FAN SUPPLY (FRONT) &amp; EXHAUST (REAR)" target="BUS">
      <data key="d7">FAN SUPPLY (FRONT) &amp; EXHAUST (REAR)</data>
      <data key="d8">BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Mechanical ventilation using supply and exhaust fans is deployed in the bus to enhance directional airflow and removal of airborne contaminants. This relationship is critical for evaluating engineered airflow solutions in public transport.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="FAN SUPPLY (FRONT) &amp; EXHAUST (REAR)" target="NORMALIZED EXPOSURE DATA">
      <data key="d7">FAN SUPPLY (FRONT) &amp; EXHAUST (REAR)</data>
      <data key="d8">NORMALIZED EXPOSURE DATA</data>
      <data key="d9">REDUCES</data>
      <data key="d10">This fan configuration reduces normalized exposure data by creating directional airflow that removes airborne contaminants more efficiently.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="FAN SUPPLY (FRONT) &amp; SUPPLY (REAR)" target="BUS">
      <data key="d7">FAN SUPPLY (FRONT) &amp; SUPPLY (REAR)</data>
      <data key="d8">BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Mechanical ventilation with supply fans at both ends is applied in the bus to increase air supply and dilution of airborne particles. The relationship highlights the impact of different fan configurations on exposure risk.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="FAN SUPPLY (FRONT) &amp; SUPPLY (REAR)" target="NORMALIZED EXPOSURE DATA">
      <data key="d7">FAN SUPPLY (FRONT) &amp; SUPPLY (REAR)</data>
      <data key="d8">NORMALIZED EXPOSURE DATA</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Supplying air at both ends of the bus reduces normalized exposure data by increasing dilution of airborne particles, though effectiveness may be less than configurations with exhaust.</data>
      <data key="d11">0.7</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="FAN OFF" target="BUS">
      <data key="d7">FAN OFF</data>
      <data key="d8">BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">All mechanical fans are turned off in the bus, resulting in no forced air movement. Used as a baseline or control scenario in exposure studies.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="FAN OFF" target="NORMALIZED EXPOSURE DATA">
      <data key="d7">FAN OFF</data>
      <data key="d8">NORMALIZED EXPOSURE DATA</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Fan off scenario is associated with higher normalized exposure data, indicating minimal reduction in airborne pathogen risk.</data>
      <data key="d11">0.7</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="NATURAL VENTILATION STRATEGY" target="SCHOOL BUILDING">
      <data key="d7">NATURAL VENTILATION STRATEGY</data>
      <data key="d8">SCHOOL BUILDING</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Natural ventilation strategies are implemented in school buildings to increase air exchange and reduce the risk of airborne pathogen transmission. The effectiveness depends on building design, occupancy, and environmental conditions.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="NATURAL VENTILATION STRATEGY" target="HOSPITAL LIFT">
      <data key="d7">NATURAL VENTILATION STRATEGY</data>
      <data key="d8">HOSPITAL LIFT</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Natural ventilation strategies are considered for hospital lifts, where air exchange is critical due to the confined space and high risk of airborne transmission.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="NATURAL VENTILATION STRATEGY" target="AIR CHANGE RATE">
      <data key="d7">NATURAL VENTILATION STRATEGY</data>
      <data key="d8">AIR CHANGE RATE</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">The effectiveness of natural ventilation is quantified by the air change rate (ACH), which determines how quickly indoor air is replaced with outdoor air, directly impacting pathogen dilution.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="NATURAL VENTILATION STRATEGY" target="SARS-COV-2">
      <data key="d7">NATURAL VENTILATION STRATEGY</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">TARGETS</data>
      <data key="d10">The primary aim of natural ventilation in the referenced studies is to reduce the concentration and transmission risk of SARS-CoV-2 aerosols in indoor environments such as schools and hospital lifts. | By increasing air change rates and reducing aerosol concentrations, natural ventilation strategies reduce the risk of SARS-CoV-2 transmission in indoor environments.</data>
      <data key="d11">1.0</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="NATURAL VENTILATION STRATEGY" target="CO2 ACCUMULATION">
      <data key="d7">NATURAL VENTILATION STRATEGY</data>
      <data key="d8">CO2 ACCUMULATION</data>
      <data key="d9">REDUCES</data>
      <data key="d10">By increasing air change rates, natural ventilation reduces CO2 accumulation, which serves as a proxy for improved ventilation and lower risk of airborne pathogen build-up.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="NATURAL VENTILATION STRATEGY" target="DROPLET DISPERSION FROM A COUGH">
      <data key="d7">NATURAL VENTILATION STRATEGY</data>
      <data key="d8">DROPLET DISPERSION FROM A COUGH</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Enhanced ventilation strategies, including natural ventilation, reduce the concentration and spatial spread of respiratory droplets from a cough, thereby lowering the risk of airborne transmission.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MECHANICAL VENTILATION STRATEGY" target="SCHOOL BUILDING">
      <data key="d7">MECHANICAL VENTILATION STRATEGY</data>
      <data key="d8">SCHOOL BUILDING</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Mechanical ventilation strategies are implemented in school buildings to control air exchange and filtration, complementing or replacing natural ventilation.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MECHANICAL VENTILATION STRATEGY" target="HOSPITAL LIFT">
      <data key="d7">MECHANICAL VENTILATION STRATEGY</data>
      <data key="d8">HOSPITAL LIFT</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Mechanical ventilation is used in hospital lifts to ensure adequate air exchange and reduce airborne pathogen exposure.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MECHANICAL VENTILATION STRATEGY" target="AIR CHANGE RATE">
      <data key="d7">MECHANICAL VENTILATION STRATEGY</data>
      <data key="d8">AIR CHANGE RATE</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Mechanical ventilation strategies are also quantified by air change rate, which is adjustable via system settings and impacts contaminant removal.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MECHANICAL VENTILATION STRATEGY" target="SARS-COV-2">
      <data key="d7">MECHANICAL VENTILATION STRATEGY</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">TARGETS</data>
      <data key="d10">Mechanical ventilation is used to reduce the concentration and transmission risk of SARS-CoV-2 aerosols in indoor environments. | Mechanical ventilation strategies reduce the risk of SARS-CoV-2 transmission by increasing air exchange and filtering aerosols.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MECHANICAL VENTILATION STRATEGY" target="CO2 ACCUMULATION">
      <data key="d7">MECHANICAL VENTILATION STRATEGY</data>
      <data key="d8">CO2 ACCUMULATION</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Mechanical ventilation reduces CO2 accumulation by actively exchanging indoor air, improving ventilation effectiveness.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="MECHANICAL VENTILATION STRATEGY" target="DROPLET DISPERSION FROM A COUGH">
      <data key="d7">MECHANICAL VENTILATION STRATEGY</data>
      <data key="d8">DROPLET DISPERSION FROM A COUGH</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Mechanical ventilation reduces the spread and concentration of respiratory droplets from a cough, lowering airborne transmission risk.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="INDOOR AEROSOL SCIENCE ASPECTS OF SARS-COV-2 TRANSMISSION" target="NATURAL VENTILATION STRATEGY">
      <data key="d7">INDOOR AEROSOL SCIENCE ASPECTS OF SARS-COV-2 TRANSMISSION</data>
      <data key="d8">NATURAL VENTILATION STRATEGY</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">This review article discusses the scientific basis for natural ventilation as a mitigation strategy for SARS-CoV-2 aerosol transmission.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="INDOOR AEROSOL SCIENCE ASPECTS OF SARS-COV-2 TRANSMISSION" target="MECHANICAL VENTILATION STRATEGY">
      <data key="d7">INDOOR AEROSOL SCIENCE ASPECTS OF SARS-COV-2 TRANSMISSION</data>
      <data key="d8">MECHANICAL VENTILATION STRATEGY</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The article also reviews mechanical ventilation as a mitigation strategy for SARS-CoV-2 aerosol transmission.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="NUMERICAL PERFORMANCE OF CO2 ACCUMULATION AND DROPLET DISPERSION FROM A COUGH INSIDE A HOSPITAL LIFT UNDER DIFFERENT VENTILATION STRATEGIES" target="NATURAL VENTILATION STRATEGY">
      <data key="d7">NUMERICAL PERFORMANCE OF CO2 ACCUMULATION AND DROPLET DISPERSION FROM A COUGH INSIDE A HOSPITAL LIFT UNDER DIFFERENT VENTILATION STRATEGIES</data>
      <data key="d8">NATURAL VENTILATION STRATEGY</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">This study provides numerical evidence supporting the effectiveness of natural ventilation strategies in reducing CO2 and droplet concentrations in confined hospital spaces.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
