      <data key="d8">CRITICAL HOSPITAL AREAS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">HEPA filtration is applied in critical hospital areas to reduce airborne pathogens and protect vulnerable patients.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
