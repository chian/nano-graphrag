    <edge source="ASHRAE RISK MANAGEMENT GUIDANCE FOR HEALTH, SAFETY AND ENVIRONMENTAL SECURITY UNDER EXTRAORDINARY INCIDENTS" target="ASHRAE HANDBOOK-FUNDAMENTALS">
      <data key="d7">ASHRAE RISK MANAGEMENT GUIDANCE FOR HEALTH, SAFETY AND ENVIRONMENTAL SECURITY UNDER EXTRAORDINARY INCIDENTS</data>
      <data key="d8">ASHRAE HANDBOOK-FUNDAMENTALS</data>
      <data key="d9">COMPLEMENTS</data>
      <data key="d10">The ASHRAE Risk Management Guidance complements the ASHRAE Handbook-Fundamentals by providing risk management context and application scenarios for the technical principles outlined in the Handbook. Together, they offer a comprehensive framework for implementing and validating engineering controls in healthcare and related settings.</data>
      <data key="d11">0.6</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
