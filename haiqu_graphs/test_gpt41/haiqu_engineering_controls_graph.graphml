      <data key="d7">VENTILATION STRATEGIES</data>
      <data key="d8">HOSPITAL LIFT</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Ventilation strategies are implemented in hospital lifts to reduce the accumulation of airborne pathogens by increasing air exchange and controlling airflow patterns.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
