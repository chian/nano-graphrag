      <data key="d8">DROPLET DISPERSION FROM A COUGH</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Ventilation strategies reduce the spatial and temporal dispersion of droplets from a cough, lowering the risk of airborne transmission in enclosed spaces.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
