      <data key="d8">COVID-19</data>
      <data key="d9">TARGETS</data>
      <data key="d10">Ventilation strategies are specifically aimed at reducing the airborne transmission of COVID-19 by diluting and removing infectious aerosols from indoor air.</data>
      <data key="d11">1.0</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
