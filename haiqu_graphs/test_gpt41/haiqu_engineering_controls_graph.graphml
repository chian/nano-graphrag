    <edge source="COVID-19 MITIGATION STRATEGY" target="COVID-19">
      <data key="d7">COVID-19 MITIGATION STRATEGY</data>
      <data key="d8">COVID-19</data>
      <data key="d9">TARGETS</data>
      <data key="d10">COVID-19 mitigation strategies are designed to reduce the transmission of COVID-19 through engineering and administrative controls.</data>
      <data key="d11">0.8</data>
