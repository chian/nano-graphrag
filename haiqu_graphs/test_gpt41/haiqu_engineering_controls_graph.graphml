      <data key="d8">NUMERICAL INVESTIGATION</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The effectiveness of ventilation strategies in mitigating airborne dispersion of MERS-CoV is validated by numerical investigation studies.</data>
      <data key="d11">0.7</data>
      <data key="d12">3</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
