      <data key="d7">VENTILATION STRATEGIES</data>
      <data key="d8">MERS-COV</data>
      <data key="d9">TARGETS</data>
      <data key="d10">Ventilation strategies are designed to reduce the airborne concentration and transmission risk of MERS-CoV in hospital settings.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION STRATEGIES" target="CRITICAL HOSPITAL AREAS">
      <data key="d7">VENTILATION STRATEGIES</data>
      <data key="d8">CRITICAL HOSPITAL AREAS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Ventilation strategies are applied in critical hospital areas to mitigate the risk of airborne transmission of pathogens, including fungi and viruses.</data>
      <data key="d11">0.85</data>
      <data key="d12">2</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
