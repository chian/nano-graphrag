      <data key="d8">CO2 ACCUMULATION</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Effective ventilation strategies reduce CO2 accumulation, which serves as a proxy for exhaled breath and potential pathogen concentration.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
