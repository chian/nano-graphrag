      <data key="d8">VENUE-SPECIFIC AEROSOL DISTRIBUTION PATTERNS</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">Specific indoor venues can have non-uniform, spatio-temporal aerosol distribution patterns that vary with venue geometry and ventilation conditions.</data>
      <data key="d11">0.88</data>
      <data key="d12">1</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_8</data>
      <data key="d14">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
    </edge>
    <edge source="VENTILATION PERFORMANCE" target="VENUE-SPECIFIC AEROSOL DISTRIBUTION PATTERNS">
