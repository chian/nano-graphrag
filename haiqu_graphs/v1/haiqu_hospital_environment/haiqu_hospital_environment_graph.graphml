      <data key="d8">INFECTIOUS AEROSOLS</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">Spectator occupancy can increase exhaled aerosol generation; if infectious occupants are present, this can increase the burden of infectious aerosols in the venue.</data>
      <data key="d11">0.78</data>
      <data key="d12">2</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_6</data>
      <data key="d14">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
    </edge>
