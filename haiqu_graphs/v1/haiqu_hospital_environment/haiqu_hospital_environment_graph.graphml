      <data key="d8">FAN-DRIVEN ROOM AIRFLOW</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">The room contains a fan-driven airflow distribution pattern produced by the two fans.</data>
      <data key="d11">0.88</data>
