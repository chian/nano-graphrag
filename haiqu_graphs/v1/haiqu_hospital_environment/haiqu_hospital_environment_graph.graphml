    <node id="WINDOWS">
      <data key="d0">WINDOWS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Openings or air-exchange paths relevant to naturally ventilated venues. The text lists windows as room parameters that influence airflow and make prediction of highly exposed positions more difficult.</data>
      <data key="d3">0.73</data>
      <data key="d4">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_47,2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_48</data>
      <data key="d5">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
    </node>
    <node id="BOUNDARY-CONDITION-SENSITIVE ROOM AIRFLOW">
      <data key="d0">BOUNDARY-CONDITION-SENSITIVE ROOM AIRFLOW</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Room airflow that changes substantially with boundary conditions and room parameters, including air inlets, outlets, windows, room height, and volume. This sensitivity limits reliable prediction of highly exposed positions in MV and NV venues.</data>
      <data key="d3">0.85</data>
      <data key="d4">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_47</data>
