      <data key="d8">AEROSOL AND DROPLET DISPERSION</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The mixed convection airflow provides the main transport mechanism for droplets, drops, and aerosols emitted by the modeled occupants.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_76</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
