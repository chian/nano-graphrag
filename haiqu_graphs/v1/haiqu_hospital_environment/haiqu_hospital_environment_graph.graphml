    <node id="REDUCED VENTILATION">
      <data key="d0">REDUCED VENTILATION</data>
      <data key="d1">ACH_RATE</data>
      <data key="d2">An event-specific ventilation condition that was disregarded in the modeling but could affect air exchange and aerosol concentration predictions.</data>
