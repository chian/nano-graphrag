      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">At the end of the simulation, the computational domain shows droplets distributed in its upper part due to buoyant transport.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_41</data>
