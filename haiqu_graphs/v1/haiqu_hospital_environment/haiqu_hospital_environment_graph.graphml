      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">The infectious emitter scenario is the source condition used to calculate infection probability and transmission risk, with risk varying by local aerosol exposure.</data>
      <data key="d11">0.88</data>
      <data key="d12">1</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_27</data>
