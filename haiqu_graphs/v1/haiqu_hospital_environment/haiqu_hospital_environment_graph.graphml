      <data key="d7">VENTILATION OF COMPARTMENT #1</data>
      <data key="d8">COMPARTMENT #1</data>
      <data key="d9">SERVES</data>
      <data key="d10">The ventilation system serves compartment #1 by removing airborne droplets from the occupied volume.</data>
      <data key="d11">0.92</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_59</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
