      <data key="d8">AIR CHANGE RATE</data>
      <data key="d9">HAS_ACH</data>
      <data key="d10">Room-level indoor spaces can be characterized by air change rate as a ventilation-performance metric.</data>
      <data key="d11">0.74</data>
      <data key="d12">1</data>
      <data key="d13">d8e5e6fb-91d7-40aa-8229-b92309abbaff_chunk_73</data>
      <data key="d14">d8e5e6fb-91d7-40aa-8229-b92309abbaff</data>
