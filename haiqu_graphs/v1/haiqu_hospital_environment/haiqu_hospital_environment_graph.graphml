    <edge source="EXHALED AIR JET" target="DROPLET AEROSOL">
      <data key="d7">EXHALED AIR JET</data>
      <data key="d8">DROPLET AEROSOL</data>
      <data key="d9">ACH_AFFECTS</data>
      <data key="d10">The velocity of the exhaled air jet affects aerosol transport. When mask use lowers the jet velocity, upward buoyancy becomes more dominant in carrying aerosol emitted by the contagious individual.</data>
      <data key="d11">0.81</data>
      <data key="d12">2</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_68</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
