      <data key="d0">FLOW DISTRIBUTION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">The room-scale airflow pattern modeled by CFD in an operating room, incorporating room dimensions, temperature, and personnel movement.</data>
      <data key="d3">0.82</data>
      <data key="d4">62e55c5d-3b2a-4772-a671-df2065fce8b1_chunk_37</data>
      <data key="d5">62e55c5d-3b2a-4772-a671-df2065fce8b1</data>
    </node>
