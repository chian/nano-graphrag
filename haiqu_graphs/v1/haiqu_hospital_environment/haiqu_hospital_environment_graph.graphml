      <data key="d8">CO2</data>
      <data key="d9">PATTERN_MEASURED_BY</data>
      <data key="d10">Ventilation performance at mass gathering events is evaluated through indoor air quality measurements, with CO2 serving as a practical tracer for rebreathed air and ventilation adequacy.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_70</data>
      <data key="d14">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
    </edge>
