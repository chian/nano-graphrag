      <data key="d8">SARS-COV-2</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">The infectious emitter increases the airborne SARS-CoV-2 source burden by releasing virus-containing aerosols into the occupied venue.</data>
      <data key="d11">0.94</data>
      <data key="d12">1</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_48</data>
      <data key="d14">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
    </edge>
    <edge source="FULLY OCCUPIED AUDIENCE" target="SARS-COV-2">
