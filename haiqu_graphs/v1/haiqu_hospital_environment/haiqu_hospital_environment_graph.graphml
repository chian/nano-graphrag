      <data key="d7">SEATED CONCERT ARENA</data>
      <data key="d8">GOOD VENTILATION CONDITIONS</data>
      <data key="d9">HAS_ACH</data>
      <data key="d10">The arena is described as well ventilated, although no specific ACH value is reported.</data>
      <data key="d11">0.78</data>
      <data key="d12">1</data>
      <data key="d13">0676edf9-1d10-4220-bdea-1b4729f9856d_chunk_16</data>
      <data key="d14">0676edf9-1d10-4220-bdea-1b4729f9856d</data>
    </edge>
    <edge source="SEATED CONCERT ARENA" target="WELL-VENTILATED AIR DISTRIBUTION">
      <data key="d7">SEATED CONCERT ARENA</data>
      <data key="d8">WELL-VENTILATED AIR DISTRIBUTION</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">The seated concert arena is characterized as having generally good ventilation, represented as a favorable air distribution condition.</data>
      <data key="d11">0.72</data>
      <data key="d12">1</data>
      <data key="d13">0676edf9-1d10-4220-bdea-1b4729f9856d_chunk_16</data>
      <data key="d14">0676edf9-1d10-4220-bdea-1b4729f9856d</data>
    </edge>
    <edge source="SEATED CONCERT ARENA" target="TRANSIT AND POST-CONCERT VENUES">
      <data key="d7">SEATED CONCERT ARENA</data>
      <data key="d8">TRANSIT AND POST-CONCERT VENUES</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The text notes that additional contacts linked to the mass gathering event may occur during transit or in bars and similar venues after the concert.</data>
      <data key="d11">0.48</data>
      <data key="d12">3</data>
      <data key="d13">0676edf9-1d10-4220-bdea-1b4729f9856d_chunk_16</data>
      <data key="d14">0676edf9-1d10-4220-bdea-1b4729f9856d</data>
    </edge>
