      <data key="d7">REAL PASSENGERS WEARING MASKS OR NOT</data>
      <data key="d8">INFECTIOUS AGENTS</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">Real passengers may carry infectious agents and release pathogen-bearing particles while breathing; mask use, leakage, or absence can alter emission magnitude and spread.</data>
      <data key="d11">0.74</data>
      <data key="d12">2</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_76</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
