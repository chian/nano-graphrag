      <data key="d8">SARS-COV-2 VIRUS</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">The exhaled droplets are described as particles capable of carrying SARS-CoV-2, thereby increasing the airborne pathogen burden when emitted by the infected passenger.</data>
      <data key="d11">0.82</data>
      <data key="d12">3</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_58</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
