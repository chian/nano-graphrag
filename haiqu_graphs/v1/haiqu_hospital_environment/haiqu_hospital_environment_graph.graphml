      <data key="d8">BUOYANT UPWARD PLUME</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">The simulated coach compartment exhibits a buoyant upward airflow pattern generated by warm exhaled air from the spreader.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_60</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
