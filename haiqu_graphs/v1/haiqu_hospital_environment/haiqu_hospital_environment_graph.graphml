    <node id="DOWNWARDS-BLOWING FAN SYSTEM">
      <data key="d0">DOWNWARDS-BLOWING FAN SYSTEM</data>
      <data key="d1">HVAC_UNIT</data>
      <data key="d2">Fan-based ventilation system configured to blow air downward in the modelled room. It expelled the most CO2 gas and removed droplets most quickly, although the study did not conclusively establish that it was safer than the upward-blowing fan case in terms of risk probability.</data>
      <data key="d3">0.89</data>
      <data key="d4">c3ec75c5-6024-45ba-a0b0-8dd0c746991b_chunk_41</data>
      <data key="d5">c3ec75c5-6024-45ba-a0b0-8dd0c746991b</data>
    </node>
