      <data key="d8">OUTSIDE THE ROOM</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The open doorway provides an air path from the neutral-pressure ICU to the outside-room zone.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">62e55c5d-3b2a-4772-a671-df2065fce8b1_chunk_0</data>
      <data key="d14">62e55c5d-3b2a-4772-a671-df2065fce8b1</data>
