    <node id="DOWNWARDS-BLOWING FAN AIRFLOW">
      <data key="d0">DOWNWARDS-BLOWING FAN AIRFLOW</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">An air distribution pattern corresponding to the fan blowing downward. The passage states that two linear regressions were proposed for the downward-blowing fan case data. | An air distribution pattern corresponding to the fan blowing upward. The passage states that one linear regression was proposed for the upward-blowing fan case data.</data>
      <data key="d3">0.64</data>
      <data key="d4">c3ec75c5-6024-45ba-a0b0-8dd0c746991b_chunk_39</data>
      <data key="d5">c3ec75c5-6024-45ba-a0b0-8dd0c746991b</data>
