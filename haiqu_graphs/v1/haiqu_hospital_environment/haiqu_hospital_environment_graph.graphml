      <data key="d0">RETURN AIR PATHS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Airflow pathways used to return indoor air within air supply-return or combined supply-return-exhaust systems. These paths contribute to recirculation and airflow complexity.</data>
      <data key="d3">0.68</data>
      <data key="d4">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_5</data>
      <data key="d5">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </node>
