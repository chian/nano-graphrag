      <data key="d4">d8e5e6fb-91d7-40aa-8229-b92309abbaff_chunk_74</data>
      <data key="d5">d8e5e6fb-91d7-40aa-8229-b92309abbaff</data>
    </node>
    <node id="BUILDING AIR EXCHANGE">
      <data key="d0">BUILDING AIR EXCHANGE</data>
      <data key="d1">ACH_RATE</data>
      <data key="d2">Air exchange in buildings, referenced as the ventilation-related quantity studied using tracer gas techniques.</data>
      <data key="d3">0.72</data>
      <data key="d4">d8e5e6fb-91d7-40aa-8229-b92309abbaff_chunk_74</data>
      <data key="d5">d8e5e6fb-91d7-40aa-8229-b92309abbaff</data>
