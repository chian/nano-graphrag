      <data key="d7">EXHALED AIR JET</data>
      <data key="d8">RE-ASPIRATION PATH</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">Some droplets associated with the respiratory airflow are re-aspirated by the manikin and removed from the computational domain.</data>
      <data key="d11">0.52</data>
      <data key="d12">3</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_44</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
