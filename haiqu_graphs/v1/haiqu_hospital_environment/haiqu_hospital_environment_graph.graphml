      <data key="d8">AIRFLOW PATTERN CONDITIONS</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">The poorer-performing ventilation version also had an airflow configuration associated with worse aerosol distribution and a ten-fold increase in exposed individuals.</data>
      <data key="d11">0.84</data>
      <data key="d12">2</data>
      <data key="d13">0676edf9-1d10-4220-bdea-1b4729f9856d_chunk_0</data>
      <data key="d14">0676edf9-1d10-4220-bdea-1b4729f9856d</data>
    </edge>
