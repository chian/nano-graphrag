      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">Coughing or breathing by occupants can increase the presence and transmission potential of airborne SARS-CoV-2 in indoor environments.</data>
      <data key="d11">0.78</data>
      <data key="d12">2</data>
      <data key="d13">c3ec75c5-6024-45ba-a0b0-8dd0c746991b_chunk_1</data>
      <data key="d14">c3ec75c5-6024-45ba-a0b0-8dd0c746991b</data>
    </edge>
