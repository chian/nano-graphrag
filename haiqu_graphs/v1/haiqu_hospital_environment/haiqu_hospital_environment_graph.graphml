      <data key="d7">LEAK ZONES</data>
      <data key="d8">UPWARD DROPLET DISPERSION</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">Droplets escaping from mask leak zones enter the surrounding flow and are subsequently entrained into the upward plume-driven dispersion.</data>
      <data key="d11">0.78</data>
      <data key="d12">3</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_47</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
    <edge source="CASE #3 SIMULATION DOMAIN" target="BUOYANT PLUME">
      <data key="d7">CASE #3 SIMULATION DOMAIN</data>
      <data key="d8">BUOYANT PLUME</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">The case #3 simulation domain contains an upward buoyant plume that governs the movement of air and droplets around the manikin.</data>
      <data key="d11">0.88</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_48</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
