      <data key="d8">COMPARTMENT #2</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The dominant extraction pathway is routed through the middle compartment, where 50% of the air is extracted.</data>
      <data key="d11">0.92</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_90</data>
