      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">The standard occupancy condition places 99 spectators in the audience seating area, increasing the number of exposed receptor positions and affecting global risk.</data>
      <data key="d11">0.78</data>
      <data key="d12">1</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_24</data>
