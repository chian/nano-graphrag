      <data key="d8">ROOM AIR MIXING</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">The fans generated or supported the room air mixing pattern that dispersed pathogen-containing aerosols before mechanical ventilation and UV-C operation began.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">19fa3b4e-2c3d-44b1-ae20-59902abc601a_chunk_24</data>
      <data key="d14">19fa3b4e-2c3d-44b1-ae20-59902abc601a</data>
