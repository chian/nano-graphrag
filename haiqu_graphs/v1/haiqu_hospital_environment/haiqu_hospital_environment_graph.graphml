      <data key="d8">HUMAN-LIKE RESPIRATORY AEROSOL DISTRIBUTION</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">Aerosol released through the nasal path follows a human-like respiratory distribution, including predominantly sub-10 μm particles and a time-varying breathing flow profile.</data>
      <data key="d11">0.86</data>
      <data key="d12">3</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_13</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
