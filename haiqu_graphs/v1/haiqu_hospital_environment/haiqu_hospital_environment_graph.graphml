      <data key="d8">SARS-COV-2</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">An average of nine direct contacts per visitor increases potential close-contact transmission opportunities for SARS-CoV-2, although the text notes that appropriate hygiene practices can substantially reduce this contact burden.</data>
      <data key="d11">0.79</data>
      <data key="d12">2</data>
      <data key="d13">0676edf9-1d10-4220-bdea-1b4729f9856d_chunk_0</data>
      <data key="d14">0676edf9-1d10-4220-bdea-1b4729f9856d</data>
    </edge>
