      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Airflow and concentration behavior that may be affected by constant thermal boundary-condition assumptions, environmental boundary conditions, heat-load reservoirs, intensified lighting, and other event-specific conditions.</data>
      <data key="d3">0.72</data>
      <data key="d4">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_43</data>
      <data key="d5">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
    </node>
