      <data key="d8">VENUE-SPECIFIC AEROSOL DISTRIBUTION PATTERNS</data>
      <data key="d9">ACH_AFFECTS</data>
      <data key="d10">Ventilation performance influences how aerosols disperse within indoor venues, shaping venue-specific aerosol distribution patterns and airborne transmission conditions.</data>
      <data key="d11">0.82</data>
      <data key="d12">2</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_8</data>
      <data key="d14">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
    </edge>
