      <data key="d8">50% EXTRACTION THROUGH COMPARTMENT #2</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The outgoing airflow configuration includes the specific condition that half of the extracted air leaves through compartment #2.</data>
      <data key="d11">0.89</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_90</data>
