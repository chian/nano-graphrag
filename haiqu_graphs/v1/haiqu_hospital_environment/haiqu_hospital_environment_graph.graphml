    <edge source="NO-VENTILATION CASE" target="CO2 CONCENTRATION">
      <data key="d7">NO-VENTILATION CASE</data>
      <data key="d8">CO2 CONCENTRATION</data>
      <data key="d9">PATTERN_MEASURED_BY</data>
      <data key="d10">The no-ventilation condition was assessed using CO2 concentration to evaluate accumulation in the absence of active mechanical airflow.</data>
      <data key="d11">0.82</data>
      <data key="d12">2</data>
      <data key="d13">c3ec75c5-6024-45ba-a0b0-8dd0c746991b_chunk_0</data>
