      <data key="d0">POSITIVE PRESSURE ENVIRONMENT</data>
      <data key="d1">PRESSURE_RELATIONSHIP</data>
      <data key="d2">A pressure condition reported across the studied rooms. The text states that this positive pressure environment resulted in significant aerosol leakage from the room, indicating outward airflow from the clinical zone.</data>
      <data key="d3">0.9</data>
      <data key="d4">62e55c5d-3b2a-4772-a671-df2065fce8b1_chunk_37</data>
