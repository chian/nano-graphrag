      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A ventilation strategy in which the ceiling fan operates as an upward-blowing exhaust, influencing removal and dispersion of CO2 and cough-generated droplets within the lift.</data>
      <data key="d3">0.91</data>
      <data key="d4">c3ec75c5-6024-45ba-a0b0-8dd0c746991b_chunk_0</data>
      <data key="d5">c3ec75c5-6024-45ba-a0b0-8dd0c746991b</data>
    </node>
    <node id="DOWNWARD-BLOWING FAN CASE">
