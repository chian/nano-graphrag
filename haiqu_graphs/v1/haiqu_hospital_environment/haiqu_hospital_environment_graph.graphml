      <data key="d8">MICROMETRIC DROPLETS</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">The breathing manikin emits micrometric respiratory droplets during exhalation, making the occupant the contaminant source in the simulation.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_41</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
