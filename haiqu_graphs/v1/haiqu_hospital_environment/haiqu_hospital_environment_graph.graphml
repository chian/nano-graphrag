      <data key="d8">VENUE</data>
      <data key="d9">SERVES</data>
      <data key="d10">The ventilation system serves the venue and provides the ventilation concepts and airflow conditions used in the infection-risk assessment.</data>
      <data key="d11">0.78</data>
      <data key="d12">1</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_40</data>
