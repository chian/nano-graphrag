      <data key="d9">HAS_ACH</data>
      <data key="d10">For the room, far-UVC exposure is estimated to provide an effective ACH of 1480 when a K mixing factor of 10 is applied.</data>
      <data key="d11">0.91</data>
      <data key="d12">1</data>
      <data key="d13">d8e5e6fb-91d7-40aa-8229-b92309abbaff_chunk_24</data>
      <data key="d14">d8e5e6fb-91d7-40aa-8229-b92309abbaff</data>
