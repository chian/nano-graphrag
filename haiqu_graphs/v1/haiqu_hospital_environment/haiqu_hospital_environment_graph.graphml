    <edge source="AIR PURIFICATION DEVICE" target="SUBWAY CABIN / COMPARTMENT">
      <data key="d7">AIR PURIFICATION DEVICE</data>
      <data key="d8">SUBWAY CABIN / COMPARTMENT</data>
      <data key="d9">SERVES</data>
      <data key="d10">The air purification device serves the subway cabin or compartment by supporting pathogen disinfection in an occupied traffic environment.</data>
      <data key="d11">0.78</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_14</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR PURIFICATION DEVICE" target="SUBWAY COMPARTMENT">
      <data key="d7">TWO PURIFICATION DEVICES</data>
      <data key="d8">SUBWAY COMPARTMENT</data>
      <data key="d9">SERVES</data>
      <data key="d10">The two purification devices serve the subway compartment during case 3, case 4, and case 5 while their purification efficiency is evaluated.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_22</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="PASSENGER OCCUPANCY IN TRAFFIC ENVIRONMENTS" target="S. AUREUS">
      <data key="d7">PASSENGER OCCUPANCY IN TRAFFIC ENVIRONMENTS</data>
      <data key="d8">S. AUREUS</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">Frequent passenger presence can increase the relevance and potential burden of respiratory-associated airborne pathogens such as S. aureus in traffic environments, motivating air purification and disinfection.</data>
      <data key="d11">0.6</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_14</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="PASSENGER OCCUPANCY IN TRAFFIC ENVIRONMENTS" target="RESPIRATORY-LIKE BIOAEROSOL EMISSION FLOW">
      <data key="d7">PASSENGER OCCUPANCY IN TRAFFIC ENVIRONMENTS</data>
      <data key="d8">RESPIRATORY-LIKE BIOAEROSOL EMISSION FLOW</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">Greater passenger occupancy increases the amount of human respiratory activity that the manikin/aerosol generator is designed to simulate through repeated breath-like bioaerosol emissions.</data>
      <data key="d11">0.62</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_14</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="TRAIN CARRIAGES" target="GOOD AIR CIRCULATION AND VENTILATION INSIDE THE CARRIAGE">
      <data key="d7">TRAIN CARRIAGES</data>
      <data key="d8">GOOD AIR CIRCULATION AND VENTILATION INSIDE THE CARRIAGE</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">Train carriages require good circulation and ventilation patterns, particularly in confined spaces during crowded operation.</data>
      <data key="d11">0.78</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="IFD AIR PURIFICATION DEVICE">
      <data key="d7">IFD FILTER</data>
      <data key="d8">AIR PURIFICATION DEVICES</data>
      <data key="d9">SERVES</data>
      <data key="d10">The IFD filter is one of the designed air purification devices evaluated for train cabin air purification.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="AIR-CONDITIONING SYSTEM">
      <data key="d7">IFD FILTER</data>
      <data key="d8">AIR CONDITIONING SYSTEM</data>
      <data key="d9">SERVES</data>
      <data key="d10">The IFD filter is selected for use with the air-conditioning system because it maintains airflow with low resistance. | The IFD filter is installed in or integrated with the air conditioning system to purify cabin air and reduce bioaerosol concentration.</data>
      <data key="d11">0.89</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="LOW AIR RESISTANCE">
      <data key="d7">IFD FILTER</data>
      <data key="d8">LOW AIR RESISTANCE</data>
      <data key="d9">HAS_PRESSURE</data>
      <data key="d10">The IFD filter is described as having low air resistance, a pressure-flow advantage for train air-conditioning use.</data>
      <data key="d11">0.88</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="GREAT VOLUME OF AIRFLOW">
      <data key="d7">IFD FILTER</data>
      <data key="d8">GREAT VOLUME OF AIRFLOW</data>
      <data key="d9">HAS_ACH</data>
      <data key="d10">The low-resistance IFD filter allows a great volume of air to flow into the air-conditioning system.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="MIXING CHAMBER">
      <data key="d7">IFD FILTER</data>
      <data key="d8">MIXING CHAMBER</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The IFD filter is installed at the mixing chamber, the point where fresh and recirculated air streams merge.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="AIR ENTERING THE CABIN">
      <data key="d7">IFD FILTER</data>
      <data key="d8">AIR ENTERING THE CABIN</data>
      <data key="d9">SERVES</data>
      <data key="d10">By filtering air at the mixing chamber, the IFD filter serves the downstream airflow entering the cabin and improves its cleanliness.</data>
      <data key="d11">0.88</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="SEALED CABIN">
      <data key="d7">IFD FILTER</data>
      <data key="d8">SEALED CABIN</data>
      <data key="d9">SERVES</data>
      <data key="d10">The IFD filter contributes to the sealed cabin's air cleanliness by treating the mixed air before it enters the cabin.</data>
      <data key="d11">0.86</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="INDOOR ENVIRONMENT">
      <data key="d7">IFD FILTER</data>
      <data key="d8">INDOOR ENVIRONMENT</data>
      <data key="d9">SERVES</data>
      <data key="d10">The IFD filter is evaluated as an indoor air purification unit intended to serve occupied indoor environments safely.</data>
      <data key="d11">0.74</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_19</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="CABIN / COMPARTMENT">
      <data key="d7">IFD FILTER</data>
      <data key="d8">CABIN / COMPARTMENT</data>
      <data key="d9">SERVES</data>
      <data key="d10">The IFD filter serves the compartment as an air-purification unit evaluated for individual and combined effectiveness.</data>
      <data key="d11">0.76</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_29</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="CABIN ENVIRONMENT">
      <data key="d7">IFD FILTER</data>
      <data key="d8">CABIN ENVIRONMENT</data>
      <data key="d9">SERVES</data>
      <data key="d10">The IFD filter operates in the cabin environment as an air purification device, reducing airborne bioaerosol concentration over time and helping cabin air approach near-zero bioaerosol concentration after 25 minutes.</data>
      <data key="d11">0.88</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_30</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="BREATHING ZONE OF SEATED PASSENGERS">
      <data key="d7">IFD FILTER</data>
      <data key="d8">BREATHING ZONE OF SEATED PASSENGERS</data>
      <data key="d9">SERVES</data>
      <data key="d10">The IFD filter serves the breathing zone of seated passengers by reducing bioaerosol concentration in the air occupants inhale.</data>
      <data key="d11">0.84</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_30</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="AIR MONITORING POINTS">
      <data key="d7">IFD FILTER</data>
      <data key="d8">AIR MONITORING POINTS</data>
      <data key="d9">SERVES</data>
      <data key="d10">The IFD filter reduced airborne bioaerosol levels measured at air monitoring points, with R values of 52.46-66.33% at t = 5 min during continuous bacterial dispersal.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_30</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="SEDIMENT MONITORING POINTS">
      <data key="d7">IFD FILTER</data>
      <data key="d8">SEDIMENT MONITORING POINTS</data>
      <data key="d9">SERVES</data>
      <data key="d10">The IFD filter reduced deposited biological contamination measured at sediment monitoring points, with an average sediment purification ability of 83.65%.</data>
      <data key="d11">0.78</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_30</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="SUBWAY CARRIAGE OCCUPIED AIRSPACE">
      <data key="d7">IFD FILTER</data>
      <data key="d8">SUBWAY CARRIAGE OCCUPIED AIRSPACE</data>
      <data key="d9">SERVES</data>
      <data key="d10">The IFD filter serves the occupied carriage airspace by removing or purifying airborne particles during the experimental cases, including Case 3 when it operates alone and Case 5 when it operates with the CP generator.</data>
      <data key="d11">0.84</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_31</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="CABIN AIR">
      <data key="d7">IFD FILTER</data>
      <data key="d8">CABIN AIR</data>
      <data key="d9">SERVES</data>
      <data key="d10">The IFD filter serves cabin air quality by purifying the air passing through the mixing chamber and reducing microorganism concentration in the cabin.</data>
      <data key="d11">0.88</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_32</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="IFD FILTER" target="MICROORGANISMS">
      <data key="d7">IFD FILTER</data>
      <data key="d8">MICROORGANISMS</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The IFD filter is functionally connected to microorganisms because its purification action reduces their concentration in cabin air.</data>
      <data key="d11">0.74</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_32</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="TRADITIONAL PHYSICAL-MECHANICAL FILTERS" target="HIGH AIR RESISTANCE">
      <data key="d7">TRADITIONAL PHYSICAL-MECHANICAL FILTERS</data>
      <data key="d8">HIGH AIR RESISTANCE</data>
      <data key="d9">HAS_PRESSURE</data>
      <data key="d10">Many traditional physical-mechanical filters are described as producing high air resistance despite strong particulate capture.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR CONDITIONING UNITS" target="SUBWAY CABINS">
      <data key="d7">AIR CONDITIONING UNITS</data>
      <data key="d8">SUBWAY CABINS</data>
      <data key="d9">SERVES</data>
      <data key="d10">Air-conditioning units serve the subway cabin environment and are explicitly included among the targets for simultaneous pathogen disinfection.</data>
      <data key="d11">0.88</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CABIN AIRFLOW" target="SUBWAY CABINS">
      <data key="d7">CABIN AIRFLOW</data>
      <data key="d8">SUBWAY CABINS</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">Cabin airflow is the internal air path within subway cabins and a direct target for pathogen disinfection.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR DUCTS" target="AIR CONDITIONING UNITS">
      <data key="d7">AIR DUCTS</data>
      <data key="d8">AIR CONDITIONING UNITS</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">Air ducts connect with the air-conditioning units as part of the cabin air-handling pathway.</data>
      <data key="d11">0.84</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR DUCTS" target="SUBWAY CABINS">
      <data key="d7">AIR DUCTS</data>
      <data key="d8">SUBWAY CABINS</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">Air ducts form part of the air path linked to subway cabins and are included in the disinfection strategy. | The air ducts are part of the cabin air-movement structure and shape airflow within the subway cabin.</data>
      <data key="d11">0.84</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR DUCTS" target="SUPPLY VENTS">
      <data key="d7">AIR DUCTS</data>
      <data key="d8">SUPPLY AIR VENTS</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The air ducts function as airflow paths that feed the supply air vents delivering air into the subway compartment.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_23</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR DUCTS" target="CENTRAL-REGION HIGHER AIR VELOCITY PATTERN">
      <data key="d7">AIR DUCTS</data>
      <data key="d8">CENTRAL-REGION HIGHER AIR VELOCITY PATTERN</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">Spatial changes in duct resistance and momentum loss, which decrease nearer the air conditioning unit, help explain why air velocity is higher in the central region than at the compartment ends.</data>
      <data key="d11">0.77</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_23</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR DUCTS" target="RELATIVE UNIFORMITY">
      <data key="d7">AIR DUCTS</data>
      <data key="d8">RELATIVE UNIFORMITY</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The nearly symmetrical air ducts shape the cabin flow field and contribute to relatively uniform bioaerosol distribution.</data>
      <data key="d11">0.78</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_26</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR DUCTS" target="TYPICAL SUBWAY CABIN">
      <data key="d7">AIR DUCTS</data>
      <data key="d8">TYPICAL SUBWAY CABIN</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The air ducts are airflow paths connected to or integrated within the subway cabin. They support airflow redistribution and contribute to cabin-scale aerosol movement.</data>
      <data key="d11">0.88</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_33</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR INTAKE" target="AIR-CONDITIONING SYSTEM">
      <data key="d7">AIR INTAKE</data>
      <data key="d8">AIR CONDITIONING SYSTEM</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">Air intake provides the incoming airflow path into the air-conditioning system.</data>
      <data key="d11">0.83</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="HIGH AIR RESISTANCE" target="AIRFLOW EFFICIENCY">
      <data key="d7">HIGH AIR RESISTANCE</data>
      <data key="d8">AIRFLOW EFFICIENCY</data>
      <data key="d9">ACH_AFFECTS</data>
      <data key="d10">High filter resistance can negatively affect the airflow efficiency of the air-conditioning system.</data>
      <data key="d11">0.78</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="GREAT VOLUME OF AIRFLOW" target="GOOD AIR CIRCULATION AND VENTILATION INSIDE THE CARRIAGE">
      <data key="d7">GREAT VOLUME OF AIRFLOW</data>
      <data key="d8">GOOD AIR CIRCULATION AND VENTILATION INSIDE THE CARRIAGE</data>
      <data key="d9">ACH_AFFECTS</data>
      <data key="d10">High airflow throughput supports good air circulation and ventilation inside confined train carriages.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="FREQUENT PRESENCE OF PASSENGERS" target="PATHOGENS">
      <data key="d7">FREQUENT PRESENCE OF PASSENGERS</data>
      <data key="d8">PATHOGENS</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">Frequent passenger presence increases the relevance of airborne pathogen-control measures in traffic environments.</data>
      <data key="d11">0.76</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_15</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="PEAK TIMES" target="PATHOGENS">
      <data key="d7">PEAK TIMES</data>
      <data key="d8">PATHOGENS</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">Peak-time crowding in confined train carriages increases concern about pathogen loading or transmission risk, making ventilation and purification more important.</data>
      <data key="d11">0.72</data>
      <data key="d12">2</data>
