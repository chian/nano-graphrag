      <data key="d8">ONE MICROMETER EXHALED DROPLETS</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">The infected passenger’s breathing generates approximately 1 µm respiratory droplets during exhalation phases, increasing the airborne droplet load in the occupied coach.</data>
      <data key="d11">0.92</data>
      <data key="d12">2</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_58</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
    <edge source="ONE MICROMETER EXHALED DROPLETS" target="SARS-COV-2 VIRUS">
