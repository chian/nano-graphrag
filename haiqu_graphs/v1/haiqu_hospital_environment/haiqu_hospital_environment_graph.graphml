      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Typical vertical ventilation pattern for railway coaches in which fresh air is supplied near the floor and extracted at a higher coach level, producing an upward or vertically organized airflow arrangement.</data>
      <data key="d3">0.78</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_84</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
