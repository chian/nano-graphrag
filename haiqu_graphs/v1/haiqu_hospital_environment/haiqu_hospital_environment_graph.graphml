      <data key="d8">SUBWAY CABIN</data>
      <data key="d9">SERVES</data>
      <data key="d10">The two air conditioning units serve the subway cabin by treating air, mixing return air with fresh air, and supplying conditioned air back into the compartment.</data>
      <data key="d11">0.96</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_11</data>
