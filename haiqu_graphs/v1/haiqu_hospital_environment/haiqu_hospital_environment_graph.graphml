      <data key="d8">BUOYANT PLUME</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">In the perfectly fitted mask case, the warm exhaled air jet is redirected upward and helps power the buoyant plume above the manikin's head.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_44</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
