      <data key="d7">FANS</data>
      <data key="d8">MEASUREMENT FACILITY</data>
      <data key="d9">SERVES</data>
      <data key="d10">The fans serve the measurement facility by promoting air movement and aerosol mixing during the dispersion period before measurements began.</data>
      <data key="d11">0.78</data>
      <data key="d12">1</data>
      <data key="d13">19fa3b4e-2c3d-44b1-ae20-59902abc601a_chunk_24</data>
