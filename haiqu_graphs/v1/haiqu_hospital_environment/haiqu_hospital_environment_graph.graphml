      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Air distribution pattern in which air is supplied along the walls at lower and upper levels and extracted at the ends of the coach.</data>
      <data key="d3">0.86</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_85</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
