      <data key="d5">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </node>
    <node id="CONVENTIONAL EXTERNAL AIR CIRCULATION APPROACH">
      <data key="d0">CONVENTIONAL EXTERNAL AIR CIRCULATION APPROACH</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">External-air circulation mode used in the vacant subway cabin experiment. It defines the baseline ventilation pattern governing transport of emitted bioaerosols and aerosols carrying active bacteria.</data>
      <data key="d3">0.84</data>
      <data key="d4">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_20</data>
      <data key="d5">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </node>
