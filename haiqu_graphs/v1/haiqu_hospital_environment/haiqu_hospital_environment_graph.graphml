      <data key="d0">STABLE FLOW FIELD CONDITIONS</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Confirmed steady airflow state prior to bioaerosol release. Stability of these conditions is used as a prerequisite before each bioaerosol experimental round.</data>
      <data key="d3">0.78</data>
      <data key="d4">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_21</data>
      <data key="d5">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </node>
    <node id="PORTABLE HOTWIRE ANEMOMETER DEVICES">
      <data key="d0">PORTABLE HOTWIRE ANEMOMETER DEVICES</data>
      <data key="d1">HVAC_UNIT</data>
      <data key="d2">Portable airflow-measurement devices used to monitor flow field data before bioaerosol release. They are represented as equipment units within the available schema.</data>
      <data key="d3">0.72</data>
      <data key="d4">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_21</data>
      <data key="d5">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </node>
