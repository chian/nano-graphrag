      <data key="d8">AIR EXCHANGE RATE CONDITIONS</data>
      <data key="d9">HAS_ACH</data>
      <data key="d10">The poorer-performing ventilation version had an air exchange condition that contributed to substantially greater aerosol exposure compared with the better-performing condition.</data>
      <data key="d11">0.82</data>
      <data key="d12">2</data>
      <data key="d13">0676edf9-1d10-4220-bdea-1b4729f9856d_chunk_0</data>
      <data key="d14">0676edf9-1d10-4220-bdea-1b4729f9856d</data>
    </edge>
