      <data key="d8">SARS-COV-2 / COVID-19 INFECTIOUS AEROSOLS</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">The checkerboard seating arrangement defined the occupied spectator distribution used to calculate exposure and infection-risk outcomes in the scenarios.</data>
      <data key="d11">0.62</data>
      <data key="d12">3</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_23</data>
      <data key="d14">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
    </edge>
