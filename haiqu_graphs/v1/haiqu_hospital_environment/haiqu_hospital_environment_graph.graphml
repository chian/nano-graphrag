    <node id="STAGE AREA">
      <data key="d0">STAGE AREA</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">An occupied performance zone in the venue. The text recommends enforcing its connection to the ventilation system because inadequate ventilation of this area can increase aerosol transmission risk for performers and staff.</data>
      <data key="d3">0.88</data>
      <data key="d4">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_48</data>
