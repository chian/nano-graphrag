      <data key="d1">AIR_PATH</data>
      <data key="d2">Indoor air movement route by which cough- or breath-generated droplets, drops, and aerosols disperse through occupied spaces and potentially carry SARS-CoV-2.</data>
      <data key="d3">0.76</data>
      <data key="d4">c3ec75c5-6024-45ba-a0b0-8dd0c746991b_chunk_1</data>
      <data key="d5">c3ec75c5-6024-45ba-a0b0-8dd0c746991b</data>
    </node>
    <node id="ACTIVE VIRAL OR BACTERIAL PARTICLES">
      <data key="d0">ACTIVE VIRAL OR BACTERIAL PARTICLES</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Viable viral or bacterial infectious particles described as being transmitted through inhalation. The text identifies these particles as one of the main routes for breathing-disease transmission.</data>
      <data key="d3">0.9</data>
      <data key="d4">c3ec75c5-6024-45ba-a0b0-8dd0c746991b_chunk_2</data>
      <data key="d5">c3ec75c5-6024-45ba-a0b0-8dd0c746991b</data>
    </node>
