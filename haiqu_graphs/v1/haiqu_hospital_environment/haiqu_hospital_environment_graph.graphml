      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Potentially infectious airborne aerosols emitted by an infected occupant during breathing. Their spatio-temporal distribution is influenced by ventilation, thermal effects, mask filtration, mask leakage, and occupancy configuration.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_1</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
