      <data key="d1">HVAC_UNIT</data>
      <data key="d2">Indoor air purification device equipped with an IFD filter. Its ozone concentration was evaluated at the outlet of the duct containing the filter.</data>
      <data key="d3">0.78</data>
      <data key="d4">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_18</data>
      <data key="d5">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </node>
