      <data key="d0">RESPIRATORY AEROSOL EXPOSURE</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Airborne respiratory aerosol exposure discussed in passenger and indoor environments; includes aerosolized particles generated by breathing or coughing that may carry infectious material.</data>
      <data key="d3">0.9</data>
      <data key="d4">c3ec75c5-6024-45ba-a0b0-8dd0c746991b_chunk_4</data>
      <data key="d5">c3ec75c5-6024-45ba-a0b0-8dd0c746991b</data>
    </node>
    <node id="VIRUS-CONTAINING COUGHING DROPLETS">
      <data key="d0">VIRUS-CONTAINING COUGHING DROPLETS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Droplets expelled during coughing that may contain virus and whose transport characteristics and transmission risk are affected by surrounding airflow.</data>
