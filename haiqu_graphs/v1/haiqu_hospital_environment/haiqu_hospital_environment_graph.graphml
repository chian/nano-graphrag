    <node id="NO-FAN AIRFLOW CONDITION">
      <data key="d0">NO-FAN AIRFLOW CONDITION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A baseline air distribution condition in which no fan was used. The text states that one linear regression was proposed for the no-fan case data.</data>
      <data key="d3">0.55</data>
      <data key="d4">c3ec75c5-6024-45ba-a0b0-8dd0c746991b_chunk_39</data>
      <data key="d5">c3ec75c5-6024-45ba-a0b0-8dd0c746991b</data>
