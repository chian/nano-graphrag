      <data key="d8">PATHOGEN-LADEN EXPIRATORY DROPLETS</data>
      <data key="d9">PATTERN_MEASURED_BY</data>
      <data key="d10">The downward-blowing fan case was evaluated by fractional droplet removal through evaporation, deposition, or expulsion and showed the best removal performance.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">c3ec75c5-6024-45ba-a0b0-8dd0c746991b_chunk_38</data>
      <data key="d14">c3ec75c5-6024-45ba-a0b0-8dd0c746991b</data>
    </edge>
