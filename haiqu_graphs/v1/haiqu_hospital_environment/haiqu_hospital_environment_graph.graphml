      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">19fa3b4e-2c3d-44b1-ae20-59902abc601a_chunk_24</data>
      <data key="d14">19fa3b4e-2c3d-44b1-ae20-59902abc601a</data>
