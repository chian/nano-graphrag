      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The nose and mouth openings are configured on the two human mannequins to reproduce breathing and coughing emissions.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">c3ec75c5-6024-45ba-a0b0-8dd0c746991b_chunk_16</data>
      <data key="d14">c3ec75c5-6024-45ba-a0b0-8dd0c746991b</data>
