    <edge source="DESIGNED IFD FILTER" target="RESTAURANT AIR CONDITIONING SYSTEM">
      <data key="d7">DESIGNED IFD FILTER</data>
      <data key="d8">TRAIN AIR CONDITIONING SYSTEM</data>
      <data key="d9">SERVES</data>
      <data key="d10">The IFD filter is field-installed in the air conditioning system to purify air passing through the system.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_16</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="DESIGNED IFD FILTER" target="PARTICLE-ASSOCIATED BACTERIA AND MICROORGANISMS">
      <data key="d7">DESIGNED IFD FILTER</data>
      <data key="d8">PARTICLE-ASSOCIATED BACTERIA AND MICROORGANISMS</data>
      <data key="d9">PRESSURE_CONTAINS</data>
      <data key="d10">Although the text describes electrostatic neutralization rather than pressure containment, the IFD filter reduces the presence and growth of particle-associated microorganisms within the filtration system.</data>
      <data key="d11">0.55</data>
      <data key="d12">3</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_16</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="RESTAURANT AIR CONDITIONING SYSTEM">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">TRAIN AIR CONDITIONING SYSTEM</data>
      <data key="d9">SERVES</data>
      <data key="d10">The CP generator is shown as an air purification device installed with the IFD filter in the air conditioning system.</data>
      <data key="d11">0.7</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_16</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="AIR SUPPLY CHAMBER">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">AIR SUPPLY CHAMBER</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The CP generator is installed in the air supply chamber so that its generated ions enter the supply airflow.</data>
      <data key="d11">0.92</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_18</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="POSITIVE AND NEGATIVE ION DISTRIBUTION">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">POSITIVE AND NEGATIVE ION DISTRIBUTION</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">The CP generator produces the positive and negative ion distribution pattern during operation.</data>
      <data key="d11">0.91</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_18</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="CP GENERATOR OZONE BUILDUP PATTERN">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">CP GENERATOR OZONE BUILDUP PATTERN</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">Operation of the CP generator produced the measured ozone buildup pattern in the sealed chamber.</data>
      <data key="d11">0.84</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_18</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="CABIN / COMPARTMENT">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">CABIN / COMPARTMENT</data>
      <data key="d9">SERVES</data>
      <data key="d10">The CP generator serves the compartment as an air-purification unit evaluated alone and in combination with the IFD filter.</data>
      <data key="d11">0.75</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_29</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="CABIN ENVIRONMENT">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">CABIN ENVIRONMENT</data>
      <data key="d9">SERVES</data>
      <data key="d10">The CP generator operates in the cabin environment as an air purification device, reducing airborne and deposited biological contamination and contributing to near-zero cabin bioaerosol concentration after 25 minutes.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_30</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="BREATHING ZONE OF SEATED PASSENGERS">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">BREATHING ZONE OF SEATED PASSENGERS</data>
      <data key="d9">SERVES</data>
      <data key="d10">The CP generator serves the breathing zone of seated passengers by lowering bioaerosol concentration and therefore reducing the risk of inhaling respiratory pathogens.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_30</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="AIR MONITORING POINTS">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">AIR MONITORING POINTS</data>
      <data key="d9">SERVES</data>
      <data key="d10">The CP generator reduced airborne bioaerosol levels measured at air monitoring points, with R values of 42.87-47.09% at t = 5 min during continuous bacterial dispersal.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_30</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="SEDIMENT MONITORING POINTS">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">SEDIMENT MONITORING POINTS</data>
      <data key="d9">SERVES</data>
      <data key="d10">The CP generator reduced deposited biological contamination measured at sediment monitoring points, with an average sediment purification ability of 87.52%, higher than that of the IFD filter.</data>
      <data key="d11">0.83</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_30</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="SUBWAY CARRIAGE OCCUPIED AIRSPACE">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">SUBWAY CARRIAGE OCCUPIED AIRSPACE</data>
      <data key="d9">SERVES</data>
      <data key="d10">The CP generator serves the carriage airspace as a plasma-based air purification device. Its contribution is evaluated when activated with the IFD filter in Case 5.</data>
      <data key="d11">0.81</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_31</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="INDOOR ENVIRONMENT">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">INDOOR ENVIRONMENT</data>
      <data key="d9">SERVES</data>
      <data key="d10">The CP generator serves the indoor environment by dispersing purifying materials throughout it using airflow organized by the duct structure.</data>
      <data key="d11">0.88</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_32</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="PATHOGENS">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">PATHOGENS</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The CP generator is connected to pathogen control because multiple units can be deployed to enhance pathogen purification rates.</data>
      <data key="d11">0.76</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_32</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CP GENERATOR" target="AIR-CONDITIONING SYSTEM">
      <data key="d7">CP GENERATOR</data>
      <data key="d8">AIR CONDITIONING SYSTEM</data>
      <data key="d9">SERVES</data>
      <data key="d10">The CP generator is installed in or integrated with the air conditioning system to purify cabin air and reduce bioaerosol concentration.</data>
      <data key="d11">0.79</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_34</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CABIN-TO-EXTERIOR AIR PATHWAY" target="EXTERNAL OPERATING ENVIRONMENT">
      <data key="d7">CABIN-TO-EXTERIOR AIR PATHWAY</data>
      <data key="d8">EXTERNAL OPERATING ENVIRONMENT</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The cabin-to-exterior air pathway links the sealed train cabin with the external operating environment.</data>
      <data key="d11">0.85</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_16</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CONDUIT LINKING THE SEALED CABIN WITH THE EXTERNAL OPERATING ENVIRONMENT" target="SEALED CABIN">
      <data key="d7">CONDUIT LINKING THE SEALED CABIN WITH THE EXTERNAL OPERATING ENVIRONMENT</data>
      <data key="d8">SEALED CABIN</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The conduit forms an airflow connection to the sealed cabin, enabling exchange that contributes to indoor airflow quality and cleanliness.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="CONDUIT LINKING THE SEALED CABIN WITH THE EXTERNAL OPERATING ENVIRONMENT" target="EXTERNAL OPERATING ENVIRONMENT">
      <data key="d7">CONDUIT LINKING THE SEALED CABIN WITH THE EXTERNAL OPERATING ENVIRONMENT</data>
      <data key="d8">EXTERNAL OPERATING ENVIRONMENT</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The conduit links the sealed cabin with the external operating environment, creating the pathway between the indoor zone and the outside surroundings.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="ROOFTOP AIR CONDITIONING UNIT" target="SEALED CABIN">
      <data key="d7">ROOFTOP AIR CONDITIONING UNIT</data>
      <data key="d8">SEALED CABIN</data>
      <data key="d9">SERVES</data>
      <data key="d10">The rooftop air conditioning unit conditions and supplies air that enters the sealed cabin, thereby serving the cabin's indoor airflow quality and air cleanliness needs.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="ROOFTOP AIR CONDITIONING UNIT" target="SARS-COV-2">
      <data key="d7">ROOFTOP AIR CONDITIONING UNIT</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">SERVES</data>
      <data key="d10">The cited HVAC context links ventilation and air-conditioning systems to airborne pathogen control during the SARS-CoV-2 epidemic, although the passage does not describe a direct measurement of this pathogen.</data>
      <data key="d11">0.42</data>
      <data key="d12">3</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="MIXING CHAMBER" target="ROOFTOP AIR CONDITIONING UNIT">
      <data key="d7">MIXING CHAMBER</data>
      <data key="d8">ROOFTOP AIR CONDITIONING UNIT</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The mixing chamber is an internal airflow section of the rooftop air conditioning unit where multiple air streams converge.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="MIXING CHAMBER" target="AIR ENTERING THE CABIN">
      <data key="d7">MIXING CHAMBER</data>
      <data key="d8">AIR ENTERING THE CABIN</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">Air leaving the mixing chamber becomes part of the downstream airflow entering the sealed cabin.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="MIXING CHAMBER" target="IFD FILTER">
      <data key="d7">MIXING CHAMBER</data>
      <data key="d8">IFD FILTER</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The IFD filter treats all air passing through the mixing chamber, including both return air and fresh air.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_32</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="FRESH AIR STREAM" target="MIXING CHAMBER">
      <data key="d7">FRESH AIR STREAM</data>
      <data key="d8">MIXING CHAMBER</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The fresh air stream enters the mixing chamber, where it merges with the recirculated air stream.</data>
      <data key="d11">0.83</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="RECIRCULATED AIR STREAM" target="MIXING CHAMBER">
      <data key="d7">RECIRCULATED AIR STREAM</data>
      <data key="d8">MIXING CHAMBER</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The recirculated air stream enters the mixing chamber and combines with the fresh air stream before air is supplied toward the cabin.</data>
      <data key="d11">0.83</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR ENTERING THE CABIN" target="SEALED CABIN">
      <data key="d7">AIR ENTERING THE CABIN</data>
      <data key="d8">SEALED CABIN</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The supply airflow from the rooftop unit enters the sealed cabin and directly affects its indoor air cleanliness.</data>
      <data key="d11">0.84</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="COLD PLASMA GENERATOR" target="SEALED CABIN">
      <data key="d7">COLD PLASMA GENERATOR</data>
      <data key="d8">SEALED CABIN</data>
      <data key="d9">SERVES</data>
      <data key="d10">The cold plasma generator is described as a second purification device intended to improve air cleanliness for the conditioned cabin environment.</data>
      <data key="d11">0.72</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_17</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="ENTIRE CABIN SPACE" target="POSITIVE AND NEGATIVE ION DISTRIBUTION">
      <data key="d7">ENTIRE CABIN SPACE</data>
      <data key="d8">POSITIVE AND NEGATIVE ION DISTRIBUTION</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">The whole cabin space is intended to receive the positive and negative ions delivered through the ventilation system.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_18</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR CONDITIONING UNIT" target="ENTIRE CABIN SPACE">
      <data key="d7">AIR CONDITIONING UNIT</data>
      <data key="d8">ENTIRE CABIN SPACE</data>
      <data key="d9">SERVES</data>
      <data key="d10">The air conditioning unit serves the occupied cabin by supplying conditioned and treated airflow toward the cabin volume.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_18</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR CONDITIONING UNIT" target="AIR DUCT SYSTEM">
      <data key="d7">AIR CONDITIONING UNIT</data>
      <data key="d8">AIR DUCT SYSTEM</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The air conditioning unit connects to the duct system, allowing treated supply air to move downstream through the ventilation network.</data>
      <data key="d11">0.84</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_18</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR CONDITIONING UNIT" target="SUBWAY COMPARTMENT INTERIOR">
      <data key="d7">AIR CONDITIONING UNIT</data>
      <data key="d8">SUBWAY COMPARTMENT INTERIOR</data>
      <data key="d9">SERVES</data>
      <data key="d10">The air conditioning unit serves the subway compartment by supporting its ventilation and conditioned airflow.</data>
      <data key="d11">0.87</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_23</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR CONDITIONING UNIT" target="AIR DUCTS">
      <data key="d7">AIR CONDITIONING UNIT</data>
      <data key="d8">AIR DUCTS</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The air conditioning unit is connected to the air ducts that distribute air through the compartment.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_23</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR SUPPLY CHAMBER" target="AIR CONDITIONING UNIT">
      <data key="d7">AIR SUPPLY CHAMBER</data>
      <data key="d8">AIR CONDITIONING UNIT</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The air supply chamber is an airflow compartment within the air conditioning unit and is connected to the unit's supply path.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_18</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
    <edge source="AIR SUPPLY CHAMBER" target="POSITIVE AND NEGATIVE ION DISTRIBUTION">
      <data key="d7">AIR SUPPLY CHAMBER</data>
      <data key="d8">POSITIVE AND NEGATIVE ION DISTRIBUTION</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">The air supply chamber is the initial supply-air location where ions from the CP generator are introduced into the airflow.</data>
