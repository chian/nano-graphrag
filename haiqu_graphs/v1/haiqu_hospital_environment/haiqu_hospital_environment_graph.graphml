      <data key="d8">MVV</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">The studied indoor venue zones included an MVV air-distribution condition, evaluated numerically and experimentally for infection-risk distributions under full and halved occupancy.</data>
      <data key="d11">0.88</data>
      <data key="d12">1</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_26</data>
      <data key="d14">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
    </edge>
    <edge source="FULL SEATING OR FULL OCCUPANCY" target="SARS-COV-2 OR COVID-19 AIRBORNE TRANSMISSION CONTEXT">
