      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">The studied indoor venue zones included a DVV air-distribution condition, for which CFD-derived individual infection risks and propagation-risk values were evaluated under full and checkerboard seating.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_26</data>
      <data key="d14">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
    </edge>
