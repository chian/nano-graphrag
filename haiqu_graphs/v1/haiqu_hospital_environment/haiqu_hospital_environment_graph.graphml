      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Airborne aerosol cloud pattern observed during singing without a surgical mask, primarily expelled into the region in front of the singer with a forward-downward direction of motion.</data>
      <data key="d3">0.95</data>
      <data key="d4">ffb605c7-88bd-433a-9478-a7261e327d48_chunk_20</data>
      <data key="d5">ffb605c7-88bd-433a-9478-a7261e327d48</data>
    </node>
