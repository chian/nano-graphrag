      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The aerosol particle trajectories are connected to the fan-induced airflow because the airflow field determines the movement of particles used in the inactivation calculation.</data>
      <data key="d11">0.78</data>
      <data key="d12">1</data>
      <data key="d13">19fa3b4e-2c3d-44b1-ae20-59902abc601a_chunk_29</data>
