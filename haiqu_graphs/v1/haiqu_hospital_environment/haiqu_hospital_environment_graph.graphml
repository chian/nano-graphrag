      <data key="d8">GOOD VENTILATION</data>
      <data key="d9">HAS_ACH</data>
      <data key="d10">Indoor mass-gathering settings may occur under good ventilation conditions, in which case the text indicates that their effect on overall infections can be minimal.</data>
      <data key="d11">0.72</data>
      <data key="d12">2</data>
      <data key="d13">0676edf9-1d10-4220-bdea-1b4729f9856d_chunk_13</data>
      <data key="d14">0676edf9-1d10-4220-bdea-1b4729f9856d</data>
