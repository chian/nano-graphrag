      <data key="d8">AEROSOL AND DROPLET DISPERSION</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">Laminar and turbulent flow regimes are cited as validation contexts for aerosol-dispersion modeling and are therefore connected to the reliability of simulated particle transport.</data>
      <data key="d11">0.64</data>
      <data key="d12">3</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_76</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
