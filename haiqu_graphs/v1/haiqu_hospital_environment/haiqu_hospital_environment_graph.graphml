      <data key="d7">UV-C SYSTEM</data>
      <data key="d8">MEASUREMENT FACILITY</data>
      <data key="d9">SERVES</data>
      <data key="d10">The UV-C system serves the measurement facility as an upper-room germicidal irradiation air-treatment system operated at full power, half power, or off during experimental runs.</data>
      <data key="d11">0.84</data>
      <data key="d12">1</data>
      <data key="d13">19fa3b4e-2c3d-44b1-ae20-59902abc601a_chunk_24</data>
