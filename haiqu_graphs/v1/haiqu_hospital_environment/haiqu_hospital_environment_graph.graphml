      <data key="d8">NASAL RESPIRATORY RELEASE PATH</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The manikin is connected to the aerosol generation system so that aerosol exits through the nasal region, forming the intended respiratory release path.</data>
      <data key="d11">0.84</data>
      <data key="d12">2</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_13</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </edge>
