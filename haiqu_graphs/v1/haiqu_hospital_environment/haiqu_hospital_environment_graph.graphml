    <node id="LOWER LEVEL OF A DOUBLE-DECKER HIGH-SPEED TRAIN">
      <data key="d0">LOWER LEVEL OF A DOUBLE-DECKER HIGH-SPEED TRAIN</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">An experimental train-compartment zone where low-momentum ventilation concepts were evaluated for thermal comfort, spatial homogeneity, heat removal efficiency, and practical integration.</data>
      <data key="d3">0.85</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="UPPER SIDE-WALL SUPPLY AIR">
      <data key="d0">UPPER SIDE-WALL SUPPLY AIR</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Supply-air path in the subway coach where air is initially injected at the top near the walls before descending toward the floor.</data>
      <data key="d3">0.86</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="DOWNWARD AIR MOVEMENT TO FLOOR">
      <data key="d0">DOWNWARD AIR MOVEMENT TO FLOOR</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Internal airflow path in the subway coach in which supplied air moves downward from the upper wall region toward the floor.</data>
      <data key="d3">0.82</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="UPWARD AIR MOVEMENT TO CENTRAL COACH">
      <data key="d0">UPWARD AIR MOVEMENT TO CENTRAL COACH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Internal airflow path in the subway coach where air rises from the lower region toward the central part of the coach after first descending to the floor.</data>
      <data key="d3">0.83</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="END-OF-COACH SUPPLY AIR">
      <data key="d0">END-OF-COACH SUPPLY AIR</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Ventilation supply path in the real-world carriage model where air is injected from the ends of the coach, contributing to longitudinal airflow and droplet transport.</data>
      <data key="d3">0.88</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="CENTRAL CEILING EXTRACTION SLOTS">
      <data key="d0">CENTRAL CEILING EXTRACTION SLOTS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Exhaust-air path in the real-world carriage model where air is extracted through slots located along the ceiling in the center of the coach.</data>
      <data key="d3">0.89</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="UPPER CABIN SUPPLY AIR">
      <data key="d0">UPPER CABIN SUPPLY AIR</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Supply-air path in the experimental train cabin where air is introduced from the upper part of the cabin, including ceiling or luggage-rack locations.</data>
      <data key="d3">0.77</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="FLOOR SUPPLY AIR">
      <data key="d0">FLOOR SUPPLY AIR</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Supply-air path in the experimental train cabin where air is introduced from the floor as part of the tested ventilation concepts.</data>
      <data key="d3">0.74</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LATERAL UPPER AIR EXTRACTION">
      <data key="d0">LATERAL UPPER AIR EXTRACTION</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Exhaust-air path in the experimental train cabin where air is extracted laterally at the top of the compartment.</data>
      <data key="d3">0.76</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="SUBWAY COACH DROPLET DISPERSION">
      <data key="d0">SUBWAY COACH DROPLET DISPERSION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Ventilation-driven dispersion pattern of passenger-emitted droplets in the subway coach, shaped by upper side-wall injection, downward movement to the floor, and upward motion toward the central coach region.</data>
      <data key="d3">0.88</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LONGITUDINAL DROPLET DISPERSION">
      <data key="d0">LONGITUDINAL DROPLET DISPERSION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Droplet transport pattern along the length of the real-world train carriage, modeled in one dimension to assess disease-transmission risk and mitigation strategies.</data>
      <data key="d3">0.91</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MICRO-JET AIR DISTRIBUTION">
      <data key="d0">MICRO-JET AIR DISTRIBUTION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Ventilation mode in which air is injected as localized micro-jets, experimentally assessed in the double-decker train compartment for comfort, spatial homogeneity, and heat removal performance.</data>
      <data key="d3">0.78</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="UNIFORM LOW-VELOCITY AIR DISTRIBUTION">
      <data key="d0">UNIFORM LOW-VELOCITY AIR DISTRIBUTION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Low-momentum ventilation mode in which air is supplied uniformly at low velocity, experimentally assessed as an alternative to micro-jet delivery in the train compartment.</data>
      <data key="d3">0.79</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="PASSENGER-EMITTED DROPLETS">
      <data key="d0">PASSENGER-EMITTED DROPLETS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Respiratory droplets emitted by passengers that may carry infectious material and whose movement is governed by carriage airflow, ventilation configuration, and occupant positioning.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="JUDICIOUS SEAT OCCUPANCY">
      <data key="d0">JUDICIOUS SEAT OCCUPANCY</data>
      <data key="d1">OCCUPANCY_LOAD</data>
      <data key="d2">Managed seating arrangement proposed as a mitigation strategy to reduce transmission risk by controlling passenger locations relative to airflow and droplet dispersion paths.</data>
      <data key="d3">0.81</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="PHYSICAL DISTANCING">
      <data key="d0">PHYSICAL DISTANCING</data>
      <data key="d1">OCCUPANCY_LOAD</data>
      <data key="d2">Occupancy-spacing strategy discussed as a way to limit passenger exposure by increasing separation between droplet sources and susceptible occupants.</data>
      <data key="d3">0.78</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_86</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="UPPER SUPPLY VENTS">
      <data key="d0">UPPER SUPPLY VENTS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Fresh-air supply openings located in the upper part of the cabin, including ceiling or luggage-rack regions. Greater supply through these vents produces a flow field mainly driven by mechanical forces.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_87</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LOWER SUPPLY VENTS">
      <data key="d0">LOWER SUPPLY VENTS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Fresh-air supply openings located near the lower part of the cabin or floor. Increasing the lower air-supply flow rate is recommended during an epidemic because it supports buoyancy-driven upward airflow and reduces longitudinal particle diffusion.</data>
      <data key="d3">0.93</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_87</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LATERAL TOP EXHAUST">
      <data key="d0">LATERAL TOP EXHAUST</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Air-extraction path located laterally at the top of the cabin, removing cabin air and completing the supply-to-exhaust airflow route.</data>
      <data key="d3">0.84</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_87</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MICRO-JET SUPPLY">
      <data key="d0">MICRO-JET SUPPLY</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A ventilation concept in which air is injected as small micro-jets. It is one of the studied air-distribution strategies with both advantages and disadvantages for cabin ventilation performance.</data>
      <data key="d3">0.74</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_87</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="UNIFORM LOW-VELOCITY SUPPLY">
      <data key="d0">UNIFORM LOW-VELOCITY SUPPLY</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A ventilation concept in which air is supplied uniformly and at low velocity from the upper cabin region or from the floor, producing different mixing and dispersion behavior from micro-jet injection.</data>
      <data key="d3">0.74</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_87</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="HYBRID VENTILATION APPROACH">
      <data key="d0">HYBRID VENTILATION APPROACH</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A combined ventilation strategy integrating multiple ventilation concepts, particularly displacement ventilation and mixed ventilation. It is described as a good compromise among the studied performance criteria.</data>
      <data key="d3">0.92</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_87</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MECHANICALLY DRIVEN FLOW FIELD">
      <data key="d0">MECHANICALLY DRIVEN FLOW FIELD</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A cabin airflow regime dominated by mechanical supply momentum. The text states this occurs when more fresh air enters the carriage through the upper vents.</data>
      <data key="d3">0.8</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_87</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="BUOYANCY-DRIVEN FLOW FIELD">
      <data key="d0">BUOYANCY-DRIVEN FLOW FIELD</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A cabin airflow regime dominated by buoyancy forces. The text states this occurs when more fresh air enters through the lower vents and is associated with upward airflow.</data>
      <data key="d3">0.83</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_87</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="UPWARD AIRFLOW PROPAGATION">
      <data key="d0">UPWARD AIRFLOW PROPAGATION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">An airflow behavior in which air mainly propagates upward, especially when lower-vent supply causes buoyancy-driven flow.</data>
      <data key="d3">0.82</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_87</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="REDUCED LONGITUDINAL PARTICLE DIFFUSION">
      <data key="d0">REDUCED LONGITUDINAL PARTICLE DIFFUSION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A particle-transport pattern characterized by lower spreading of particles along the length of the carriage, associated with lower-vent supply and upward buoyancy-driven airflow.</data>
      <data key="d3">0.84</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_87</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="TRAIN COACH/CARRIAGE">
      <data key="d0">TRAIN COACH/CARRIAGE</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">The occupied rail vehicle interior in which ventilation, particle dispersion, passenger comfort, heat removal, and infection-transmission mitigation are evaluated. Although not a hospital space, it is the primary enclosed air-handled zone in this extraction schema.</data>
      <data key="d3">0.94</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="RAIL COACH NUMERICAL MODEL">
      <data key="d0">RAIL COACH NUMERICAL MODEL</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">The modeled train-coach environment used in numerical studies to assess how inlet placement, outlet placement, extraction flow, and ventilation strategy influence SARS-CoV-2 particle transport.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="UPPER PART OF THE COACH">
      <data key="d0">UPPER PART OF THE COACH</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">The upper vertical region of the coach, identified as the preferred location for high extraction flow in one reviewed numerical study.</data>
      <data key="d3">0.77</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LOWER PART OF THE CARRIAGE">
      <data key="d0">LOWER PART OF THE CARRIAGE</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">The lower vertical region of the carriage, used as the extraction region in the usual Korean express train ventilation configuration.</data>
      <data key="d3">0.76</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="USUAL KOREAN EXPRESS TRAIN VENTILATION SYSTEM">
      <data key="d0">USUAL KOREAN EXPRESS TRAIN VENTILATION SYSTEM</data>
      <data key="d1">HVAC_UNIT</data>
      <data key="d2">A ventilation configuration typical of Korean express trains, with air injected along the windows and extracted from the lower part of the carriage.</data>
      <data key="d3">0.86</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="ALTERNATIVE BOTTOM-TO-TOP VENTILATION SYSTEM">
      <data key="d0">ALTERNATIVE BOTTOM-TO-TOP VENTILATION SYSTEM</data>
      <data key="d1">HVAC_UNIT</data>
      <data key="d2">An alternative ventilation configuration in which air circulates from the bottom of the carriage toward the top. It is described as more effective for evacuating particles emitted by passengers.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="AIR INLETS ABOVE THE WINDOWS">
      <data key="d0">AIR INLETS ABOVE THE WINDOWS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Supply-air openings positioned above the windows in the rail coach numerical model. They introduce air into the coach and shape the subsequent airflow field.</data>
      <data key="d3">0.79</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="WINDOW-SIDE SUPPLY AIR PATH">
      <data key="d0">WINDOW-SIDE SUPPLY AIR PATH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">The supply-air path used in the usual Korean express train configuration, where air is injected along the windows before being extracted lower in the carriage.</data>
      <data key="d3">0.78</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="VARIABLE EXHAUST VENTS">
      <data key="d0">VARIABLE EXHAUST VENTS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Exhaust outlets of variable sizes and positions in the rail coach model. Their locations include ceiling, central/longitudinal coach positions, and floor locations.</data>
      <data key="d3">0.84</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="CEILING EXHAUST VENTS">
      <data key="d0">CEILING EXHAUST VENTS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Exhaust vents positioned on the ceiling of the coach. They support upper-level extraction strategies.</data>
      <data key="d3">0.72</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="CENTRAL LONGITUDINAL EXHAUST VENTS">
      <data key="d0">CENTRAL LONGITUDINAL EXHAUST VENTS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Exhaust vents located in the centre and along the coach, representing one of the variable outlet-position options studied numerically.</data>
      <data key="d3">0.68</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="FLOOR EXHAUST VENTS">
      <data key="d0">FLOOR EXHAUST VENTS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Exhaust vents positioned on the floor of the coach, representing a lower-level outlet configuration considered in the reviewed ventilation studies.</data>
      <data key="d3">0.71</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LOWER CARRIAGE EXTRACTION PATH">
      <data key="d0">LOWER CARRIAGE EXTRACTION PATH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">The exhaust or return-air path in the usual Korean express train ventilation system, where air is extracted from the lower part of the carriage.</data>
      <data key="d3">0.78</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="WINDOW-SIDE SUPPLY WITH LOWER EXTRACTION PATTERN">
      <data key="d0">WINDOW-SIDE SUPPLY WITH LOWER EXTRACTION PATTERN</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">The airflow pattern of the usual Korean express train system: air is supplied along the windows and extracted from the lower part of the carriage.</data>
      <data key="d3">0.81</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="HIGH UPPER-COACH EXTRACTION FLOW PATTERN">
      <data key="d0">HIGH UPPER-COACH EXTRACTION FLOW PATTERN</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A preferred airflow strategy identified in the reviewed numerical study, characterized by a high extraction flow rate in the upper part of the coach.</data>
      <data key="d3">0.86</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="BOTTOM-UP AIR VENTILATION MODE">
      <data key="d0">BOTTOM-UP AIR VENTILATION MODE</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">An airflow pattern in which air moves from the lower region toward the upper region of the coach. The authors adopt this mode in their 3D numerical study and note that literature suggests it can improve evacuation of passenger-emitted particles.</data>
      <data key="d3">0.96</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88,6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_89</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="FLOOR-BASED VENTILATION STRATEGY">
      <data key="d0">FLOOR-BASED VENTILATION STRATEGY</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A general railway ventilation strategy in which air is supplied or organized from the floor region.</data>
      <data key="d3">0.62</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="CEILING-BASED VENTILATION STRATEGY">
      <data key="d0">CEILING-BASED VENTILATION STRATEGY</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A general railway ventilation strategy in which air is supplied or organized from the ceiling region.</data>
      <data key="d3">0.62</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MIXED FLOOR-AND-CEILING VENTILATION STRATEGY">
      <data key="d0">MIXED FLOOR-AND-CEILING VENTILATION STRATEGY</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A railway ventilation strategy combining floor-based and ceiling-based airflow. Its mention reflects the absence of a single ideal or consensus system.</data>
      <data key="d3">0.61</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="PASSENGER-EMITTED SARS-COV-2-LADEN PARTICLES">
      <data key="d0">PASSENGER-EMITTED SARS-COV-2-LADEN PARTICLES</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Airborne infectious particles emitted by passengers and transported within the coach airflow. The text focuses on evacuating these particles through suitable ventilation strategies.</data>
      <data key="d3">0.88</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_88</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="END-TO-MIDDLE AIRFLOW PATTERN">
      <data key="d0">END-TO-MIDDLE AIRFLOW PATTERN</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">The intended large-scale airflow pattern in which air moves from the two ends of the rail coach toward the middle compartment. It is produced by adjusting extraction rates in compartments #1 and #3 while extracting compartment #2 at atmospheric pressure.</data>
      <data key="d3">0.92</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_89,6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_90</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="SUPPLY VENTS">
      <data key="d0">SUPPLY VENTS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Fresh-air inlet paths whose location, shape, dimensions, velocities, and flow rates define the air supply conditions. In the simulation, they introduce outdoor air at each end of the coach. | Air delivery openings that introduce conditioned air into the subway compartment. Their position relative to the return air vents contributes to the observed peak velocity in the central cabin region.</data>
      <data key="d3">0.82</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_89</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42,92822355-ab82-4e40-9fca-0876f2fc943e</data>
      <data key="d6">SUPPLY AIR VENTS</data>
    </node>
    <node id="ROOF SLITS">
      <data key="d0">ROOF SLITS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Specific extraction openings located in the roof of each compartment. They remove air from compartments #1, #2, and #3 under either imposed outlet conditions or atmospheric-pressure extraction.</data>
      <data key="d3">0.86</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_89</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="IMPOSED SUPPLY VELOCITIES AND FLOW RATES">
      <data key="d0">IMPOSED SUPPLY VELOCITIES AND FLOW RATES</data>
      <data key="d1">ACH_RATE</data>
      <data key="d2">The prescribed inlet airflow conditions for fresh outdoor air supplied to each end of the rail coach. | The prescribed outlet airflow conditions used for extraction in occupied compartments #1 and #3.</data>
      <data key="d3">0.78</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_89</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
      <data key="d6">IMPOSED EXIT VELOCITIES AND FLOW RATES</data>
    </node>
    <node id="ADJUSTED AIR EXTRACTION RATES">
      <data key="d0">ADJUSTED AIR EXTRACTION RATES</data>
      <data key="d1">ACH_RATE</data>
      <data key="d2">The extraction rates in compartments #1 and #3 that were adjusted to produce airflow from the ends of the coach toward the middle.</data>
      <data key="d3">0.84</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_89</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="ATMOSPHERIC PRESSURE EXTRACTION">
      <data key="d0">ATMOSPHERIC PRESSURE EXTRACTION</data>
      <data key="d1">PRESSURE_RELATIONSHIP</data>
      <data key="d2">The pressure boundary condition used for air extraction in compartment #2. It contributes to the balance of overall airflows between compartments.</data>
      <data key="d3">0.79</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_89</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="AIRBORNE PARTICLES">
      <data key="d0">AIRBORNE PARTICLES</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Particles whose dispersion and evacuation are influenced by ventilation strategy, supply and extraction conditions, and compartment airflow patterns. The referenced prior studies concern particles carrying SARS-CoV-2.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_89</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="RAIL COACH DIGITAL TWIN">
      <data key="d0">RAIL COACH DIGITAL TWIN</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">The modeled rail coach environment used for 3D numerical ventilation simulations. It is divided into compartments and assigned inlet and outlet airflow boundary conditions. | Modeled indoor enclosure representing the railway coach used for simulating airborne particle dispersion. Although not a hospital space, it functions as the bounded modeled zone for airflow and pathogen transport.</data>
      <data key="d3">0.94</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_90</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
      <data key="d6">RAILWAY COACH DIGITAL TWIN</data>
    </node>
    <node id="INCOMING AIRFLOWS">
      <data key="d0">INCOMING AIRFLOWS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Supply airflow paths entering the coach compartments. These supplied flow rates are used to compute the air renewal rate and residence time for each compartment.</data>
      <data key="d3">0.82</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_90</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="OUTGOING AIRFLOWS">
      <data key="d0">OUTGOING AIRFLOWS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Extracted airflow paths leaving the coach compartments. Their distribution is adjusted to balance airflows and to route a large fraction of extracted air through the middle compartment.</data>
      <data key="d3">0.83</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_90</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="50% EXTRACTION THROUGH COMPARTMENT #2">
      <data key="d0">50% EXTRACTION THROUGH COMPARTMENT #2</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">The extraction configuration in which half of the air is removed through the middle compartment, making compartment #2 the dominant exhaust pathway.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_90</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LOW-VELOCITY SUPPLY AND EXTRACTION CONDITION">
      <data key="d0">LOW-VELOCITY SUPPLY AND EXTRACTION CONDITION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A comfort-driven airflow condition requiring the velocities of supplied and extracted air to remain below 0.2 m s−1, as prescribed by railway operators.</data>
      <data key="d3">0.76</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_90</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="ATMOSPHERIC PRESSURE AIRFLOW BALANCE">
      <data key="d0">ATMOSPHERIC PRESSURE AIRFLOW BALANCE</data>
      <data key="d1">PRESSURE_RELATIONSHIP</data>
      <data key="d2">The pressure-related condition in which the modeled compartments are maintained at atmospheric pressure, resulting in a balance of overall airflows between compartments.</data>
      <data key="d3">0.78</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_90</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="UNMASKED MOUTH BREATHING AIR PATH">
      <data key="d0">UNMASKED MOUTH BREATHING AIR PATH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Air inhaled and exhaled by the manikin in the no-mask base case, passing directly through the mouth boundary of the 3D simulation domain.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_91</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="FITTED-MASK FILTRATION AIR PATH">
      <data key="d0">FITTED-MASK FILTRATION AIR PATH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Air emitted by the manikin when wearing a perfectly fitted mask, with no face-mask leaks; air and particles not retained by the mask pass through the porous filtering surface.</data>
      <data key="d3">0.95</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_91</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LOOSE-MASK LEAKAGE AIR PATH">
      <data key="d0">LOOSE-MASK LEAKAGE AIR PATH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Air emitted by the manikin when wearing a loosely fitted mask, allowing leakage between the face and the mask in addition to flow through the filtering material.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_91</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="DIRECT ORAL BREATHING DISTRIBUTION">
      <data key="d0">DIRECT ORAL BREATHING DISTRIBUTION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Distribution pattern for the unmasked case, where inhaled and exhaled air moves directly through the mouth opening rather than being slowed or diffused by a mask.</data>
      <data key="d3">0.8</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_91</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="POROUS MASK DIFFUSION DISTRIBUTION">
      <data key="d0">POROUS MASK DIFFUSION DISTRIBUTION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Distribution pattern created by the porous filtering part of a mask, where emitted air is slowed and diffused over a much larger surface than the mouth opening.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_91</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="FACE-MASK LEAK DISTRIBUTION">
      <data key="d0">FACE-MASK LEAK DISTRIBUTION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Distribution pattern associated with a loose mask, where some air bypasses the filtering surface through leaks between the manikin face and the mask.</data>
      <data key="d3">0.85</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_91</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="RESPIRATORY PARTICLES">
      <data key="d0">RESPIRATORY PARTICLES</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Particles carried in the manikin's emitted respiratory airflow; the text notes that particles not retained by the mask may pass through the filter or potentially through leaks.</data>
      <data key="d3">0.75</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_91</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="INFECTED HUMANOID MANIKIN">
      <data key="d0">INFECTED HUMANOID MANIKIN</data>
      <data key="d1">OCCUPANCY_LOAD</data>
      <data key="d2">A single presumed-infected occupant source used in the breathing dissemination simulation. The manikin exhales pathogen-laden droplets at each breathing cycle.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_92</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="NORMAL BREATHING">
      <data key="d0">NORMAL BREATHING</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Repeated exhalation-driven airflow pattern used to model dissemination of droplets from the infected manikin. The resulting outlet paths and velocities vary across no-mask, well-fitted-mask, and loose-mask configurations.</data>
      <data key="d3">0.82</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_92</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MOUTH BOUNDARY">
      <data key="d0">MOUTH BOUNDARY</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Boundary of the 3D simulation domain associated with the manikin's mouth, where breathing-related boundary conditions are imposed and exhaled air carrying droplets enters the modeled domain.</data>
      <data key="d3">0.78</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_92</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="FILTERING PART OF THE MASK">
      <data key="d0">FILTERING PART OF THE MASK</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Porous mask outlet path through which exhaled air and particles pass when they are not retained by the mask. It is the main outlet in the perfectly fitted mask case and one of the outlets in the loose-mask case.</data>
      <data key="d3">0.75</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_92</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LEAKAGE SURFACES ON MASK EDGES">
      <data key="d0">LEAKAGE SURFACES ON MASK EDGES</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Additional outlet paths present when the mask is worn loosely. These leakage surfaces allow exhaled air and particles to bypass the filtering material at the mask edges.</data>
      <data key="d3">0.74</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_92</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="NOSE LEAK ZONE">
      <data key="d0">NOSE LEAK ZONE</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Specific leakage air path near the nose in the loose-mask configuration, included as one of the mask-edge leak zones where boundary conditions are applied.</data>
      <data key="d3">0.6</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_92</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="CHEEK LEAK ZONES">
      <data key="d0">CHEEK LEAK ZONES</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Specific leakage air paths near the cheeks in the loose-mask configuration, included among the mask-edge leak zones where air and particles can escape.</data>
      <data key="d3">0.6</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_92</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="CHIN LEAK ZONE">
      <data key="d0">CHIN LEAK ZONE</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Specific leakage air path near the chin in the loose-mask configuration, included as one of the mask-edge leak zones where air and particles can escape.</data>
      <data key="d3">0.6</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_92</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="NO-MASK EXHALATION FLOW">
      <data key="d0">NO-MASK EXHALATION FLOW</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Airflow pattern for the configuration without a mask. The air carrying droplets leaves the manikin with velocity slightly higher than the surrounding air velocity around the manikin. | Airflow pattern for the loosely worn mask configuration. Exhaled air and particles exit both through the filtering part of the mask and through leakage surfaces near the nose, cheeks, and chin.</data>
      <data key="d3">0.72</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_92</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
      <data key="d6">LOOSE-MASK EXHALATION FLOW</data>
    </node>
    <node id="WELL-FITTED MASK EXHALATION FLOW">
      <data key="d0">WELL-FITTED MASK EXHALATION FLOW</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Airflow pattern for the perfectly fitted mask configuration. Air and particles not retained by the mask pass through the filtering part, and the mask reduces the velocity of air carrying droplets.</data>
      <data key="d3">0.68</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_92</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="SARS-COV-2-CARRYING 1 MICROMETER DROPLETS">
      <data key="d0">SARS-COV-2-CARRYING 1 MICROMETER DROPLETS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Modeled airborne infectious particles released by infected passengers during exhalation. The simulation uses 1 µm droplets because droplets below 10 µm are stated to exhibit similar overall airborne behavior.</data>
      <data key="d3">0.95</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_93</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MASKED SPREADER MANIKIN">
      <data key="d0">MASKED SPREADER MANIKIN</data>
      <data key="d1">OCCUPANCY_LOAD</data>
      <data key="d2">Modeled infected source occupant wearing a mask and seated in compartment #1 of the railway coach digital twin. The manikin defines the source location and masked exhalation conditions for the dispersion simulation.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_93</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="COMPARTMENT #1 OF THE RAILWAY COACH">
      <data key="d0">COMPARTMENT #1 OF THE RAILWAY COACH</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Specific modeled compartment within the railway coach where the masked spreader manikin is seated. This location is arbitrary but defines the initial source zone for particle release and dispersion observations.</data>
      <data key="d3">0.78</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_93</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MASK-FILTERED EXHALATION AIR PATH">
      <data key="d0">MASK-FILTERED EXHALATION AIR PATH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Airflow route carrying exhaled droplets through the mask worn by the manikin. The text states that wearing a mask reduces the velocity of the droplet-carrying air passing through it and that larger drops above 10 µm are properly filtered by surgical masks.</data>
      <data key="d3">0.8</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_93</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="FACE LEAKAGE AIR PATHS">
      <data key="d0">FACE LEAKAGE AIR PATHS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Leakage routes around the masked manikin’s face through which exhaled air and droplets may escape into the surrounding coach air. The text notes that air velocity through these leaks is low.</data>
      <data key="d3">0.74</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_93</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LOW-VELOCITY AIRFLOW AROUND MASKED MANIKIN">
      <data key="d0">LOW-VELOCITY AIRFLOW AROUND MASKED MANIKIN</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Local airflow condition around the masked manikin characterized by reduced air velocity through the mask and low-velocity leakage around the face. This airflow pattern affects how pathogen-carrying droplets enter the coach air.</data>
      <data key="d3">0.76</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_93</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="DROPLET DISPERSION IN THE RAILWAY COACH">
      <data key="d0">DROPLET DISPERSION IN THE RAILWAY COACH</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Simulated spread pattern of SARS-CoV-2-carrying droplets within the railway coach. The dispersion is shaped by the source location in compartment #1, exhalation from infected occupants, mask filtration, reduced exit velocity, and leakage airflow around the face.</data>
      <data key="d3">0.88</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_93</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="HUMANOID MANIKIN BREATHING LOAD">
      <data key="d0">HUMANOID MANIKIN BREATHING LOAD</data>
      <data key="d1">OCCUPANCY_LOAD</data>
      <data key="d2">Simulated humanoid manikin respiratory source with a breathing cycle of approximately 5 seconds, corresponding to 12 breaths per minute, used to model airflow and associated particle production.</data>
      <data key="d3">0.86</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_95</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MOUTH RESPIRATORY AIR PATH">
      <data key="d0">MOUTH RESPIRATORY AIR PATH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Case #1 airflow route where inhalation and exhalation occur directly through the manikin mouth. Expiration and inspiration velocities are calculated from the mouth surface, with exhaled air directed orthogonally from the mouth at 15 degrees below the horizontal.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_95</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="PERFECTLY FITTED MASK RESPIRATORY AIR PATH">
      <data key="d0">PERFECTLY FITTED MASK RESPIRATORY AIR PATH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Case #2 airflow route where respiratory flow passes through the mask inlet surface with a perfect facial fit and no leak pathway. Air velocities are adapted according to mask inlet area while conserving the same total respiratory flow rate.</data>
      <data key="d3">0.88</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_95</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LEAKY MASK RESPIRATORY AIR PATH">
      <data key="d0">LEAKY MASK RESPIRATORY AIR PATH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Case #3 airflow route where respiratory flow is distributed through both the mask surface and leak openings. Velocities through the mask and leaks are adjusted according to their inlet areas using mass conservation.</data>
      <data key="d3">0.92</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_95</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="BREATHING CYCLE DISTRIBUTION PATTERN">
      <data key="d0">BREATHING CYCLE DISTRIBUTION PATTERN</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Temporal airflow pattern consisting of two successive phases, exhalation and inhalation, lasting about 5 seconds per cycle and governing the modeled direction and magnitude of respiratory airflow.</data>
      <data key="d3">0.87</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_95</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MOUTH INLET SURFACE">
      <data key="d0">MOUTH INLET SURFACE</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">The manikin mouth treated as the sole airflow inlet surface in case #1. It provides the baseline mouth-only flow path for comparison with mask-only and mask-plus-leak configurations.</data>
      <data key="d3">0.58</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_96</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MASK INLET SURFACES">
      <data key="d0">MASK INLET SURFACES</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Modeled inlet surfaces on the mask through which air is distributed in mask-related cases. These surfaces receive the total flow in case #2 or share the conserved total flow with leak openings in case #3.</data>
      <data key="d3">0.68</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_96</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LEAKS AROUND THE EDGE OF THE MASK">
      <data key="d0">LEAKS AROUND THE EDGE OF THE MASK</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Unintended perimeter openings around the mask edge that act as airflow paths when the mask is not optimally adjusted. Literature-based leak distribution is used to allocate part of the total flow through these leak paths.</data>
      <data key="d3">0.72</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_96</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MASS-CONSERVED FLOW DISTRIBUTION THROUGH INLET SURFACES">
      <data key="d0">MASS-CONSERVED FLOW DISTRIBUTION THROUGH INLET SURFACES</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">The modeled allocation of the same total flow rate among available inlet surfaces, applying mass conservation across mouth, mask, and leak paths depending on the simulation case.</data>
      <data key="d3">0.76</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_96</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="ORTHOGONAL AIR JETS THROUGH MASK AND LEAKS">
      <data key="d0">ORTHOGONAL AIR JETS THROUGH MASK AND LEAKS</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">The resulting jet pattern in which air passes through the mask surfaces and any leak openings, with jets oriented orthogonally to the local facets of the mask and leak surface mesh.</data>
      <data key="d3">0.7</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_96</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MASK-ONLY FLOW CASE">
      <data key="d0">MASK-ONLY FLOW CASE</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Simulation case #2, where airflow is distributed through the mask inlet surfaces without leak contribution. The velocity evolution through the mask is evaluated for this configuration.</data>
      <data key="d3">0.55</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_96</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="MASK-AND-LEAK FLOW CASE">
      <data key="d0">MASK-AND-LEAK FLOW CASE</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Simulation case #3, where airflow is distributed between mask inlet surfaces and perimeter leaks while maintaining the same total flow rate. The velocity evolution through both mask and leaks is evaluated for this configuration.</data>
      <data key="d3">0.62</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_96</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="CASE #1 MOUTH AIRFLOW PATH">
      <data key="d0">CASE #1 MOUTH AIRFLOW PATH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Airflow route through the manikin mouth in the no-mask case, with air velocity evolving over exhalation and inhalation phases.</data>
      <data key="d3">0.86</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_97</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="CASE #2 MASK AIRFLOW PATH">
      <data key="d0">CASE #2 MASK AIRFLOW PATH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Airflow route through the perfectly fitted mask worn by the manikin, including modeled droplet filtration during exhalation.</data>
      <data key="d3">0.88</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_97</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="CASE #3 MASK-AND-LEAK AIRFLOW PATH">
      <data key="d0">CASE #3 MASK-AND-LEAK AIRFLOW PATH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Airflow route through both the mask material and leakage paths around the manikin face in the imperfect-fit mask case.</data>
      <data key="d3">0.9</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_97</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="CASES #1-#3 INLET-SURFACE FLOW DISTRIBUTION">
      <data key="d0">CASES #1-#3 INLET-SURFACE FLOW DISTRIBUTION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Distribution of airflow over the relevant inlet surfaces for the three simulated cases: mouth only, mask only, and mask plus face leaks.</data>
      <data key="d3">0.82</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_97</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="EXHALED AND RE-INHALED DROPLET PARTICLES">
      <data key="d0">EXHALED AND RE-INHALED DROPLET PARTICLES</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Modeled airborne droplet particles injected during exhalation; in the no-mask case 1000 particles were injected, and some may be re-inhaled depending on local velocity conditions and proximity to the mouth.</data>
      <data key="d3">0.84</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_97</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="RAIL COACH SIMULATION DOMAIN">
      <data key="d0">RAIL COACH SIMULATION DOMAIN</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Modeled enclosed rail-coach environment containing the humanoid manikins and bounded by coach surfaces. Although not a hospital space, it is the primary occupied indoor zone in the simulation; its boundaries and surfaces are held at a stable temperature of 20 °C.</data>
      <data key="d3">0.82</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_99</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="AIR INJECTED AT THE ENDS OF THE RAIL COACH">
      <data key="d0">AIR INJECTED AT THE ENDS OF THE RAIL COACH</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Supply airflow path introduced by the ventilation system at both ends of the rail coach. This incoming air is modeled at a constant temperature of 20 °C and contributes to the coach airflow field affecting droplet transport.</data>
      <data key="d3">0.74</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_99</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="AIR EXHALED BY THE HUMANOID MANIKINS">
      <data key="d0">AIR EXHALED BY THE HUMANOID MANIKINS</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Respiratory airflow emitted by the manikins through the mouth or through the mask. It is modeled at 34 °C and acts as the carrier airflow for exhaled droplets during the respiratory cycle.</data>
      <data key="d3">0.76</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_99</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="EXHALED DROPLETS">
      <data key="d0">EXHALED DROPLETS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Respiratory droplets released by the manikins through the mask and mask leaks during a respiratory cycle. They are the airborne contaminant of interest whose distribution is analyzed in case #3.</data>
      <data key="d3">0.73</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_99,6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_110</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="DROPLET DISTRIBUTION THROUGH MASK AND LEAKS">
      <data key="d0">DROPLET DISTRIBUTION THROUGH MASK AND LEAKS</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Modeled distribution pattern of droplets exhaled through the mask and leakage paths during the respiratory cycle in case #3.</data>
      <data key="d3">0.66</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_99</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="STANDING AND LYING HUMAN MANIKINS">
      <data key="d0">STANDING AND LYING HUMAN MANIKINS</data>
      <data key="d1">OCCUPANCY_LOAD</data>
      <data key="d2">Simulated human occupants in standing and lying postures within the operating-room model. Their assumed surface temperatures and clothing coverage influence whether body-generated thermal plumes and buoyancy effects are under- or over-represented in particle-dispersion simulations.</data>
      <data key="d3">0.75</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_100</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="THERMAL PLUME">
      <data key="d0">THERMAL PLUME</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">A convective airflow pattern that can form around human or manikin bodies when their surface temperature is above ambient air temperature. The text notes that warmer manikin body temperatures reported in other studies would strengthen plume-related buoyancy and affect aerosol or particle motion.</data>
      <data key="d3">0.84</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_100</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="BUOYANCY EFFECTS">
      <data key="d0">BUOYANCY EFFECTS</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Temperature-driven airflow behavior caused by density differences between warmer air near bodies or surfaces and cooler surrounding air. In the text, assuming manikin bodies are not in thermal equilibrium with the environment would reinforce these effects, making them important for simulated particle transport.</data>
      <data key="d3">0.8</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_100</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="LEAKAGE SURFACES">
      <data key="d0">LEAKAGE SURFACES</data>
      <data key="d1">AIR_PATH</data>
      <data key="d2">Model surfaces through which particles were introduced in the simulations. They represent leakage-related pathways that can influence how particles enter or redistribute within the operating-room airflow model.</data>
      <data key="d3">0.6</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_100,6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_101</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="PARTICLE INJECTION THROUGH LEAKAGE SURFACES">
      <data key="d0">PARTICLE INJECTION THROUGH LEAKAGE SURFACES</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Airborne particle movement condition in which particles are introduced through leakage surfaces at the surrounding air temperature of 34 °C.</data>
      <data key="d3">0.62</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_101</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="DISPERSION OF PARTICLES CARRYING THE SARS-COV-2 VIRUS">
      <data key="d0">DISPERSION OF PARTICLES CARRYING THE SARS-COV-2 VIRUS</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Simulated airborne transport pattern describing the spread of SARS-CoV-2-carrying particles in a railway transport coach, as referenced by the cited modelling study.</data>
      <data key="d3">0.78</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_101</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="DISPERSION OF DROPLETS AND DROPS CARRYING THE SARS-COV-2 VIRUS">
      <data key="d0">DISPERSION OF DROPLETS AND DROPS CARRYING THE SARS-COV-2 VIRUS</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Simulated airborne transport pattern describing the spread of droplets and drops containing SARS-CoV-2 in a railway transport coach, as referenced by the cited modelling study.</data>
      <data key="d3">0.74</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_101</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="SPEECH-GENERATED DROPLET DISPERSION">
      <data key="d0">SPEECH-GENERATED DROPLET DISPERSION</data>
      <data key="d1">AIR_DISTRIBUTION_PATTERN</data>
      <data key="d2">Speech-generated droplet dispersion is referenced through studies visualizing oral fluid droplets and evaluating the airborne lifetime of small speech droplets, representing a particle distribution pattern relevant to airborne transmission.</data>
      <data key="d3">0.75</data>
      <data key="d4">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_103</data>
      <data key="d5">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </node>
    <node id="COVID-19 / CORONAVIRUS">
      <data key="d0">COVID-19 / CORONAVIRUS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
