      <data key="d7">JET OF EXHALED AIR</data>
      <data key="d8">BUOYANT PLUME</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">Warm exhaled air is redirected upward and contributes to the buoyant plume above the manikin.</data>
      <data key="d11">0.86</data>
      <data key="d12">2</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_47</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
    <edge source="JET OF EXHALED AIR" target="BUOYANT THERMAL PLUMES ABOVE PASSENGERS">
