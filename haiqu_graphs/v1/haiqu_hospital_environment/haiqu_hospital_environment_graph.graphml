      <data key="d8">ROOM AIR FLOW PATTERN</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The aerosol particle trajectories are determined from and follow the modeled room air flow pattern.</data>
      <data key="d11">0.78</data>
      <data key="d12">2</data>
      <data key="d13">19fa3b4e-2c3d-44b1-ae20-59902abc601a_chunk_15</data>
      <data key="d14">19fa3b4e-2c3d-44b1-ae20-59902abc601a</data>
