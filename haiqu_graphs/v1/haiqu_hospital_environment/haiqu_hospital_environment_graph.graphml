      <data key="d8">CO2</data>
      <data key="d9">PATTERN_MEASURED_BY</data>
      <data key="d10">The large-scale monitoring study analyzed ventilation effectiveness in differently ventilated theatres using CO2 sensors, making CO2 the tracer used to evaluate the ventilation concepts during occupied events.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_6</data>
