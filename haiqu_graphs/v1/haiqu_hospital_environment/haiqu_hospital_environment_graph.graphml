      <data key="d7">CEILING AIR EXTRACTION VENTS</data>
      <data key="d8">RAIL COACH COMPARTMENT</data>
      <data key="d9">SERVES</data>
      <data key="d10">The ceiling extraction vents serve the coach compartment by removing air and entrained droplets from the upper region.</data>
      <data key="d11">0.88</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_60</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
