      <data key="d9">ACH_AFFECTS</data>
      <data key="d10">The supplied incoming airflow rate is the basis for computing the reported renewal rate of 8.7 in each compartment.</data>
      <data key="d11">0.82</data>
      <data key="d12">2</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_90</data>
