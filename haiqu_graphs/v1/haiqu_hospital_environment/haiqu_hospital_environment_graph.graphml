      <data key="d11">0.72</data>
      <data key="d12">2</data>
      <data key="d13">c3ec75c5-6024-45ba-a0b0-8dd0c746991b_chunk_33</data>
      <data key="d14">c3ec75c5-6024-45ba-a0b0-8dd0c746991b</data>
    </edge>
