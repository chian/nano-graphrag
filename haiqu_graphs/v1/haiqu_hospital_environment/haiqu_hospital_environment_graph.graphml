      <data key="d7">MANIKIN OCCUPANCY SOURCE</data>
      <data key="d8">EXHALED AIR PATH</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The manikin acts as the source of exhaled air, establishing the airflow path through which droplets enter the coach environment.</data>
      <data key="d11">0.82</data>
      <data key="d12">2</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_46</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
