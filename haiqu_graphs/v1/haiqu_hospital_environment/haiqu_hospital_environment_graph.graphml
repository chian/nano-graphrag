      <data key="d8">SUPPLY AIR DUCTS</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">Treated air leaves the air conditioning units and enters the supply air ducts for delivery toward the cabin.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_11</data>
