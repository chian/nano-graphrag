      <data key="d8">CO2</data>
      <data key="d9">PATTERN_MEASURED_BY</data>
      <data key="d10">CO2 measurements can support validation of assumed or simulated stationary airflow behavior by indicating how exhaled air is distributed under real indoor ventilation conditions.</data>
      <data key="d11">0.66</data>
      <data key="d12">2</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_9</data>
      <data key="d14">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
