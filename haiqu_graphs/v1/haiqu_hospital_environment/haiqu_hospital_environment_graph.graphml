      <data key="d8">SIMULATION DOMAIN</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The downward isothermal path carries droplets toward the bottom boundary of the simulation domain, where they depart from it.</data>
      <data key="d11">0.7</data>
      <data key="d12">3</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_43</data>
