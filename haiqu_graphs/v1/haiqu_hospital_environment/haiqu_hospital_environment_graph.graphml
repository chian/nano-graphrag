      <data key="d0">AIR CONDITIONING SYSTEM WITH SPONGE FILTERS</data>
      <data key="d1">HVAC_UNIT</data>
      <data key="d2">Subway air-conditioning equipment using sponge filters for particle filtration. The same filter type is used in case 1 and case 2 to reflect actual subway operating conditions.</data>
      <data key="d3">0.78</data>
      <data key="d4">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_20</data>
      <data key="d5">92822355-ab82-4e40-9fca-0876f2fc943e</data>
    </node>
