      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">Breathing manikins act as respiratory emission sources for droplets or particles that may carry SARS-CoV-2.</data>
      <data key="d11">0.75</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_78</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
