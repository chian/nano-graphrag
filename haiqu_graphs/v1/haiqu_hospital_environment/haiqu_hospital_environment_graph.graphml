    <node id="UWMC">
      <data key="d0">UWMC</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">The working hospital environment in which the aerosol plume tracing study was conducted during the Covid-19 pandemic. Additional experiments were suggested to generalize aerosol propagation trends at this facility.</data>
      <data key="d3">0.72</data>
      <data key="d4">62e55c5d-3b2a-4772-a671-df2065fce8b1_chunk_36</data>
