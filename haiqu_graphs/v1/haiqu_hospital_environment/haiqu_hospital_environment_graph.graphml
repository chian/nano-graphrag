      <data key="d8">JETS OF AIR FROM LEAK AREAS</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">Poorly sealed mask regions at the nose, cheeks, and chin generate localized leakage jets.</data>
      <data key="d11">0.92</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_47</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
