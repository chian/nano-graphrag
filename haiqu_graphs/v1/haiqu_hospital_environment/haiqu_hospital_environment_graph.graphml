      <data key="d8">SARS-COV-2</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">Aerosol and droplet dispersion is the pathway through which infectious agents such as SARS-CoV-2 may disseminate in the semi-confined railway coach.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_76</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
