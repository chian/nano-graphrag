      <data key="d7">HUMANOID MANIKINS WEARING MASKS OR NOT</data>
      <data key="d8">MIXED CONVECTION FLOWS</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The manikins contribute to mixed convection through temperature differences between their bodies and the surrounding railway-coach environment.</data>
      <data key="d11">0.76</data>
      <data key="d12">2</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_76</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
