      <data key="d7">VENTILATION IN THE RAILWAY COACH</data>
      <data key="d8">RAILWAY COACH</data>
      <data key="d9">SERVES</data>
      <data key="d10">The ventilation system serves the railway coach by providing air movement in the semi-confined occupied zone.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_76</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
