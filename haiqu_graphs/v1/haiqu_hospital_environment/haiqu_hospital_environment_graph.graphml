      <data key="d8">AUDIENCE SEATING AREA</data>
      <data key="d9">ADJACENT_TO</data>
      <data key="d10">The checkerboard seating arrangement applies to the audience seating area and changes the spatial relationship among occupied and unoccupied seats, affecting exposure patterns.</data>
      <data key="d11">0.63</data>
      <data key="d12">1</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_24</data>
      <data key="d14">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
