      <data key="d8">RESPIRATORY DROPLETS</data>
      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">The infected manikin increases the droplet load in the compartment through breathing, which is identified as the dissemination event.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_59</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
