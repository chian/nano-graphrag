      <data key="d8">SILENT, SEDENTARY EMITTER</data>
      <data key="d9">ADJACENT_TO</data>
      <data key="d10">Some spectators were seated in front of and next to the emitter. These nearby spectators were reported to remain almost unaffected and showed low individual infection risks.</data>
      <data key="d11">0.64</data>
      <data key="d12">2</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_21</data>
      <data key="d14">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
    </edge>
