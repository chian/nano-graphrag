      <data key="d0">EFFECTIVE AIR HANDLING SCHEME</data>
      <data key="d1">HVAC_UNIT</data>
      <data key="d2">An air-handling arrangement serving larger modern operating rooms. It limited aerosol plume spread such that the plume did not reach the room perimeter.</data>
      <data key="d3">0.84</data>
      <data key="d4">62e55c5d-3b2a-4772-a671-df2065fce8b1_chunk_37</data>
      <data key="d5">62e55c5d-3b2a-4772-a671-df2065fce8b1</data>
