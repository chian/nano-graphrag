      <data key="d8">TWO AIR CONDITIONING UNITS</data>
      <data key="d9">SERVES</data>
      <data key="d10">The intelligent control cabinet supports operation of the air conditioning units by enabling multiple ventilation modes and air-supply frequency modulation.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">92822355-ab82-4e40-9fca-0876f2fc943e_chunk_11</data>
      <data key="d14">92822355-ab82-4e40-9fca-0876f2fc943e</data>
