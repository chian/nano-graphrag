      <data key="d7">BUOYANT PLUME ABOVE THE MANIKIN'S HEAD</data>
      <data key="d8">UPPER-PART DROPLET DISTRIBUTION</data>
      <data key="d9">HAS_DISTRIBUTION_PATTERN</data>
      <data key="d10">The buoyant plume carries droplets upward, producing the observed upper-domain droplet distribution by t = 120 s.</data>
      <data key="d11">0.89</data>
      <data key="d12">2</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_41</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
