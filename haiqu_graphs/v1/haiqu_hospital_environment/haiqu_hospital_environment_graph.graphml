      <data key="d9">CONNECTS_TO</data>
      <data key="d10">Spectator dummies are equipped with virtual mouth openings for respiration, linking each modeled spectator to a local breathing and exposure-assessment air path.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">0676edf9-1d10-4220-bdea-1b4729f9856d_chunk_27</data>
      <data key="d14">0676edf9-1d10-4220-bdea-1b4729f9856d</data>
