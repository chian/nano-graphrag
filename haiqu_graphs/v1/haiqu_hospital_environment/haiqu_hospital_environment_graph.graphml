      <data key="d8">WARM EXHALED AIR JET</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The breathing manikin is the source of the warm exhaled airflow jet released into the computational domain during respiratory cycles.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_41</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
