      <data key="d9">OCCUPANCY_INCREASES</data>
      <data key="d10">Human occupancy can increase respiratory aerosol emissions and potential SARS-CoV-2 inhalation exposure in indoor spaces.</data>
      <data key="d11">0.7</data>
      <data key="d12">2</data>
      <data key="d13">19fa3b4e-2c3d-44b1-ae20-59902abc601a_chunk_13</data>
