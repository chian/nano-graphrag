      <data key="d8">MICROMETRIC DROPLETS</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The warm exhaled air jet initially transports the micrometric droplets away from the manikin into the computational domain.</data>
      <data key="d11">0.84</data>
      <data key="d12">1</data>
      <data key="d13">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42_chunk_41</data>
      <data key="d14">6ce6bcdd-6339-49d0-abf2-8f8a9a51aa42</data>
    </edge>
    <edge source="WARM EXHALED AIR JET" target="PARALLELEPIPEDIC SIMULATION DOMAIN">
