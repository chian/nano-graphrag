      <data key="d7">ROOM AIRFLOW</data>
      <data key="d8">INDOOR EXPERIMENTAL ROOM</data>
      <data key="d9">CONNECTS_TO</data>
      <data key="d10">The room airflow is the air path through which aerosol nuclei move within the indoor experimental room.</data>
      <data key="d11">0.78</data>
      <data key="d12">2</data>
      <data key="d13">2c371b3c-bdf6-4d57-aab2-55e74c106206_chunk_51</data>
      <data key="d14">2c371b3c-bdf6-4d57-aab2-55e74c106206</data>
    </edge>
