  <key id="d0" for="node" attr.name="entity_name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="RECAPTCHA">
      <data key="d0">RECAPTCHA</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Google reCAPTCHA service embedded on the webpage to verify human users and block automated access attempts.</data>
      <data key="d3">0.95</data>
      <data key="d4">acd1f3b8-58df-4f9c-b442-fddccc439222_chunk_0</data>
      <data key="d5">acd1f3b8-58df-4f9c-b442-fddccc439222</data>
    </node>
    <node id="IMAGE SELECTION CHALLENGE (BUS IMAGES)">
      <data key="d0">IMAGE SELECTION CHALLENGE (BUS IMAGES)</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">The visual puzzle that requires selecting all images containing a bus; used as the measurable test to distinguish humans from bots.</data>
      <data key="d3">0.85</data>
      <data key="d4">acd1f3b8-58df-4f9c-b442-fddccc439222_chunk_0</data>
      <data key="d5">acd1f3b8-58df-4f9c-b442-fddccc439222</data>
    </node>
    <node id="PUBMED.NCBI.NLM.NIH.GOV PAGE">
      <data key="d0">PUBMED.NCBI.NLM.NIH.GOV PAGE</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">The PubMed web resource page being protected by the verification control (treated here as the protected digital/health information zone).</data>
      <data key="d3">0.75</data>
      <data key="d4">acd1f3b8-58df-4f9c-b442-fddccc439222_chunk_0</data>
      <data key="d5">acd1f3b8-58df-4f9c-b442-fddccc439222</data>
    </node>
    <node id="AUTOMATED ACCESS ATTEMPTS (BOTS)">
      <data key="d0">AUTOMATED ACCESS ATTEMPTS (BOTS)</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Automated scripts and bots attempting unauthorized or high-volume access to the site; primary target the verification seeks to deter.</data>
      <data key="d3">0.88</data>
      <data key="d4">acd1f3b8-58df-4f9c-b442-fddccc439222_chunk_0</data>
      <data key="d5">acd1f3b8-58df-4f9c-b442-fddccc439222</data>
    </node>
    <node id="USER VERIFICATION COMPLIANCE">
      <data key="d0">USER VERIFICATION COMPLIANCE</data>
      <data key="d1">COMPLIANCE_RATE</data>
      <data key="d2">The requirement and observed rate at which human users complete the captcha flow (click verify after selecting images).</data>
      <data key="d3">0.6</data>
      <data key="d4">acd1f3b8-58df-4f9c-b442-fddccc439222_chunk_0</data>
      <data key="d5">acd1f3b8-58df-4f9c-b442-fddccc439222</data>
    </node>
    <node id="USABILITY COST (DELAY/FRICTION)">
      <data key="d0">USABILITY COST (DELAY/FRICTION)</data>
      <data key="d1">COST_PROXY</data>
      <data key="d2">Extra time, interaction steps, and potential redirect delays imposed on users by the captcha challenge, used as a proxy for operational cost.</data>
      <data key="d3">0.55</data>
      <data key="d4">acd1f3b8-58df-4f9c-b442-fddccc439222_chunk_0</data>
      <data key="d5">acd1f3b8-58df-4f9c-b442-fddccc439222</data>
    </node>
    <node id="USER FRUSTRATION / ACCESS DIFFICULTY">
      <data key="d0">USER FRUSTRATION / ACCESS DIFFICULTY</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">Potential negative effect on legitimate users (frustration, failed verification, interrupted access) resulting from the captcha process.</data>
      <data key="d3">0.45</data>
      <data key="d4">acd1f3b8-58df-4f9c-b442-fddccc439222_chunk_0</data>
      <data key="d5">acd1f3b8-58df-4f9c-b442-fddccc439222</data>
    </node>
    <node id="HTTPS (ENCRYPTED CONNECTION)">
      <data key="d0">HTTPS (ENCRYPTED CONNECTION)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">The HTTPS protocol described on the page as ensuring that connections to the site are encrypted and transmitted securely; a technical control applied to protect data-in-transit between user and server. | The transport-layer security mechanism (https://) used by the site to encrypt data in transit, ensuring connections between user agents and the server are confidential and integrity-protected.</data>
      <data key="d3">0.95</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_0</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b,e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">HTTPS (SECURE CONNECTION)</data>
    </node>
    <node id=".GOV DOMAIN (OFFICIAL SITE INDICATOR)">
      <data key="d0">.GOV DOMAIN (OFFICIAL SITE INDICATOR)</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Presence of a .gov domain used on federal government websites as an authenticity/officiality indicator for users (page text: 'The .gov means it’s official'). | The presence of a .gov (or .mil) domain as an authenticity indicator for federal government websites; recommended as a quick heuristic to verify official status before sharing sensitive information.</data>
      <data key="d3">0.85</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_0</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b,e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">.GOV DOMAIN (OFFICIAL FEDERAL SITE INDICATOR)</data>
    </node>
    <node id="PUBMED WEBSITE (PUBMED.NCBI.NLM.NIH.GOV)">
      <data key="d0">PUBMED WEBSITE (PUBMED.NCBI.NLM.NIH.GOV)</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">The PubMed/NCBI web platform hosting the page and links (includes the site content stating HTTPS and .gov guidance and linking to PMID 32218911). Treated here as the location/context in which controls and effects are applied.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_0</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="TEMPORARY UNAVAILABILITY OF CLIPBOARD/SEARCH HISTORY AND ADVANCED FEATURES">
      <data key="d0">TEMPORARY UNAVAILABILITY OF CLIPBOARD/SEARCH HISTORY AND ADVANCED FEATURES</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">User-facing adverse effect noted on the page: Clipboard, Search History and several other advanced features are temporarily unavailable, reducing site functionality and user capability.</data>
      <data key="d3">0.72</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_0</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="RISK OF UNSECURED DATA TRANSMISSION (WITHOUT HTTPS)">
      <data key="d0">RISK OF UNSECURED DATA TRANSMISSION (WITHOUT HTTPS)</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">Potential adverse outcome that HTTPS seeks to mitigate: unencrypted transmission leading to risk of interception, tampering or exposure of sensitive information if not protected by HTTPS.</data>
      <data key="d3">0.6</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_0</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="PUBMED ARTICLE 32218911">
      <data key="d0">PUBMED ARTICLE 32218911</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">The specific PubMed article referenced by the page (PMID 32218911); included on the page as the primary content resource linked from the site header.</data>
      <data key="d3">0.4</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_0</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="PUBMED PMID 32218911">
      <data key="d0">PUBMED PMID 32218911</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">PubMed bibliographic record (PMID 32218911). Represents a validation study or article that may report empirical evidence (methods, results, conclusions) about engineering controls for airborne transmission in healthcare or similar settings. Serves as a traceable source to validate effectiveness, doses/rates, costs, adverse effects, or compliance data when the full article is consulted.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ENGINEERING CONTROLS FOR AIRBORNE PATHOGENS">
      <data key="d0">ENGINEERING CONTROLS FOR AIRBORNE PATHOGENS</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Physical or mechanical interventions intended to reduce airborne transmission risk (examples: ventilation improvements, increased air changes per hour, HEPA filtration, UV germicidal irradiation, directional airflow). Defined by operational parameters and implemented in healthcare or built environments.</data>
      <data key="d3">0.95</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="UNSPECIFIED AIRBORNE PATHOGENS">
      <data key="d0">UNSPECIFIED AIRBORNE PATHOGENS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Pathogens transmitted via aerosols or airborne particles (not specified in the source text). Represents the target organisms whose airborne concentration or transmission risk engineering controls aim to reduce.</data>
      <data key="d3">0.7</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="HEALTHCARE SETTINGS / HOSPITAL ZONES">
      <data key="d0">HEALTHCARE SETTINGS / HOSPITAL ZONES</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Physical areas in healthcare facilities where engineering controls would be applied (e.g., patient rooms, wards, procedure rooms, isolation rooms). Context for application and performance assessment of controls.</data>
      <data key="d3">0.65</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="EFFECTIVENESS MEASURES (E.G., REDUCTION IN AIRBORNE CONCENTRATION, INFECTION RISK)">
      <data key="d0">EFFECTIVENESS MEASURES (E.G., REDUCTION IN AIRBORNE CONCENTRATION, INFECTION RISK)</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Quantitative or qualitative outcomes used to evaluate control performance, such as percent reduction in airborne particle/pathogen concentration, estimated infection risk reduction, or relative performance versus alternatives. These measures are typically reported in validation studies.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="DOSE OR RATE PARAMETERS (E.G., AIR CHANGES PER HOUR, FLOW RATES)">
      <data key="d0">DOSE OR RATE PARAMETERS (E.G., AIR CHANGES PER HOUR, FLOW RATES)</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Operational parameters that characterize engineering controls (for example, air changes per hour (ACH), clean air delivery rate, filtration flow rates, UV dose). These parameters determine control intensity and are often linked to effectiveness.</data>
      <data key="d3">0.75</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COST PROXIES (CAPITAL AND OPERATING COST ESTIMATES)">
      <data key="d0">COST PROXIES (CAPITAL AND OPERATING COST ESTIMATES)</data>
      <data key="d1">COST_PROXY</data>
      <data key="d2">Economic indicators or proxies for implementing and operating engineering controls (examples: equipment capital cost, installation cost, energy and maintenance operating costs). Used for assessing feasibility and trade-offs.</data>
      <data key="d3">0.5</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COMPLIANCE RATE (OPERATION AND MAINTENANCE ADHERENCE)">
      <data key="d0">COMPLIANCE RATE (OPERATION AND MAINTENANCE ADHERENCE)</data>
      <data key="d1">COMPLIANCE_RATE</data>
      <data key="d2">Measures of how consistently controls are operated and maintained as intended (e.g., adherence to maintenance schedules, correct operation of ventilation/filtration systems). Affects real-world effectiveness.</data>
      <data key="d3">0.5</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ADVERSE EFFECTS (E.G., NOISE, DRAFTS, OZONE)">
      <data key="d0">ADVERSE EFFECTS (E.G., NOISE, DRAFTS, OZONE)</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">Potential negative consequences of engineering controls, such as increased noise, drafts, thermal discomfort, or byproduct generation (e.g., ozone from certain UV systems). Relevant for risk–benefit evaluation.</data>
      <data key="d3">0.4</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION SYSTEM DESIGN">
      <data key="d0">VENTILATION SYSTEM DESIGN</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Planned configuration of supply/exhaust locations, flow patterns and ventilation components used to control airborne contaminant transport in a specific space; here it denotes site-specific, scientifically based design choices intended to reduce occupant exposure in clinical rooms. Key functions: changes particle trajectories, can optimize exposure control via flow-path manipulation even without increasing volumetric airflow.</data>
      <data key="d3">0.95</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="UNINTERRUPTED SOURCE-TO-EXHAUST AIRFLOW PATH">
      <data key="d0">UNINTERRUPTED SOURCE-TO-EXHAUST AIRFLOW PATH</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A design principle that ensures a direct airflow route from the contaminant source (e.g., patient) to exhaust outlets to limit mixing into occupied breathing zones; depends on supply/exhaust placement, room layout and local flows.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INCREASING VENTILATION AIRFLOW RATE">
      <data key="d0">INCREASING VENTILATION AIRFLOW RATE</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Operational strategy of raising the volumetric airflow delivered to a space (expressed via ACH or flow rate units) to enhance dilution of airborne contaminants; effective for steady, well-mixed sources but may not improve localized ventilation effectiveness if flow pathing is poor.</data>
      <data key="d3">0.75</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIR CHANGES PER HOUR (ACH)">
      <data key="d0">AIR CHANGES PER HOUR (ACH)</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Numeric ventilation metric indicating how many times the room air volume is replaced per hour; commonly used to quantify dilution capacity but does not fully capture path-dependent ventilation effectiveness.</data>
      <data key="d3">0.85</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2,3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION AIRFLOW RATE">
      <data key="d0">VENTILATION AIRFLOW RATE</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Volumetric flow of supply/exhaust air delivered to a space (e.g., CFM or m3/h); the operative parameter increased when raising ACH and a determinant of dilution kinetics.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE INFECTIOUS DISEASE AGENTS">
      <data key="d0">AIRBORNE INFECTIOUS DISEASE AGENTS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Particles or aerosols containing infectious material that can be transported by air and expose occupants; exposure-to-infection is dose-dependent and not guaranteed for every exposure event.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ISOLATION ROOM">
      <data key="d0">ISOLATION ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">An enclosed, mechanically ventilated patient room intended to isolate infectious patients; used here as the study context for design and CFD analysis.</data>
      <data key="d3">0.93</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS">
      <data key="d0">COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Simulation-based analysis performed to resolve local airflow and particle trajectories, examine transport mechanisms and evaluate control strategies for reducing airborne infectious agents in an isolation room.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="EXTENSIVE LITERATURE REVIEW">
      <data key="d0">EXTENSIVE LITERATURE REVIEW</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Comprehensive synthesis of prior empirical and modeling studies summarizing evidence on ACH, dilution effects, ventilation effectiveness and exposure–infection relationships; used to contextualize limitations of relying solely on increased airflow.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COST OF NOSOCOMIAL INFECTIONS $4-5 BILLION ANNUALLY">
      <data key="d0">COST OF NOSOCOMIAL INFECTIONS $4-5 BILLION ANNUALLY</data>
      <data key="d1">COST_PROXY</data>
      <data key="d2">A cited national estimate of the annual US economic burden of hospital-acquired infections ($4–5 billion/year) used as motivation for investing in optimized ventilation and site-specific risk analysis to achieve long-term cost savings.</data>
      <data key="d3">0.6</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="SITE-SPECIFIC RISK ANALYSIS">
      <data key="d0">SITE-SPECIFIC RISK ANALYSIS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A location-focused assessment of transmission risks and environmental conditions used to inform ventilation system design decisions (supply/exhaust placement, airflow targets and controls) for a specific room or facility.</data>
      <data key="d3">0.78</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION EFFECTIVENESS">
      <data key="d0">VENTILATION EFFECTIVENESS</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">A measure of how well ventilation achieves contaminant removal from occupied breathing zones, accounting for flow patterns and transport pathways rather than only room-average dilution.</data>
      <data key="d3">0.86</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="PARTICLE TRANSPORT MECHANISM">
      <data key="d0">PARTICLE TRANSPORT MECHANISM</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Mechanistic description of how particles move within a room (advection, diffusion, deposition, recirculation) that determines exposure patterns and how controls perform.</data>
      <data key="d3">0.82</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INFECTION RISK">
      <data key="d0">INFECTION RISK</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Probability or likelihood that exposure to airborne infectious agents leads to infection of occupants; influenced by exposure magnitude, particle transport, host susceptibility and control effectiveness.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="EXPOSURE-TO-INFECTION RELATIONSHIP">
      <data key="d0">EXPOSURE-TO-INFECTION RELATIONSHIP</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Dose–response concept expressing that not every exposure results in infection and that infection probability depends on pathogen dose, exposure duration and host factors; used to interpret control benefits.</data>
      <data key="d3">0.7</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="NEGATIVE-PRESSURIZED ISOLATION ROOM">
      <data key="d0">NEGATIVE-PRESSURIZED ISOLATION ROOM</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">An engineered patient room that maintains a lower air pressure relative to adjacent spaces so that air flows into the room and contaminated air is contained and exhausted. Key features include dedicated exhaust, sealed construction, pressure monitoring, and filtration or direct exhaust. In the text this control is evaluated for Emergency Departments (Wang et al. 2022) as a means to limit dissemination of respiratory-virus–laden aerosols.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION">
      <data key="d0">VENTILATION</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Mechanical or natural air exchange and flow control in indoor spaces used to dilute, remove, or direct airborne contaminants. Attributes: airflow rates (ACH), supply/exhaust placement, flow direction and patterns. In the text, different ventilation configurations are experimentally or computationally assessed for their effect on cough-droplet trajectories and on occupant-related outcomes. | An engineering/operational measure to reduce indoor airborne exposures by exchanging, filtering, or diluting indoor air (natural or mechanical). Key attributes: air change rate (ACH), outdoor-air fraction, filtration, and mixing. In this context ventilation is the primary environmental control discussed for lowering indoor aerosol concentrations and inhalation risk; its performance is commonly monitored using CO2 as a proxy.</data>
      <data key="d3">0.95</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b,e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">VENTILATION</data>
    </node>
    <node id="HOSPITAL ISOLATION ROOM">
      <data key="d0">HOSPITAL ISOLATION ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">A clinical room used to isolate patients with contagious infections. Typically incorporates engineering controls (ventilation, pressure differentials) and is the spatial context for studies of droplet/aerosol behavior and negative-pressure room performance.</data>
      <data key="d3">0.82</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="EMERGENCY DEPARTMENTS">
      <data key="d0">EMERGENCY DEPARTMENTS</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Hospital emergency care areas with high patient throughput and urgent-care needs; they present operational constraints and unique requirements for isolation rooms and ventilation performance. Wang et al. (2022) specifically evaluates a negative-pressurized isolation room designed for ED use.</data>
      <data key="d3">0.78</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COVID-19">
      <data key="d0">COVID-19</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Disease caused by SARS-CoV-2; used here as the specific pathogen whose cough-generated droplets/aerosols were modeled or measured in isolation-room ventilation studies (Dao et al. 2022). | The disease caused by SARS-CoV-2; cited as the primary airborne infectious risk examined across the referenced studies and modeling efforts.</data>
      <data key="d3">0.92</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4,3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b,e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">COVID-19</data>
    </node>
    <node id="RESPIRATORY VIRUSES">
      <data key="d0">RESPIRATORY VIRUSES</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">A class of viruses (e.g., influenza, coronaviruses) that transmit via respiratory droplets and aerosols. The category frames why ventilation and isolation-room controls are used and are the subject of transmissibility reviews (Leung 2021).</data>
      <data key="d3">0.86</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION PERFORMANCE EVALUATION OF A NEGATIVE-PRESSURIZED ISOLATION ROOM FOR EMERGENCY DEPARTMENTS">
      <data key="d0">VENTILATION PERFORMANCE EVALUATION OF A NEGATIVE-PRESSURIZED ISOLATION ROOM FOR EMERGENCY DEPARTMENTS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Wang F et al., Healthcare (Basel). 2022 (PMID: 35206808). Empirical evaluation of ventilation and negative-pressure performance of an isolation room designed for Emergency Department settings; provides measured/monitored evidence on pressure differentials, airflow characteristics, and operational considerations for ED deployment.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="BEHAVIOR OF COUGH DROPLETS EMITTED FROM COVID-19 PATIENT IN HOSPITAL ISOLATION ROOM WITH DIFFERENT VENTILATION CONFIGURATIONS">
      <data key="d0">BEHAVIOR OF COUGH DROPLETS EMITTED FROM COVID-19 PATIENT IN HOSPITAL ISOLATION ROOM WITH DIFFERENT VENTILATION CONFIGURATIONS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Dao HT, Kim KS, et al., Build Environ. 2022 (PMID: 34898818). Experimental and/or computational study comparing how alternative ventilation configurations affect cough-generated droplet/aerosol transport, residence time, and likely exposure zones in a hospital isolation room containing a Covid-19 patient.</data>
      <data key="d3">0.88</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="SUMMARY OF HUMAN RESPONSES TO VENTILATION">
      <data key="d0">SUMMARY OF HUMAN RESPONSES TO VENTILATION</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Seppänen OA, Fisk WJ. Indoor Air. 2004 (PMID: 15330778). A review synthesizing evidence on human physiological and perceptual responses to ventilation (comfort, perceived air quality, symptoms) and implications for occupant behavior and exposure risk.</data>
      <data key="d3">0.7</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="TRANSMISSIBILITY AND TRANSMISSION OF RESPIRATORY VIRUSES">
      <data key="d0">TRANSMISSIBILITY AND TRANSMISSION OF RESPIRATORY VIRUSES</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Leung NHL. Nat Rev Microbiol. 2021 (PMID: 33753932). A review summarizing modes and determinants of respiratory-virus transmission (droplet vs aerosol, environmental modifiers), providing mechanistic justification for ventilation and isolation controls.</data>
      <data key="d3">0.82</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COUGH-GENERATED DROPLET/AEROSOL BEHAVIOR AND AIRBORNE PERSISTENCE">
      <data key="d0">COUGH-GENERATED DROPLET/AEROSOL BEHAVIOR AND AIRBORNE PERSISTENCE</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Outcome measures describing droplet/aerosol trajectories, residence time in breathing zones, deposition vs exhaust, and spatial patterns of airborne particle concentrations following a cough. Used to quantify how engineering controls (ventilation, negative pressure) change exposure risk.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="OCCUPANT COMFORT AND PERCEIVED AIR QUALITY">
      <data key="d0">OCCUPANT COMFORT AND PERCEIVED AIR QUALITY</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Measures of human thermal comfort, sensory perception of air quality, and symptom reports that are influenced by ventilation rates and patterns and that can affect occupant behavior and compliance with infection-control practices.</data>
      <data key="d3">0.65</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION STRATEGIES">
      <data key="d0">VENTILATION STRATEGIES</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Engineering and operational approaches to control indoor airflow (e.g., supply/exhaust placement, air change rates, directional flow, local exhaust) intended to dilute, remove or redirect airborne contaminants. In the cited work these strategies are modeled at ward scale to assess impacts on aerosol transport and residence time. Relevant attributes: HVAC configuration dependency, achievable dilution/removal, and interaction with room geometry and occupancy. | Engineering and operational measures that change air exchange rates and airflow patterns (e.g., increased ACH, directed exhaust, air cleaners) to dilute/remove exhaled aerosols and reduce airborne transmission risk in enclosed spaces.</data>
      <data key="d3">0.95</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b,e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">VENTILATION STRATEGIES</data>
    </node>
    <node id="PERSONAL PROTECTIVE EQUIPMENT">
      <data key="d0">PERSONAL PROTECTIVE EQUIPMENT</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Individual-level barrier and filtration devices (e.g., surgical masks, N95/FFP respirators, eye protection, gowns) used by healthcare workers to reduce exposure to respiratory pathogens. Key attributes: protection class, fit/seal, correct donning/doffing and task-specific selection. In the text this is discussed in the context of surgical practice during COVID-19.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INPATIENT WARDS">
      <data key="d0">INPATIENT WARDS</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">General patient care areas where patients are admitted for ongoing treatment; typically multi-bed rooms or single rooms with routine staff contact. Ward layout, occupancy and typical activities influence airborne dispersion and effectiveness of ventilation interventions modeled in the Satheesan study.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CRITICAL HOSPITAL AREAS">
      <data key="d0">CRITICAL HOSPITAL AREAS</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">High-acuity or high-sensitivity clinical spaces (e.g., intensive care units, transplant or oncology wards, sterile processing areas) where air quality and contamination control are critical and occupants may be highly vulnerable. The Belizario review synthesizes evidence about fungal presence in such areas.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="OPERATING ROOMS">
      <data key="d0">OPERATING ROOMS</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Surgical suites where invasive procedures are performed; characterized by controlled ventilation, sterile workflows and distinct PPE and airflow requirements. The Stewart review addresses PPE considerations relevant to surgeons and perioperative teams in these settings.</data>
      <data key="d3">0.82</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="MERS-COV">
      <data key="d0">MERS-COV</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Middle East Respiratory Syndrome coronavirus (MERS-CoV), a respiratory coronavirus that can produce virus-laden aerosols under some circumstances and has caused nosocomial transmission events. In the Satheesan study it is the modeled pathogen for dispersion simulations in wards.</data>
      <data key="d3">0.85</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="FUNGI">
      <data key="d0">FUNGI</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Environmental fungal spores and hyphal fragments (e.g., Aspergillus spp. and other opportunistic molds) detectable in indoor air and potentially pathogenic to immunocompromised patients. The Belizario review compiles surveillance data from critical hospital areas on fungal presence and implications for infection control.</data>
      <data key="d3">0.75</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE DISPERSION">
      <data key="d0">AIRBORNE DISPERSION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Quantitative or qualitative measure of aerosol transport and distribution in indoor spaces (e.g., concentration fields, residence time, exposure at receptor locations). Used as the outcome measure to evaluate how ventilation strategies alter pathogen-laden aerosol behavior in the Satheesan numerical study.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="SATHEESAN 2024 HELIYON">
      <data key="d0">SATHEESAN 2024 HELIYON</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Satheesan MK, Tsang TW, Wong LT, Mui KW. Heliyon. 2024 Feb 14;10(4):e26159. Numerical (computational) investigation modeling how different ventilation strategies affect airborne dispersion of MERS-CoV in inpatient ward geometries. Provides simulated evidence on mechanisms and relative performance of ventilation configurations.</data>
      <data key="d3">0.88</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="STEWART 2020 ANN SURG">
      <data key="d0">STEWART 2020 ANN SURG</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Stewart CL, Thornblade LW, Diamond DJ, Fong Y, Melstrom LG. Ann Surg. 2020 Aug;272(2):e132-e138. Review synthesizing guidance and evidence about personal protective equipment for surgeons during the COVID-19 pandemic, including device selection, procedural considerations and practical implementation issues.</data>
      <data key="d3">0.87</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="BELIZARIO 2021 AEROBIOLOGIA">
      <data key="d0">BELIZARIO 2021 AEROBIOLOGIA</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Belizario JA, Lopes LG, Pires RH. Aerobiologia (Bologna). 2021;37(3):379-394. Review summarizing studies of fungal organisms in indoor air of critical hospital areas, including sampling results, species identified and implications for vulnerable patients and infection-control practices.</data>
      <data key="d3">0.77</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="LEUNG 2021 NAT REV MICROBIOL">
      <data key="d0">LEUNG 2021 NAT REV MICROBIOL</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Leung NHL. Nat Rev Microbiol. 2021 Aug;19(8):528-545. Review of airborne transmission science and control measures for respiratory infections, providing conceptual and evidence-based background for environmental and personal protective strategies in healthcare and public health.</data>
      <data key="d3">0.78</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION OF HEALTH CARE FACILITIES">
      <data key="d0">VENTILATION OF HEALTH CARE FACILITIES</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Mechanical ventilation and HVAC strategies used in health-care settings (room supply/exhaust rates, filtration, pressure relationships, air distribution and commissioning) intended to dilute and remove airborne infectious particles and to establish directional pressure for isolation or protective environments.</data>
      <data key="d3">1.0</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="HEALTH CARE FACILITIES">
      <data key="d0">HEALTH CARE FACILITIES</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Clinical and institutional spaces where patients are assessed and treated (wards, procedure rooms, waiting areas, isolation rooms). These are the deployment environments for ventilation controls and the primary subjects of ASHRAE/ASHE Standard 170-2008.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ASHRAE/ASHE STANDARD 170-2008">
      <data key="d0">ASHRAE/ASHE STANDARD 170-2008</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Consensus standard 'Ventilation of Health Care Facilities' (2008) that prescribes minimum ventilation rates (ACH), pressure relationships, filtration recommendations and HVAC performance criteria used to design and operate ventilation in health-care spaces to achieve infection-control objectives.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ASHRAE HANDBOOK-FUNDAMENTALS">
      <data key="d0">ASHRAE HANDBOOK-FUNDAMENTALS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">ASHRAE Handbook - Fundamentals (2005) providing core engineering principles, calculation methods (airflow, contaminant transport), and data on filtration and HVAC systems that underpin the design rationale for ventilation controls.</data>
      <data key="d3">0.7</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="RISK MANAGEMENT GUIDANCE FOR HEALTH, SAFETY AND ENVIRONMENTAL SECURITY UNDER EXTRAORDINARY INCIDENTS">
      <data key="d0">RISK MANAGEMENT GUIDANCE FOR HEALTH, SAFETY AND ENVIRONMENTAL SECURITY UNDER EXTRAORDINARY INCIDENTS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">ASHRAE guidance (2003) giving high-level institutional risk-management recommendations for environmental controls, including how ventilation may be adjusted during extraordinary incidents (outbreaks, environmental hazards) as part of preparedness and mitigation.</data>
      <data key="d3">0.6</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE PATHOGEN">
      <data key="d0">AIRBORNE PATHOGEN</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Respiratory infectious agents or infectious particles (droplets/aerosols) that can be transmitted through the air and whose concentration and transmission risk are affected by ventilation and HVAC controls.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE CONCENTRATION REDUCTION">
      <data key="d0">AIRBORNE CONCENTRATION REDUCTION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">A measurable reduction in airborne infectious particle concentration (steady-state or time-averaged) attributable to ventilation, filtration and pressure control; used to quantify intervention effectiveness for infection control.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COMPLIANCE WITH STANDARD 170-2008">
      <data key="d0">COMPLIANCE WITH STANDARD 170-2008</data>
      <data key="d1">COMPLIANCE_RATE</data>
      <data key="d2">The degree to which a health-care facility's design, commissioning and operations meet the prescriptive requirements of ASHRAE/ASHE Standard 170-2008 (e.g., meeting specified ACH, pressure differentials and filtration levels).</data>
      <data key="d3">0.6</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="HVAC UPGRADE AND OPERATING COSTS">
      <data key="d0">HVAC UPGRADE AND OPERATING COSTS</data>
      <data key="d1">COST_PROXY</data>
      <data key="d2">Estimated capital and recurring costs associated with implementing, upgrading or operating ventilation and HVAC systems to meet prescribed standards (including equipment, filtration, commissioning and energy costs).</data>
      <data key="d3">0.5</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INCREASED ENERGY CONSUMPTION">
      <data key="d0">INCREASED ENERGY CONSUMPTION</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">An adverse effect associated with higher ventilation rates and HVAC operation, expressed as increased energy use (and potential indirect environmental impacts) that may accompany interventions aimed at reducing airborne pathogen concentrations.</data>
      <data key="d3">0.45</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="USER DOMAIN-CHECKING BEHAVIOR">
      <data key="d0">USER DOMAIN-CHECKING BEHAVIOR</data>
      <data key="d1">COMPLIANCE_RATE</data>
      <data key="d2">The rate at which users follow guidance to verify the site domain (for example, checking for .gov and HTTPS) prior to submitting sensitive information; higher compliance reduces exposure risk.</data>
      <data key="d3">0.6</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_0</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="RISK OF DATA EXPOSURE DURING TRANSMISSION">
      <data key="d0">RISK OF DATA EXPOSURE DURING TRANSMISSION</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">Potential adverse outcome where sensitive information is intercepted, exposed, or tampered with while being transmitted over the network if connections are not secure or users do not verify site authenticity.</data>
      <data key="d3">0.85</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_0</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="TEMPORARY UNAVAILABILITY OF ADVANCED FEATURES (CLIPBOARD, SEARCH HISTORY)">
      <data key="d0">TEMPORARY UNAVAILABILITY OF ADVANCED FEATURES (CLIPBOARD, SEARCH HISTORY)</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">Temporary disabling of advanced site features (e.g., Clipboard, Search History) that reduces functionality and can disrupt user workflows and efficiency.</data>
      <data key="d3">0.45</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_0</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="WORKFLOW DISRUPTION DUE TO FEATURE OUTAGE">
      <data key="d0">WORKFLOW DISRUPTION DUE TO FEATURE OUTAGE</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">Degradation of user workflow and productivity resulting from the temporary unavailability of site features.</data>
      <data key="d3">0.5</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_0</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="SAVED SEARCH ALERT">
      <data key="d0">SAVED SEARCH ALERT</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Feature that notifies users of new search results for a saved query; configurable via frequency and item limits.</data>
      <data key="d3">0.9</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="EMAIL UPDATES FREQUENCY">
      <data key="d0">EMAIL UPDATES FREQUENCY</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Rate setting controlling how often saved-search alerts are sent (options: Monthly, Weekly, Daily).</data>
      <data key="d3">0.85</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="NUMBER OF ITEMS PER ALERT">
      <data key="d0">NUMBER OF ITEMS PER ALERT</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Limit on how many items are included in each alert message (options shown: 1, 5, 10, 20, 50, 100, 200).</data>
      <data key="d3">0.78</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="EMAIL VERIFICATION STATUS">
      <data key="d0">EMAIL VERIFICATION STATUS</data>
      <data key="d1">COMPLIANCE_RATE</data>
      <data key="d2">Whether a user's email address has been verified; required for sending alerts and can block delivery if unverified.</data>
      <data key="d3">0.76</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="CREATE RSS FEED">
      <data key="d0">CREATE RSS FEED</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Alternative delivery mechanism to email for receiving updates via an RSS feed.</data>
      <data key="d3">0.55</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="ADD TO COLLECTIONS FEATURE">
      <data key="d0">ADD TO COLLECTIONS FEATURE</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Functionality to add items to a user collection; UI shows errors when collections cannot be loaded.</data>
      <data key="d3">0.5</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="ADD TO MY BIBLIOGRAPHY FEATURE">
      <data key="d0">ADD TO MY BIBLIOGRAPHY FEATURE</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Functionality to add items to the user's bibliography; can fail when delegate or account data cannot be loaded.</data>
      <data key="d3">0.45</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="CITATION FORMAT OPTIONS">
      <data key="d0">CITATION FORMAT OPTIONS</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Format choices for exported citations (Summary, Summary text, Abstract, Abstract text, PMID, CSV) that change usefulness of exported data.</data>
      <data key="d3">0.4</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="LOADING ERRORS">
      <data key="d0">LOADING ERRORS</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">UI/backend errors reported in the interface (e.g., 'Unable to load your collection', 'Unable to load your delegates') that disrupt features and reduce usability.</data>
      <data key="d3">0.8</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="SEND EVEN WHEN NO NEW RESULTS OPTION">
      <data key="d0">SEND EVEN WHEN NO NEW RESULTS OPTION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Option to send alerts even if there are no new search results; affects perceived relevance of alerts.</data>
      <data key="d3">0.35</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="ALERT RELEVANCE">
      <data key="d0">ALERT RELEVANCE</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Conceptual measure of how relevant and useful alerts are to users (affected by frequency, item limits, and sending empty alerts).</data>
      <data key="d3">0.65</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="BANDWIDTH / DELIVERY COST PROXY">
      <data key="d0">BANDWIDTH / DELIVERY COST PROXY</data>
      <data key="d1">COST_PROXY</data>
      <data key="d2">Proxy for system load or delivery cost associated with alert frequency and number of items per alert.</data>
      <data key="d3">0.5</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="WINDOWS OPEN (GENERAL)">
      <data key="d0">WINDOWS OPEN (GENERAL)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Opening bus windows (general) to increase natural ventilation; reported to substantially increase air exchange rate (ACH) and, in the moving bus, to reduce average SARS-CoV-2 infection risk by 92% compared with windows closed.</data>
      <data key="d3">0.95</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="TWO WINDOWS OPEN - FRONT + REAR">
      <data key="d0">TWO WINDOWS OPEN - FRONT + REAR</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Configuration with one front and one rear window open; produced greater ACH than the configuration with two rear windows open. | Configuration with two rear windows open; increased ACH but less than front+rear configuration.</data>
      <data key="d3">0.85</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">TWO WINDOWS OPEN - TWO REAR</data>
    </node>
    <node id="VENTILATION FANS SET TO EXHAUST (FRONT AND REAR)">
      <data key="d0">VENTILATION FANS SET TO EXHAUST (FRONT AND REAR)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Setting both front and rear ventilation fans to exhaust mode; reported to more than double ACH compared with both set to supply and to reduce average infection risk by 35% when the bus was moving with windows closed. | Setting both front and rear ventilation fans to supply mode; associated with lower ACH compared with exhaust mode.</data>
      <data key="d3">0.85</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">VENTILATION FANS SET TO SUPPLY (FRONT AND REAR)</data>
    </node>
    <node id="AIR CONDITIONING (AC) WITH PREFILTER / APPROPRIATE FILTER (AC ON)">
      <data key="d0">AIR CONDITIONING (AC) WITH PREFILTER / APPROPRIATE FILTER (AC ON)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">AC unit equipped with an appropriate prefilter: when AC is on with filtration, particles are partially trapped by the prefilter, reducing particle spread rate relative to CO2 and thereby reducing airborne particle exposure and infection risk.</data>
      <data key="d3">0.8</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="AIR CONDITIONING (AC) OFF (NO FILTRATION)">
      <data key="d0">AIR CONDITIONING (AC) OFF (NO FILTRATION)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">AC turned off (no active filtration); in this state CO2 and particles were observed to spread proportionally from a source.</data>
      <data key="d3">0.5</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="ACH (AIR EXCHANGE RATE)">
      <data key="d0">ACH (AIR EXCHANGE RATE)</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Air changes per hour measured in the bus; increased with bus speed and with number/configuration of open windows, and was more than doubled by exhaust fan operation compared with supply.</data>
      <data key="d3">0.9</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="CO2 SPREAD RATE">
      <data key="d0">CO2 SPREAD RATE</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Advection-diffusion/spread rate of CO2 used as a tracer of ventilation and transport; with AC off it spread proportionally to particles from a source.</data>
      <data key="d3">0.65</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="PARTICLE SPREAD RATE">
      <data key="d0">PARTICLE SPREAD RATE</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Advection-diffusion/spread rate of airborne particles (aerosols); with AC on and a prefilter the particle spread rate was approximately half that of CO2, suggesting trapping by the AC prefilter.</data>
      <data key="d3">0.75</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="SARS-COV-2">
      <data key="d0">SARS-COV-2</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">The airborne pathogen targeted in the infection-risk assessment (study focused on commuter bus transmission of SARS-CoV-2).</data>
      <data key="d3">0.9</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="INFECTION RISK REDUCTION - 92% (WINDOWS OPEN VS CLOSED)">
      <data key="d0">INFECTION RISK REDUCTION - 92% (WINDOWS OPEN VS CLOSED)</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Quantified outcome from the study's modified Wells–Riley calculations: average infection risk was reduced by 92% in the moving bus with windows open compared with windows closed.</data>
      <data key="d3">0.95</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="INFECTION RISK REDUCTION - 35% (EXHAUST FANS VS SUPPLY, WINDOWS CLOSED)">
      <data key="d0">INFECTION RISK REDUCTION - 35% (EXHAUST FANS VS SUPPLY, WINDOWS CLOSED)</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Quantified outcome from the study's modified Wells–Riley calculations: when the bus was moving with windows closed, exhaust fan operation reduced the average risk by 35% compared with supply mode.</data>
      <data key="d3">0.75</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="MODIFIED WELLS-RILEY CALCULATION (VALIDATION STUDY)">
      <data key="d0">MODIFIED WELLS-RILEY CALCULATION (VALIDATION STUDY)</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">The study's model calculations using a modified Wells–Riley equation to estimate infection risk and to validate the effectiveness measures reported (92% and 35% reductions).</data>
      <data key="d3">0.8</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="OPENING_WINDOWS">
      <data key="d0">OPENING_WINDOWS</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Operational ventilation intervention consisting of opening vehicle windows (e.g., 5 windows fully opened) to increase natural ventilation in the commuter bus. Modulates cross-flow and exchange with outdoor air, affecting ACH and interior aerosol/CO2 concentrations. Used as an experimental condition compared with windows-closed scenarios in the Tsukuba measurements.</data>
      <data key="d3">0.95</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="WINDOWS_CLOSED">
      <data key="d0">WINDOWS_CLOSED</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Baseline ventilation condition in which bus windows remain closed. Serves as the comparator to window-opening interventions in experiments, associated with lower ACH and higher retained CO2/particle concentrations relative to open-window conditions. | Baseline natural-ventilation state with windows closed, reducing direct air exchange with outdoors.</data>
      <data key="d3">0.78</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">WINDOWS CLOSED</data>
    </node>
    <node id="CO2_MONITORING">
      <data key="d0">CO2_MONITORING</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Use of CO2 sensors and defined monitoring locations inside the bus to quantify indoor CO2 concentrations as a tracer of exhaled breath and ventilation performance. Provides time-resolved data used to infer ventilation adequacy and to complement particle measurements when interpreting ACH and exposure risk.</data>
      <data key="d3">0.88</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="PARTICLE_MONITORING">
      <data key="d0">PARTICLE_MONITORING</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Instrumentation and monitoring points for airborne particles (particle emission systems and sensors) placed inside the bus to measure aerosol concentrations and dynamics. Directly quantifies particulate levels used to assess potential aerosol exposure and the impact of ventilation maneuvers.</data>
      <data key="d3">0.88</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="ACH">
      <data key="d0">ACH</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Air changes per hour (ACH), the primary quantitative ventilation-rate metric measured in the study. Reported as a function of vehicle speed, occupancy (75 mannequins vs none), and window-opening state; central outcome for assessing how quickly interior air is replaced/diluted.</data>
      <data key="d3">0.98</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="INDOOR_CO2_CONCENTRATION">
      <data key="d0">INDOOR_CO2_CONCENTRATION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Measured indoor CO2 concentration (ppm) representing accumulation of occupant-derived exhaled air; used as a proxy to infer ventilation effectiveness and correlate with ACH and aerosol dilution under different experimental conditions.</data>
      <data key="d3">0.9</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="AEROSOL_PARTICLE_CONCENTRATION">
      <data key="d0">AEROSOL_PARTICLE_CONCENTRATION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Measured concentration of airborne particles (size-resolved particulate matter) inside the bus, recorded by particle monitoring systems to evaluate aerosol emission dynamics and the effect of ventilation interventions on potential exposure.</data>
      <data key="d3">0.9</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="VEHICLE_SPEED_30_KM_H">
      <data key="d0">VEHICLE_SPEED_30_KM_H</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Operational movement parameter used in the stop-and-go test: bus repeatedly moved 500 m at 30 km/h. Influences aerodynamic ventilation and contributes to measured ACH differences between moving and stationary conditions.</data>
      <data key="d3">0.6</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="DOOR_OPENING_20_S">
      <data key="d0">DOOR_OPENING_20_S</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Transient ventilation event in the stop-and-go protocol where the bus door was opened for 20 seconds at each stop. Represents episodic exchange events (boarding/alighting) that increase short-term air exchange and influence particle/CO2 clearance.</data>
      <data key="d3">0.6</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="OCCUPANCY_75_MANNEQUINS">
      <data key="d0">OCCUPANCY_75_MANNEQUINS</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Simulated passenger load used in tests representing 75 occupants (mannequins). Alters internal mixing and source strength for exhaled-like emissions and modifies ACH effects relative to empty-bus conditions.</data>
      <data key="d3">0.72</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="STOP_AND_GO_TEST_TSUKUBA">
      <data key="d0">STOP_AND_GO_TEST_TSUKUBA</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Experimental measurement campaign conducted at Tsukuba that quantified ACH, indoor CO2, and particle concentrations under defined conditions (windows open vs closed, 75 mannequins vs none, moving at specified speeds, and repeated stop-and-go cycles with door openings). Provides the empirical data used to validate ventilation effects reported in the figures.</data>
      <data key="d3">0.97</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="COMMUTER_BUS_INTERIOR">
      <data key="d0">COMMUTER_BUS_INTERIOR</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Enclosed physical environment under study (interior of the commuter bus) where ventilation interventions, monitoring, and measurements were performed. Represented schematically in figure captions showing sensor and emission locations, seating, and window positions.</data>
      <data key="d3">0.85</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="AIR CHANGES PER HOUR (ACH) IN BUS">
      <data key="d0">AIR CHANGES PER HOUR (ACH) IN BUS</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Ventilation rate measured in the bus experiments (air changes per hour). Reported for multiple configurations (with/without mannequins, different window openings) and in both stationary and moving tests.</data>
      <data key="d3">0.9</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="VENTILATION FAN OPERATION">
      <data key="d0">VENTILATION FAN OPERATION</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Operation of the bus ventilation fans (general control). Figures describe effects of turning fans on/off and configurations labelled F (front) and R (rear).</data>
      <data key="d3">0.9</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="OPEN WINDOWS (WINDOW-OPENING CONFIGURATIONS)">
      <data key="d0">OPEN WINDOWS (WINDOW-OPENING CONFIGURATIONS)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Different numbers and specific combinations of open windows studied (e.g., right front + left rear, etc.) as a passive ventilation control affecting ACH and exposure.</data>
      <data key="d3">0.85</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="FRONT VENTILATION FAN (F)">
      <data key="d0">FRONT VENTILATION FAN (F)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">The front-mounted ventilation fan (denoted F in figures). Studied separately and in combination with rear fan to evaluate effect on ACH and exposure.</data>
      <data key="d3">0.65</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="REAR VENTILATION FAN (R)">
      <data key="d0">REAR VENTILATION FAN (R)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">The rear-mounted ventilation fan (denoted R in figures). Studied separately and in combination with front fan to evaluate effect on ACH and exposure.</data>
      <data key="d3">0.65</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="INHALATION VOLUME OF CO2 RELATIVE TO EMITTED VOLUME">
      <data key="d0">INHALATION VOLUME OF CO2 RELATIVE TO EMITTED VOLUME</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Fraction or volume of CO2 inhaled by occupants relative to the volume emitted at a source location in the bus; reported for different source positions and test conditions (used as a proxy for exposure).</data>
      <data key="d3">0.9</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="STATIONARY TESTS WITH MANNEQUINS (CAR BARN, FUJISAWA)">
      <data key="d0">STATIONARY TESTS WITH MANNEQUINS (CAR BARN, FUJISAWA)</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Controlled stationary experiments conducted in the car barn at the Fujisawa plant using mannequins to measure ACH and inhalation CO2 under defined window/fan configurations.</data>
      <data key="d3">0.75</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="STATIONARY TESTS WITHOUT MANNEQUINS">
      <data key="d0">STATIONARY TESTS WITHOUT MANNEQUINS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Stationary ACH measurements conducted without mannequins (used to evaluate ventilation effects of window-opening configurations and fan operation).</data>
      <data key="d3">0.6</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="MOVING TESTS OUTDOORS (TSUKUBA)">
      <data key="d0">MOVING TESTS OUTDOORS (TSUKUBA)</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Moving-bus experiments performed outdoors at Tsukuba to assess ACH and ventilation behavior under operational conditions without mannequins.</data>
      <data key="d3">0.6</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="AC (AIR CONDITIONING)">
      <data key="d0">AC (AIR CONDITIONING)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Vehicle HVAC/air-conditioning system in the bus tests. Modeled as ON vs OFF; affects airflow patterns, dilution/recirculation and (if filtered) particle removal.</data>
      <data key="d3">0.92</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="WINDOWS OPEN">
      <data key="d0">WINDOWS OPEN</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Natural-ventilation state with bus windows opened to increase outdoor air exchange and cross-ventilation.</data>
      <data key="d3">0.96</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="FAN OFF">
      <data key="d0">FAN OFF</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Internal mechanical fans turned off (low-mixing baseline) used in stationary-bus tests.</data>
      <data key="d3">0.68</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="FAN SUPPLY (FRONT) &amp; EXHAUST (REAR)">
      <data key="d0">FAN SUPPLY (FRONT) &amp; EXHAUST (REAR)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Mechanical configuration with a supply fan at the front and exhaust fan at the rear to create directed front-to-rear through-flow.</data>
      <data key="d3">0.93</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="FAN SUPPLY (FRONT) &amp; SUPPLY (REAR)">
      <data key="d0">FAN SUPPLY (FRONT) &amp; SUPPLY (REAR)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Mechanical configuration with supply fans at both front and rear (no dedicated exhaust) resulting in different mixing/recirculation patterns than supply-exhaust.</data>
      <data key="d3">0.8</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="PATHOGEN-LADEN DROPLETS">
      <data key="d0">PATHOGEN-LADEN DROPLETS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Respiratory droplets/droplet nuclei capable of carrying infectious agents; represented implicitly by measured particle concentrations in the experiments.</data>
      <data key="d3">0.89</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="PARTICLES (P_PARTICLES)">
      <data key="d0">PARTICLES (P_PARTICLES)</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Aerosol particle concentrations measured at multiple bus positions (P_particles) used as a surrogate for pathogen-laden aerosols in exposure analyses.</data>
      <data key="d3">0.86</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="P_CO2 (INHALATION VOLUME OF CO2)">
      <data key="d0">P_CO2 (INHALATION VOLUME OF CO2)</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Measured inhalation volume or tracer-derived CO2 at indicated positions (P_CO2); used as a proxy for rebreathed air fraction and potential aerosol exposure.</data>
      <data key="d3">0.88</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="NORMALIZED EXPOSURE DATA">
      <data key="d0">NORMALIZED EXPOSURE DATA</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Dimensionless/relative particle-exposure metrics reported across bus scenarios (used to compare configurations A–D in the study).</data>
      <data key="d3">0.91</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="PMID 35347782">
      <data key="d0">PMID 35347782</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Primary PMC/PubMed study reporting moving-mannequin and stationary-bus experiments comparing AC on/off, windows open/closed and fan configurations with measured P_CO2 and P_particles (figures 7–9).</data>
      <data key="d3">0.99</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="PMID 37121320">
      <data key="d0">PMID 37121320</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Related Sci Total Environ. 2023 study (coach-bus natural ventilation) cited as corroborative evidence on window-opening and ventilation design effects.</data>
      <data key="d3">0.82</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="CITY BUS">
      <data key="d0">CITY BUS</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Transit vehicle test environment (stationary and moving city/coach bus) where ventilation controls and tracer/particle measurements were performed.</data>
      <data key="d3">0.94</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="HOSPITAL LIFT">
      <data key="d0">HOSPITAL LIFT</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">A small-volume enclosed elevator in a healthcare facility where rapid accumulation of exhaled CO2 and respiratory droplets/aerosols can occur, making ventilation and airflow patterns critical to exposure outcomes.</data>
      <data key="d3">0.75</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="PERFORMANCE OF CO2 ACCUMULATION AND DROPLET DISPERSION FROM A COUGH INSIDE A HOSPITAL LIFT UNDER DIFFERENT VENTILATION STRATEGIES">
      <data key="d0">PERFORMANCE OF CO2 ACCUMULATION AND DROPLET DISPERSION FROM A COUGH INSIDE A HOSPITAL LIFT UNDER DIFFERENT VENTILATION STRATEGIES</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Empirical and/or computational study (Sci Rep. 2024) that evaluates CO2 accumulation and cough-generated droplet/aerosol dispersion in a hospital elevator under varied ventilation configurations to quantify how ventilation alters tracer and particle behavior.</data>
      <data key="d3">0.85</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="MULTI-SCALE RISK ASSESSMENT AND MITIGATIONS COMPARISON FOR COVID-19 IN URBAN PUBLIC TRANSPORT: A COMBINED FIELD MEASUREMENT AND MODELING APPROACH">
      <data key="d0">MULTI-SCALE RISK ASSESSMENT AND MITIGATIONS COMPARISON FOR COVID-19 IN URBAN PUBLIC TRANSPORT: A COMBINED FIELD MEASUREMENT AND MODELING APPROACH</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Field measurements combined with modeling (Build Environ. 2023) to assess COVID-19 exposure risks across scales in urban public transport and compare mitigation options including ventilation.</data>
      <data key="d3">0.78</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="SPATIAL DISTRIBUTIONS OF AIRBORNE TRANSMISSION RISK ON COMMUTER BUSES: NUMERICAL CASE STUDY USING COMPUTATIONAL FLUID AND PARTICLE DYNAMICS WITH COMPUTER-SIMULATED PERSONS">
      <data key="d0">SPATIAL DISTRIBUTIONS OF AIRBORNE TRANSMISSION RISK ON COMMUTER BUSES: NUMERICAL CASE STUDY USING COMPUTATIONAL FLUID AND PARTICLE DYNAMICS WITH COMPUTER-SIMULATED PERSONS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">CFD and particle-dynamics numerical case study (Exp Comput Multiph Flow. 2023) mapping spatial patterns of aerosol transport and transmission risk inside commuter buses using simulated occupants and emissions.</data>
      <data key="d3">0.76</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="COVID-19 TRANSMISSION AND CONTROL IN LAND PUBLIC TRANSPORT: A LITERATURE REVIEW">
      <data key="d0">COVID-19 TRANSMISSION AND CONTROL IN LAND PUBLIC TRANSPORT: A LITERATURE REVIEW</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A literature review (Fundam Res. 2023/2024) synthesizing evidence on transmission dynamics and control measures, including ventilation, for COVID-19 in land-based public transport.</data>
      <data key="d3">0.7</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="WIND VELOCITY AND DISPERSION/ADVECTION-DIFFUSION OF ARTIFICIAL DROPLETS AND DROPLET NUCLEI IN A DOMED ALL-WEATHER MULTI-PURPOSE STADIUM">
      <data key="d0">WIND VELOCITY AND DISPERSION/ADVECTION-DIFFUSION OF ARTIFICIAL DROPLETS AND DROPLET NUCLEI IN A DOMED ALL-WEATHER MULTI-PURPOSE STADIUM</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Study (Sci Rep. 2024) investigating wind-driven advection-diffusion and dispersion of artificial droplets/nuclei in a large domed stadium to characterize large-venue airflow effects on particle transport.</data>
      <data key="d3">0.6</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="CO2 ACCUMULATION">
      <data key="d0">CO2 ACCUMULATION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Accumulation of CO2 as a tracer for rebreathed air fraction and ventilation effectiveness; used as a proxy indicator of dilution of exhaled breath and potential airborne infection exposure.</data>
      <data key="d3">0.82</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="DROPLET DISPERSION">
      <data key="d0">DROPLET DISPERSION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Spatial and temporal distribution of respiratory droplets/aerosols after emission (e.g., from a cough), including concentration gradients and residence time that determine exposure risk.</data>
      <data key="d3">0.88</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="COUGH EMISSION">
      <data key="d0">COUGH EMISSION</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">The source term representing emission rate, size distribution, momentum, and initial concentration of droplets/aerosols generated by a cough; used in experiments and models as the contaminant source.</data>
      <data key="d3">0.8</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="SARS-COV-2 / COVID-19">
      <data key="d0">SARS-COV-2 / COVID-19</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Severe acute respiratory syndrome coronavirus 2 (SARS-CoV-2), the respiratory virus responsible for the COVID-19 pandemic. In the text this pathogen is the central public-health target of the cited reports and the Scientific Reports study.</data>
      <data key="d3">0.95</data>
