      <data key="d8">COMPLIANCE RATE (OPERATION AND MAINTENANCE ADHERENCE)</data>
      <data key="d9">HAS_COMPLIANCE</data>
      <data key="d10">The real-world effectiveness of controls depends on compliance rates for proper operation and maintenance.</data>
      <data key="d11">0.6</data>
      <data key="d12">2</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
