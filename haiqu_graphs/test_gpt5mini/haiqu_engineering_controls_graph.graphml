      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="EFFECTIVENESS MEASURES (E.G., REDUCTION IN AIRBORNE CONCENTRATION, INFECTION RISK)" target="PUBMED PMID 32218911">
      <data key="d7">EFFECTIVENESS MEASURES (E.G., REDUCTION IN AIRBORNE CONCENTRATION, INFECTION RISK)</data>
      <data key="d8">PUBMED PMID 32218911</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">Effectiveness measures reported (or expected) for controls can be validated by the cited study; the article may contain quantitative reductions or risk estimates that substantiate these measures.</data>
      <data key="d11">0.8</data>
      <data key="d12">2</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="DOSE OR RATE PARAMETERS (E.G., AIR CHANGES PER HOUR, FLOW RATES)" target="PUBMED PMID 32218911">
      <data key="d7">DOSE OR RATE PARAMETERS (E.G., AIR CHANGES PER HOUR, FLOW RATES)</data>
      <data key="d8">PUBMED PMID 32218911</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">Operational dose/rate parameters (e.g., ACH, UV dose) that define control intensity may be reported or supported by the PubMed study.</data>
      <data key="d11">0.7</data>
      <data key="d12">2</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION SYSTEM DESIGN" target="ISOLATION ROOM">
      <data key="d7">VENTILATION SYSTEM DESIGN</data>
      <data key="d8">ISOLATION ROOM</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Ventilation system design is implemented in isolation rooms to control airborne contaminant transport by configuring supply/exhaust placement and flow patterns.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION SYSTEM DESIGN" target="AIRBORNE INFECTIOUS DISEASE AGENTS">
      <data key="d7">VENTILATION SYSTEM DESIGN</data>
      <data key="d8">AIRBORNE INFECTIOUS DISEASE AGENTS</data>
      <data key="d9">TARGETS</data>
      <data key="d10">Ventilation system design targets airborne infectious agents by modifying transport pathways and removal points to lower occupant exposure. | Optimized ventilation system design reduces exposure to airborne infectious agents by channeling contaminants to exhaust and lowering residence time in breathing zones.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION SYSTEM DESIGN" target="AIR CHANGES PER HOUR (ACH)">
      <data key="d7">VENTILATION SYSTEM DESIGN</data>
      <data key="d8">AIR CHANGES PER HOUR (ACH)</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Ventilation system design is characterized in part by ACH as an operational metric that quantifies volumetric exchange target for the design. | Design choices complement ACH targets by ensuring the quantitative exchange capacity is delivered through beneficial flow paths to improve ventilation effectiveness.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION SYSTEM DESIGN" target="COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS">
      <data key="d7">VENTILATION SYSTEM DESIGN</data>
      <data key="d8">COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">Design recommendations are supported by the CFD analysis which simulates airflow and particle paths to assess control performance.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION SYSTEM DESIGN" target="COST OF NOSOCOMIAL INFECTIONS $4-5 BILLION ANNUALLY">
      <data key="d7">VENTILATION SYSTEM DESIGN</data>
      <data key="d8">COST OF NOSOCOMIAL INFECTIONS $4-5 BILLION ANNUALLY</data>
      <data key="d9">INCURS_COST</data>
      <data key="d10">The national cost burden of nosocomial infections provides economic motivation for ventilation design; optimized design is framed as having potential to reduce this aggregate cost.</data>
      <data key="d11">0.6</data>
      <data key="d12">2</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION SYSTEM DESIGN" target="SITE-SPECIFIC RISK ANALYSIS">
      <data key="d7">VENTILATION SYSTEM DESIGN</data>
      <data key="d8">SITE-SPECIFIC RISK ANALYSIS</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">Ventilation system design decisions are informed and validated by site-specific risk analysis to tailor controls to room-specific hazards and conditions.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION SYSTEM DESIGN" target="PARTICLE TRANSPORT MECHANISM">
      <data key="d7">VENTILATION SYSTEM DESIGN</data>
      <data key="d8">PARTICLE TRANSPORT MECHANISM</data>
      <data key="d9">TARGETS</data>
      <data key="d10">Ventilation design targets the particle transport mechanism by altering flows and placement to change trajectories and residence times of particles.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION SYSTEM DESIGN" target="INFECTION RISK">
      <data key="d7">VENTILATION SYSTEM DESIGN</data>
      <data key="d8">INFECTION RISK</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Optimized ventilation design is intended to reduce infection risk by lowering occupant exposure to infectious aerosols via improved transport and removal.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="UNINTERRUPTED SOURCE-TO-EXHAUST AIRFLOW PATH" target="ISOLATION ROOM">
      <data key="d7">UNINTERRUPTED SOURCE-TO-EXHAUST AIRFLOW PATH</data>
      <data key="d8">ISOLATION ROOM</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">The uninterrupted source-to-exhaust airflow path is an applied control within isolation rooms to channel emissions directly to exhaust and minimize exposure of occupants.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="UNINTERRUPTED SOURCE-TO-EXHAUST AIRFLOW PATH" target="AIRBORNE INFECTIOUS DISEASE AGENTS">
      <data key="d7">UNINTERRUPTED SOURCE-TO-EXHAUST AIRFLOW PATH</data>
      <data key="d8">AIRBORNE INFECTIOUS DISEASE AGENTS</data>
      <data key="d9">TARGETS</data>
      <data key="d10">An uninterrupted source-to-exhaust airflow path targets airborne infectious agents by directing emitted particles to exhaust before they disperse into occupied zones.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="UNINTERRUPTED SOURCE-TO-EXHAUST AIRFLOW PATH" target="COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS">
      <data key="d7">UNINTERRUPTED SOURCE-TO-EXHAUST AIRFLOW PATH</data>
      <data key="d8">COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The role of a direct source-to-exhaust path is supported by CFD simulations that showed particle trajectories and transport dominance by pathing.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="UNINTERRUPTED SOURCE-TO-EXHAUST AIRFLOW PATH" target="INCREASING VENTILATION AIRFLOW RATE">
      <data key="d7">UNINTERRUPTED SOURCE-TO-EXHAUST AIRFLOW PATH</data>
      <data key="d8">INCREASING VENTILATION AIRFLOW RATE</data>
      <data key="d9">OUTPERFORMS</data>
      <data key="d10">The direct source-to-exhaust airflow path is hypothesized (CFD-supported) to outperform simply increasing airflow rate for reducing local exposure when pathing issues would otherwise cause short-circuiting or recirculation.</data>
      <data key="d11">0.88</data>
      <data key="d12">2</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="INCREASING VENTILATION AIRFLOW RATE" target="ISOLATION ROOM">
      <data key="d7">INCREASING VENTILATION AIRFLOW RATE</data>
      <data key="d8">ISOLATION ROOM</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Raising ventilation airflow rate is an operational option applied to isolation rooms to increase dilution of airborne contaminants.</data>
      <data key="d11">0.75</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="INCREASING VENTILATION AIRFLOW RATE" target="AIRBORNE INFECTIOUS DISEASE AGENTS">
      <data key="d7">INCREASING VENTILATION AIRFLOW RATE</data>
      <data key="d8">AIRBORNE INFECTIOUS DISEASE AGENTS</data>
      <data key="d9">TARGETS</data>
      <data key="d10">Increasing ventilation airflow rate targets airborne infectious agents through enhanced dilution and increased removal of room air.</data>
      <data key="d11">0.75</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="INCREASING VENTILATION AIRFLOW RATE" target="VENTILATION AIRFLOW RATE">
      <data key="d7">INCREASING VENTILATION AIRFLOW RATE</data>
      <data key="d8">VENTILATION AIRFLOW RATE</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Increasing ventilation airflow rate is operationalized by raising the volumetric ventilation airflow rate (e.g., CFM, m3/h).</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="INCREASING VENTILATION AIRFLOW RATE" target="AIR CHANGES PER HOUR (ACH)">
      <data key="d7">INCREASING VENTILATION AIRFLOW RATE</data>
      <data key="d8">AIR CHANGES PER HOUR (ACH)</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Increasing ventilation airflow rate is expressed quantitatively as an increase in ACH (room air volume replacements per hour).</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="INCREASING VENTILATION AIRFLOW RATE" target="EXTENSIVE LITERATURE REVIEW">
      <data key="d7">INCREASING VENTILATION AIRFLOW RATE</data>
      <data key="d8">EXTENSIVE LITERATURE REVIEW</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The benefits and limitations of increasing ventilation airflow rate are described and contextualized in the extensive literature review.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="INCREASING VENTILATION AIRFLOW RATE" target="INFECTION RISK">
      <data key="d7">INCREASING VENTILATION AIRFLOW RATE</data>
      <data key="d8">INFECTION RISK</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Increasing airflow rate can reduce infection risk by diluting airborne contaminants and lowering steady-state concentrations for continuous sources, though impact may be limited by flow pathing.</data>
      <data key="d11">0.7</data>
      <data key="d12">2</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="AIR CHANGES PER HOUR (ACH)" target="AIRBORNE PATHOGEN">
      <data key="d7">AIR CHANGES PER HOUR (ACH)</data>
      <data key="d8">AIRBORNE PATHOGEN</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Higher ACH increases dilution and air replacement, thereby reducing steady-state airborne pathogen concentrations and lowering exposure risk; the magnitude of reduction depends on ACH value, room volume, source strength and filtration.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="AIR CHANGES PER HOUR (ACH)" target="AIRBORNE CONCENTRATION REDUCTION">
      <data key="d7">AIR CHANGES PER HOUR (ACH)</data>
      <data key="d8">AIRBORNE CONCENTRATION REDUCTION</data>
      <data key="d9">REDUCES</data>
      <data key="d10">ACH is directly tied to the measurable effectiveness outcome of airborne concentration reduction; increasing ACH is expected to produce greater reductions in airborne contaminant levels, all else equal.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_6</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="SITE-SPECIFIC RISK ANALYSIS" target="ISOLATION ROOM">
      <data key="d7">SITE-SPECIFIC RISK ANALYSIS</data>
      <data key="d8">ISOLATION ROOM</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Site-specific risk analyses are performed for a given isolation room to identify risks and guide design choices (supply/exhaust placement, controls).</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="VENTILATION EFFECTIVENESS" target="AIR CHANGES PER HOUR (ACH)">
      <data key="d7">VENTILATION EFFECTIVENESS</data>
      <data key="d8">AIR CHANGES PER HOUR (ACH)</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Ventilation effectiveness is partly quantified by ACH as a dose/rate metric, but effectiveness also depends on flow-path quality and local transport.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="PARTICLE TRANSPORT MECHANISM" target="COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS">
      <data key="d7">PARTICLE TRANSPORT MECHANISM</data>
      <data key="d8">COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">CFD analysis validates and elucidates particle transport mechanisms by resolving airflow and particle trajectories under specified conditions.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="EXPOSURE-TO-INFECTION RELATIONSHIP" target="EXTENSIVE LITERATURE REVIEW">
      <data key="d7">EXPOSURE-TO-INFECTION RELATIONSHIP</data>
      <data key="d8">EXTENSIVE LITERATURE REVIEW</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The literature review documents evidence that exposure does not always lead to infection and summarizes dose–response considerations.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
    <edge source="EXPOSURE-TO-INFECTION RELATIONSHIP" target="INFECTION RISK">
      <data key="d7">EXPOSURE-TO-INFECTION RELATIONSHIP</data>
      <data key="d8">INFECTION RISK</data>
      <data key="d9">TARGETS</data>
      <data key="d10">The exposure-to-infection relationship describes how exposure magnitude and duration influence infection risk and is central to interpreting control benefits.</data>
      <data key="d11">0.75</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
