      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The Seppänen &amp; Fisk (2004) review synthesizes evidence linking ventilation rates and patterns to human comfort and perceived air quality, which can affect behavior and exposure.</data>
      <data key="d11">0.7</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
