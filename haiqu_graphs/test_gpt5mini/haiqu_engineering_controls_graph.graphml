      <data key="d7">ENGINEERING CONTROLS FOR AIRBORNE PATHOGENS</data>
      <data key="d8">ADVERSE EFFECTS (E.G., NOISE, DRAFTS, OZONE)</data>
      <data key="d9">HAS_ADVERSE_EFFECT</data>
      <data key="d10">Engineering controls may produce adverse effects (comfort issues, byproducts) that should be assessed alongside benefits.</data>
      <data key="d11">0.45</data>
      <data key="d12">3</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_1</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
