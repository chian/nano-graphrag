      <data key="d10">Choosing to send alerts when there are no new results reduces perceived relevance of alerts for users.</data>
      <data key="d11">0.6</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_1</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS OPEN (GENERAL)" target="ACH (AIR EXCHANGE RATE)">
      <data key="d7">WINDOWS OPEN (GENERAL)</data>
      <data key="d8">ACH (AIR EXCHANGE RATE)</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Opening windows increases ACH; more windows open increases ACH and thereby improves ventilation.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS OPEN (GENERAL)" target="SARS-COV-2">
      <data key="d7">WINDOWS OPEN (GENERAL)</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Windows-open control reduces airborne SARS-CoV-2 transmission risk (study reported a 92% average infection-risk reduction when moving with windows open vs closed).</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="TWO WINDOWS OPEN - FRONT + REAR" target="ACH (AIR EXCHANGE RATE)">
      <data key="d7">TWO WINDOWS OPEN - FRONT + REAR</data>
      <data key="d8">ACH (AIR EXCHANGE RATE)</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Front+rear window configuration increases ACH compared with closed windows and compared to some other window configurations.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="TWO WINDOWS OPEN - FRONT + REAR" target="TWO WINDOWS OPEN - FRONT + REAR">
      <data key="d7">TWO WINDOWS OPEN - FRONT + REAR</data>
      <data key="d8">TWO WINDOWS OPEN - TWO REAR</data>
      <data key="d9">OUTPERFORMS</data>
      <data key="d10">The front+rear window configuration produced greater ACH than the two-rear-window configuration.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="VENTILATION FANS SET TO EXHAUST (FRONT AND REAR)" target="ACH (AIR EXCHANGE RATE)">
      <data key="d7">VENTILATION FANS SET TO EXHAUST (FRONT AND REAR)</data>
      <data key="d8">ACH (AIR EXCHANGE RATE)</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Setting both fans to exhaust more than doubled ACH relative to having both set to supply.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="VENTILATION FANS SET TO EXHAUST (FRONT AND REAR)" target="VENTILATION FANS SET TO EXHAUST (FRONT AND REAR)">
      <data key="d7">VENTILATION FANS SET TO EXHAUST (FRONT AND REAR)</data>
      <data key="d8">VENTILATION FANS SET TO SUPPLY (FRONT AND REAR)</data>
      <data key="d9">OUTPERFORMS</data>
      <data key="d10">Exhaust-mode operation outperformed supply-mode operation in increasing ACH (reported &gt;2x ACH).</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="VENTILATION FANS SET TO EXHAUST (FRONT AND REAR)" target="SARS-COV-2">
      <data key="d7">VENTILATION FANS SET TO EXHAUST (FRONT AND REAR)</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Operating fans in exhaust mode reduced average SARS-CoV-2 infection risk (study reported a 35% reduction when moving with windows closed and fans exhaust).</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="ACH (AIR EXCHANGE RATE)" target="SARS-COV-2">
      <data key="d7">ACH (AIR EXCHANGE RATE)</data>
      <data key="d8">SARS-COV-2</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Higher ACH reduces airborne concentration and thus exposure risk to SARS-CoV-2 (mechanism by which window opening and exhaust fans reduce infection risk).</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="ACH (AIR EXCHANGE RATE)" target="PARTICLE SPREAD RATE">
      <data key="d7">ACH (AIR EXCHANGE RATE)</data>
      <data key="d8">PARTICLE SPREAD RATE</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Higher ACH tends to reduce the airborne particle concentration and spread rate (mechanism linking ventilation to lower particle exposure).</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="ACH (AIR EXCHANGE RATE)" target="CO2 SPREAD RATE">
      <data key="d7">ACH (AIR EXCHANGE RATE)</data>
      <data key="d8">CO2 SPREAD RATE</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Higher ACH reduces CO2 (tracer gas) concentration and spread from a source, reflecting improved ventilation.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="CO2 SPREAD RATE" target="PARTICLE SPREAD RATE">
      <data key="d7">CO2 SPREAD RATE</data>
      <data key="d8">PARTICLE SPREAD RATE</data>
      <data key="d9">COMPLEMENTS</data>
      <data key="d10">When AC was off, CO2 and particle spread rates were observed to be proportional (CO2 used as a tracer for particle transport).</data>
      <data key="d11">0.65</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="INFECTION RISK REDUCTION - 92% (WINDOWS OPEN VS CLOSED)" target="MODIFIED WELLS-RILEY CALCULATION (VALIDATION STUDY)">
      <data key="d7">INFECTION RISK REDUCTION - 92% (WINDOWS OPEN VS CLOSED)</data>
      <data key="d8">MODIFIED WELLS-RILEY CALCULATION (VALIDATION STUDY)</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The 92% infection-risk reduction estimate was derived from and validated by the study's modified Wells–Riley calculations.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="INFECTION RISK REDUCTION - 35% (EXHAUST FANS VS SUPPLY, WINDOWS CLOSED)" target="MODIFIED WELLS-RILEY CALCULATION (VALIDATION STUDY)">
      <data key="d7">INFECTION RISK REDUCTION - 35% (EXHAUST FANS VS SUPPLY, WINDOWS CLOSED)</data>
      <data key="d8">MODIFIED WELLS-RILEY CALCULATION (VALIDATION STUDY)</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">The 35% infection-risk reduction estimate for exhaust fan operation (with windows closed) was derived from the study's modified Wells–Riley calculations.</data>
      <data key="d11">0.85</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_2</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="OPENING_WINDOWS" target="COMMUTER_BUS_INTERIOR">
      <data key="d7">OPENING_WINDOWS</data>
      <data key="d8">COMMUTER_BUS_INTERIOR</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Opening windows is an intervention applied to the commuter bus interior to modify ventilation pathways and increase exchange with outdoor air.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="OPENING_WINDOWS" target="ACH">
      <data key="d7">OPENING_WINDOWS</data>
      <data key="d8">ACH</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">Window-opening is a manipulable parameter that changes the effective ventilation rate (ACH); experiments compared specific window-opening states (e.g., 5 windows fully opened) to quantify ACH differences.</data>
      <data key="d11">0.93</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="OPENING_WINDOWS" target="AEROSOL_PARTICLE_CONCENTRATION">
      <data key="d7">OPENING_WINDOWS</data>
      <data key="d8">AEROSOL_PARTICLE_CONCENTRATION</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Opening windows increases air exchange and airflow, which reduces interior aerosol particle concentrations by dilution and enhanced removal compared with closed-window conditions (effect observed in Tsukuba tests).</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="OPENING_WINDOWS" target="INDOOR_CO2_CONCENTRATION">
      <data key="d7">OPENING_WINDOWS</data>
      <data key="d8">INDOOR_CO2_CONCENTRATION</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Opening windows lowers accumulation of occupant-derived CO2 by increasing dilution and exchange with outdoor air, as shown by CO2 traces reported in the experiments.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS_CLOSED" target="COMMUTER_BUS_INTERIOR">
      <data key="d7">WINDOWS_CLOSED</data>
      <data key="d8">COMMUTER_BUS_INTERIOR</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Closed-window condition applied to the commuter bus interior serving as the baseline comparator in measured scenarios.</data>
      <data key="d11">0.75</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS_CLOSED" target="INDOOR_CO2_CONCENTRATION">
      <data key="d7">WINDOWS_CLOSED</data>
      <data key="d8">INDOOR_CO2_CONCENTRATION</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">The closed-window condition is a baseline parameter associated with higher indoor CO2 accumulation (relative to windows-open) in the experimental design; used to quantify contrasts in ventilation effectiveness.</data>
      <data key="d11">0.7</data>
      <data key="d12">2</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="WINDOWS_CLOSED" target="CITY BUS">
      <data key="d7">WINDOWS CLOSED</data>
      <data key="d8">CITY BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Closed-window baseline scenarios were used in the bus tests to represent limited natural ventilation.</data>
      <data key="d11">0.82</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_5</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="CO2_MONITORING" target="STOP_AND_GO_TEST_TSUKUBA">
      <data key="d7">CO2_MONITORING</data>
      <data key="d8">STOP_AND_GO_TEST_TSUKUBA</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">CO2 monitoring measurements were collected and reported as part of the Tsukuba stop-and-go test to validate ventilation performance and infer occupant-exhaled air accumulation.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="CO2_MONITORING" target="PARTICLE_MONITORING">
      <data key="d7">CO2_MONITORING</data>
      <data key="d8">PARTICLE_MONITORING</data>
      <data key="d9">COMPLEMENTS</data>
      <data key="d10">CO2 monitoring complements particle monitoring by providing an orthogonal tracer of ventilation (proxy for exhaled breath) while particle monitoring directly measures aerosol concentrations; their combined use strengthens interpretation of ventilation effectiveness and exposure risk.</data>
      <data key="d11">0.78</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="PARTICLE_MONITORING" target="STOP_AND_GO_TEST_TSUKUBA">
      <data key="d7">PARTICLE_MONITORING</data>
      <data key="d8">STOP_AND_GO_TEST_TSUKUBA</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">Particle monitoring instrumentation and measurements were part of the Tsukuba campaign, validating aerosol emission and concentration dynamics under the tested ventilation and occupancy scenarios.</data>
      <data key="d11">0.86</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="ACH" target="STOP_AND_GO_TEST_TSUKUBA">
      <data key="d7">ACH</data>
      <data key="d8">STOP_AND_GO_TEST_TSUKUBA</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">Measured ACH values reported in the figures were derived from the Tsukuba stop-and-go experimental measurements under multiple occupancy, window, and speed conditions.</data>
      <data key="d11">0.96</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="ACH" target="AEROSOL_PARTICLE_CONCENTRATION">
      <data key="d7">ACH</data>
      <data key="d8">AEROSOL_PARTICLE_CONCENTRATION</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Higher ACH (faster air replacement) reduces steady-state aerosol particle concentrations in the bus interior by increasing dilution and removal rates, a primary mechanism linking ventilation to exposure reduction.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="STOP_AND_GO_TEST_TSUKUBA" target="VEHICLE_SPEED_30_KM_H">
      <data key="d7">STOP_AND_GO_TEST_TSUKUBA</data>
      <data key="d8">VEHICLE_SPEED_30_KM_H</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">The Tsukuba stop-and-go test protocol included a movement parameter of 30 km/h (bus moved 500 m at this speed) as an operational dose that affects aerodynamic ventilation and measured ACH.</data>
      <data key="d11">0.72</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="STOP_AND_GO_TEST_TSUKUBA" target="DOOR_OPENING_20_S">
      <data key="d7">STOP_AND_GO_TEST_TSUKUBA</data>
      <data key="d8">DOOR_OPENING_20_S</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">The Tsukuba protocol specified repeated door-opening events lasting 20 seconds per stop; this transient dosing parameter contributes to episodic increases in ventilation and particle/CO2 clearance.</data>
      <data key="d11">0.72</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="STOP_AND_GO_TEST_TSUKUBA" target="OCCUPANCY_75_MANNEQUINS">
      <data key="d7">STOP_AND_GO_TEST_TSUKUBA</data>
      <data key="d8">OCCUPANCY_75_MANNEQUINS</data>
      <data key="d9">HAS_DOSE</data>
      <data key="d10">The validation study included experimental scenarios with 75 mannequins (simulated occupancy) as a dose parameter to assess how occupancy alters ACH effects, CO2 build-up, and particle dynamics compared with empty-bus conditions.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="STOP_AND_GO_TEST_TSUKUBA" target="COMMUTER_BUS_INTERIOR">
      <data key="d7">STOP_AND_GO_TEST_TSUKUBA</data>
      <data key="d8">COMMUTER_BUS_INTERIOR</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">The stop-and-go measurement campaign was conducted in the commuter bus interior; the study applied experimental protocols and measurements to this enclosed space to derive ACH and concentration data.</data>
      <data key="d11">0.95</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_3</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="AIR CHANGES PER HOUR (ACH) IN BUS" target="STATIONARY TESTS WITHOUT MANNEQUINS">
      <data key="d7">AIR CHANGES PER HOUR (ACH) IN BUS</data>
      <data key="d8">STATIONARY TESTS WITHOUT MANNEQUINS</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">ACH measurements in configurations without mannequins were validated/obtained in stationary tests referenced in the figures.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="AIR CHANGES PER HOUR (ACH) IN BUS" target="MOVING TESTS OUTDOORS (TSUKUBA)">
      <data key="d7">AIR CHANGES PER HOUR (ACH) IN BUS</data>
      <data key="d8">MOVING TESTS OUTDOORS (TSUKUBA)</data>
      <data key="d9">VALIDATED_BY</data>
      <data key="d10">ACH behavior under operational conditions was validated/assessed by moving-bus experiments conducted outdoors at Tsukuba.</data>
      <data key="d11">0.8</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </edge>
    <edge source="VENTILATION FAN OPERATION" target="AIR CHANGES PER HOUR (ACH) IN BUS">
      <data key="d7">VENTILATION FAN OPERATION</data>
      <data key="d8">AIR CHANGES PER HOUR (ACH) IN BUS</data>
      <data key="d9">APPLIED_TO</data>
      <data key="d10">Operation of ventilation fans was applied to the ventilation rate (ACH) in the bus experiments; fan operation increased ACH in tested configurations.</data>
      <data key="d11">0.9</data>
      <data key="d12">1</data>
      <data key="d13">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d14">e45568c3-e22e-4830-92f5-64de955e8aee</data>
