      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A figure-referenced study assessing how varying the number and placement of open windows affects ACH in a bus without mannequins, including stationary (Fujisawa) and moving (Tsukuba) conditions.</data>
      <data key="d3">0.71</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
