  <graph edgedefault="directed">
    <node id="VENTILATION SYSTEM DESIGN">
      <data key="d0">VENTILATION SYSTEM DESIGN</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Engineering configuration of room ventilation that prioritizes directing contaminant-laden air from the source to exhaust to enhance removal; can reduce infection risk without necessarily increasing airflow.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CONTROL STRATEGY">
      <data key="d0">CONTROL STRATEGY</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">An operational/engineering approach informed by CFD that manages transport mechanisms and particle paths to keep flow from source to exhaust uninterrupted, thereby limiting exposure.</data>
      <data key="d3">0.82</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INCREASING VENTILATION AIRFLOW RATE">
      <data key="d0">INCREASING VENTILATION AIRFLOW RATE</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A dilution-based control action that raises airflow to increase air changes per hour; improves dilution when emissions are constant but may not improve ventilation effectiveness if flow paths are suboptimal.</data>
      <data key="d3">0.74</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIR CHANGES PER HOUR (ACH)">
      <data key="d0">AIR CHANGES PER HOUR (ACH)</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Ventilation rate metric indicating the number of times room air is replaced per hour; commonly used as a dilution indicator for airborne contaminants.</data>
      <data key="d3">0.82</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2,3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION AIRFLOW RATE">
      <data key="d0">VENTILATION AIRFLOW RATE</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Quantitative airflow supplied/exhausted by the ventilation system; increasing this raises ACH but does not necessarily improve contaminant removal effectiveness.</data>
      <data key="d3">0.62</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE INFECTIOUS DISEASE AGENTS">
      <data key="d0">AIRBORNE INFECTIOUS DISEASE AGENTS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Pathogenic particles/aerosols capable of airborne transmission in indoor environments that the ventilation design and control strategy aim to remove.</data>
      <data key="d3">0.84</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ISOLATION ROOM">
      <data key="d0">ISOLATION ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">An enclosed, mechanically ventilated hospital room used to isolate infectious patients; setting for the optimization of ventilation design and controls.</data>
      <data key="d3">0.86</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS">
      <data key="d0">COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Simulation-based analysis used to examine airflow, transport mechanisms, and particle trajectories to evaluate and inform ventilation control strategies.</data>
      <data key="d3">0.79</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="EXTENSIVE LITERATURE REVIEW">
      <data key="d0">EXTENSIVE LITERATURE REVIEW</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Synthesis of prior evidence indicating that exposure does not always result in infection, supporting emphasis on flow-path control in addition to dilution.</data>
      <data key="d3">0.46</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="SOURCE-TO-EXHAUST FLOW PATH INTEGRITY">
      <data key="d0">SOURCE-TO-EXHAUST FLOW PATH INTEGRITY</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">A measure of how direct and uninterrupted the airflow path is between the contaminant source and the exhaust; hypothesized as the dominant factor in contaminant control in enclosed, mechanically ventilated rooms.</data>
      <data key="d3">0.87</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION EFFECTIVENESS">
      <data key="d0">VENTILATION EFFECTIVENESS</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">The efficiency of a ventilation system in removing contaminants from occupied zones, influenced by flow path configuration and source/exhaust placement beyond simple dilution.</data>
      <data key="d3">0.76</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="NOSOCOMIAL INFECTIONS ANNUAL COST (US$4–5B, U.S.)">
      <data key="d0">NOSOCOMIAL INFECTIONS ANNUAL COST (US$4–5B, U.S.)</data>
      <data key="d1">COST_PROXY</data>
      <data key="d2">Economic burden associated with hospital-acquired infections in the United States, cited as approximately $4–$5 billion per year; serves as a motivation for optimizing ventilation controls.</data>
      <data key="d3">0.7</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="PATH-CONFORMING VENTILATION DESIGN (DIRECT SOURCE-TO-EXHAUST AIRFLOW)">
      <data key="d0">PATH-CONFORMING VENTILATION DESIGN (DIRECT SOURCE-TO-EXHAUST AIRFLOW)</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Ventilation system layout that maintains an uninterrupted airflow path from the contaminant source (e.g., patient) directly to the exhaust, minimizing cross-flow interference per the hypothesized path principle.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIR CHANGE RATE (ACH)">
      <data key="d0">AIR CHANGE RATE (ACH)</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Ventilation flow rate expressed as air changes per hour; higher ACH generally increases removal of airborne contaminants. | The rate of air exchange with outdoor or cleaned air (per hour), a key dose parameter determining dilution of indoor aerosols under different ventilation strategies.</data>
      <data key="d3">0.82</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b,e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">AIR CHANGE RATE (ACH)</data>
    </node>
    <node id="PATIENT ROOM">
      <data key="d0">PATIENT ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Healthcare indoor environment where patient care occurs and ventilation strategies are applied.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COUGH-GENERATED BIOAEROSOLS">
      <data key="d0">COUGH-GENERATED BIOAEROSOLS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Transient respiratory particles produced by coughing that can carry infectious organisms and drive short-term exposure events.</data>
      <data key="d3">0.6</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INFECTION RISK DURING TRANSIENT COUGHING EXPOSURE">
      <data key="d0">INFECTION RISK DURING TRANSIENT COUGHING EXPOSURE</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Probability of infection to nearby occupants during short-duration coughing events in a patient room.</data>
      <data key="d3">0.85</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INCREASED SOURCE-TO-RECEPTOR DISTANCE">
      <data key="d0">INCREASED SOURCE-TO-RECEPTOR DISTANCE</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Spatial separation strategy that increases distance between the contaminant source (patient) and susceptible individuals to reduce exposure.</data>
      <data key="d3">0.65</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CFD-BASED PATIENT ROOM VENTILATION EFFECTIVENESS STUDY (2011)">
      <data key="d0">CFD-BASED PATIENT ROOM VENTILATION EFFECTIVENESS STUDY (2011)</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Computational Fluid Dynamics analysis demonstrating that a direct source-to-exhaust airflow path is a dominant factor for contaminant control, showing that distancing reduces risk and that the effect is more pronounced at higher ACH.</data>
      <data key="d3">0.75</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CONTAMINANT TRANSMISSION">
      <data key="d0">CONTAMINANT TRANSMISSION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Undesired movement of airborne contaminants from source to room occupants before removal by the exhaust.</data>
      <data key="d3">0.6</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="NEGATIVE-PRESSURE ISOLATION ROOM">
      <data key="d0">NEGATIVE-PRESSURE ISOLATION ROOM</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A specialized isolation room designed to maintain lower air pressure than adjacent spaces, driving inward airflow and exhausting contaminated air to contain and remove infectious aerosols in healthcare settings such as emergency departments.</data>
      <data key="d3">0.96</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION CONFIGURATION">
      <data key="d0">VENTILATION CONFIGURATION</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">The arrangement and operation of supply and exhaust terminals, airflow rates, and flow patterns in a room; variations are used to influence aerosol dispersion, dilution, removal, and containment in isolation rooms.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="EMERGENCY DEPARTMENTS">
      <data key="d0">EMERGENCY DEPARTMENTS</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">High-acuity hospital areas with rapid patient turnover and potential aerosol-generating procedures where negative-pressure isolation rooms are deployed to limit airborne transmission.</data>
      <data key="d3">0.7</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="HOSPITAL ISOLATION ROOM">
      <data key="d0">HOSPITAL ISOLATION ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Dedicated rooms within hospitals used to house and isolate infectious patients; ventilation configurations within these rooms determine aerosol dispersion and removal performance.</data>
      <data key="d3">0.82</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="SARS-COV-2">
      <data key="d0">SARS-COV-2</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">The respiratory virus responsible for COVID-19; aerosol and droplet emissions from infected patients can be mitigated by optimized ventilation and negative-pressure isolation strategies. | Respiratory virus causing COVID-19; risk assessed for airborne transmission within a route bus environment.</data>
      <data key="d3">0.95</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4,3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b,e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">SARS-COV-2</data>
    </node>
    <node id="RESPIRATORY VIRUSES">
      <data key="d0">RESPIRATORY VIRUSES</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">A group of pathogens transmitted via respiratory droplets and aerosols (e.g., influenza viruses, coronaviruses); engineering controls aim to reduce airborne spread in healthcare environments.</data>
      <data key="d3">0.78</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION PERFORMANCE EVALUATION OF A NEGATIVE-PRESSURIZED ISOLATION ROOM FOR EMERGENCY DEPARTMENTS">
      <data key="d0">VENTILATION PERFORMANCE EVALUATION OF A NEGATIVE-PRESSURIZED ISOLATION ROOM FOR EMERGENCY DEPARTMENTS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A 2022 study (Healthcare (Basel)) evaluating ventilation performance of a negative-pressurized isolation room in emergency departments, examining airflow behavior, pressure differentials, and containment relevant to exposure control.</data>
      <data key="d3">0.86</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="BEHAVIOR OF COUGH DROPLETS EMITTED FROM COVID-19 PATIENT IN HOSPITAL ISOLATION ROOM WITH DIFFERENT VENTILATION CONFIGURATIONS">
      <data key="d0">BEHAVIOR OF COUGH DROPLETS EMITTED FROM COVID-19 PATIENT IN HOSPITAL ISOLATION ROOM WITH DIFFERENT VENTILATION CONFIGURATIONS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A 2022 study (Building and Environment) analyzing how varying ventilation configurations in a hospital isolation room affect the transport and fate of cough droplets from a COVID-19 patient, informing control effectiveness.</data>
      <data key="d3">0.86</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="SUMMARY OF HUMAN RESPONSES TO VENTILATION">
      <data key="d0">SUMMARY OF HUMAN RESPONSES TO VENTILATION</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A 2004 review (Indoor Air) summarizing how ventilation rates and patterns influence human exposures and health-related responses, supporting the rationale for optimized ventilation in isolation settings.</data>
      <data key="d3">0.62</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="TRANSMISSIBILITY AND TRANSMISSION OF RESPIRATORY VIRUSES">
      <data key="d0">TRANSMISSIBILITY AND TRANSMISSION OF RESPIRATORY VIRUSES</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A 2021 review (Nature Reviews Microbiology) on mechanisms and determinants of respiratory virus transmission, emphasizing the role of airborne pathways and the importance of airflow management.</data>
      <data key="d3">0.64</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ROOM PRESSURE DIFFERENTIAL">
      <data key="d0">ROOM PRESSURE DIFFERENTIAL</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">The negative pressure magnitude (e.g., Pascals) maintained between an isolation room and adjacent spaces; determines the inward airflow that limits aerosol escape.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AEROSOL CLEARANCE TIME (99% REMOVAL)">
      <data key="d0">AEROSOL CLEARANCE TIME (99% REMOVAL)</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Time required to remove 99% of airborne particles from a room, reflecting how quickly ventilation and airflow patterns clear infectious aerosols.</data>
      <data key="d3">0.76</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CONTAINMENT LEAKAGE FRACTION">
      <data key="d0">CONTAINMENT LEAKAGE FRACTION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">The fraction of contaminants escaping from an isolation room to adjacent areas, indicating the containment performance of pressure and airflow controls.</data>
      <data key="d3">0.75</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE INFECTIOUS AEROSOL CONCENTRATION">
      <data key="d0">AIRBORNE INFECTIOUS AEROSOL CONCENTRATION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">The concentration of pathogen-laden aerosols in room air; a direct indicator of exposure risk influenced by ventilation rates and flow patterns.</data>
      <data key="d3">0.78</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION STRATEGIES IN INPATIENT WARDS">
      <data key="d0">VENTILATION STRATEGIES IN INPATIENT WARDS</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Room- and ward-level ventilation configurations and strategies intended to mitigate airborne dispersion of infectious aerosols in hospital inpatient wards.</data>
      <data key="d3">0.86</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_5</data>
