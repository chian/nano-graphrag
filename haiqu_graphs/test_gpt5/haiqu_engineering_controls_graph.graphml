      <data key="d0">RIGHT FRONT AND LEFT REAR WINDOWS OPEN</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A cross-ventilation window configuration (right-front and left-rear open) used to enhance airflow through the bus and influence resulting ACH. | A rear-focused cross-ventilation configuration (right-rear and left-rear open) that primarily ventilates the aft section and yields a measurable ACH.</data>
      <data key="d3">0.74</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
      <data key="d6">RIGHT REAR AND LEFT REAR WINDOWS OPEN</data>
    </node>
    <node id="VENTILATION FAN OPERATION">
      <data key="d0">VENTILATION FAN OPERATION</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Operating the bus’s ventilation fans increases airflow and mixing, affecting cabin ACH and distribution of aerosols.</data>
      <data key="d3">0.87</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="FRONT VENTILATION FAN">
      <data key="d0">FRONT VENTILATION FAN</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">The front-mounted ventilation fan subsystem that drives airflow from the front of the bus, contributing to overall ACH.</data>
      <data key="d3">0.61</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="REAR VENTILATION FAN">
      <data key="d0">REAR VENTILATION FAN</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">The rear-mounted ventilation fan subsystem that drives airflow from the rear of the bus, contributing to overall ACH.</data>
      <data key="d3">0.61</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="ACH">
      <data key="d0">ACH</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Air changes per hour (ACH), the ventilation rate metric indicating how frequently cabin air is replaced. Higher ACH generally provides greater dilution of airborne contaminants.</data>
      <data key="d3">0.93</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="INHALATION VOLUME OF CO2 RELATIVE TO THE VOLUME EMITTED (P_CO2)">
