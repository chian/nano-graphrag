      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Concentration of cough-generated respiratory droplets and droplet nuclei suspended in the elevator cabin air, reflecting short-range emission and room-scale dispersion.</data>
      <data key="d3">0.78</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="AIRBORNE TRANSMISSION RISK SCORE">
      <data key="d0">AIRBORNE TRANSMISSION RISK SCORE</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">An integrated risk metric (model- or measurement-derived) estimating likelihood of airborne infection under given ventilation and occupancy conditions.</data>
