      <data key="d0">MOVING TESTS OUTDOORS AT TSUKUBA</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Outdoor moving experiments at Tsukuba evaluating bus ACH under different window configurations without mannequins.</data>
