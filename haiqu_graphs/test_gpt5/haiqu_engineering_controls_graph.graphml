    <node id="AIR CHANGES PER HOUR (ACH) IN ELEVATOR CABIN">
      <data key="d0">AIR CHANGES PER HOUR (ACH) IN ELEVATOR CABIN</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Ventilation rate metric describing how many times per hour the cabin’s air volume is replaced. Key controllable parameter for dilution of exhaled CO2 and respiratory aerosols in elevators.</data>
      <data key="d3">0.8</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
