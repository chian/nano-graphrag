      <data key="d0">CO2 CONCENTRATION IN CABIN AIR</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Measured indoor CO2 (e.g., ppm) used as a proxy for rebreathed air fraction and occupant-generated aerosol accumulation within the elevator cabin.</data>
      <data key="d3">0.82</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
