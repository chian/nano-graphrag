      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_6</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="VENTILATION STRATEGIES">
      <data key="d0">VENTILATION STRATEGIES</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Operational approaches that adjust outdoor air exchange, airflow paths, mixing, and extraction to dilute and remove exhaled CO2 and cough-generated droplets in enclosed spaces. In the cited context, they are evaluated inside a hospital lift to mitigate short-duration airborne exposure.</data>
      <data key="d3">0.86</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="PERFORMANCE OF CO2 ACCUMULATION AND DROPLET DISPERSION FROM A COUGH INSIDE A HOSPITAL LIFT UNDER DIFFERENT VENTILATION STRATEGIES.">
      <data key="d0">PERFORMANCE OF CO2 ACCUMULATION AND DROPLET DISPERSION FROM A COUGH INSIDE A HOSPITAL LIFT UNDER DIFFERENT VENTILATION STRATEGIES.</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Scientific Reports (2024; PMID: 38514758). Evaluates CO2 buildup and cough droplet dispersion in a hospital elevator under varying ventilation strategies, quantifying how engineering ventilation measures alter exposure proxies in this micro-environment.</data>
      <data key="d3">0.88</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="MULTI-SCALE RISK ASSESSMENT AND MITIGATIONS COMPARISON FOR COVID-19 IN URBAN PUBLIC TRANSPORT: A COMBINED FIELD MEASUREMENT AND MODELING APPROACH.">
      <data key="d0">MULTI-SCALE RISK ASSESSMENT AND MITIGATIONS COMPARISON FOR COVID-19 IN URBAN PUBLIC TRANSPORT: A COMBINED FIELD MEASUREMENT AND MODELING APPROACH.</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Building and Environment (2023; PMID: 37333517). Combines field measurements and modeling to compare COVID-19 mitigations in public transport, providing transferable evidence on how ventilation and related controls influence airborne risk.</data>
      <data key="d3">0.62</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="SPATIAL DISTRIBUTIONS OF AIRBORNE TRANSMISSION RISK ON COMMUTER BUSES: NUMERICAL CASE STUDY USING COMPUTATIONAL FLUID AND PARTICLE DYNAMICS WITH COMPUTER-SIMULATED PERSONS.">
      <data key="d0">SPATIAL DISTRIBUTIONS OF AIRBORNE TRANSMISSION RISK ON COMMUTER BUSES: NUMERICAL CASE STUDY USING COMPUTATIONAL FLUID AND PARTICLE DYNAMICS WITH COMPUTER-SIMULATED PERSONS.</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Experimental and Computational Multiphase Flow (2023; PMID: 36788805). Uses CFD and particle dynamics with virtual occupants to resolve spatial risk patterns in buses, informing ventilation and airflow control principles relevant to enclosed shared spaces.</data>
      <data key="d3">0.53</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
    <node id="COVID-19 TRANSMISSION AND CONTROL IN LAND PUBLIC TRANSPORT: A LITERATURE REVIEW.">
      <data key="d0">COVID-19 TRANSMISSION AND CONTROL IN LAND PUBLIC TRANSPORT: A LITERATURE REVIEW.</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Fundamental Research (2023; PMID: 38933205). Review synthesizing evidence on SARS-CoV-2 transmission and engineering/operational controls in land public transport, supporting generalizable ventilation-based mitigation concepts.</data>
      <data key="d3">0.55</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_7</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
