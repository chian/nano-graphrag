      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">Experiments quantifying how front (F) and rear (R) ventilation fan operation changes ACH in the bus cabin without mannequins.</data>
      <data key="d3">0.75</data>
      <data key="d4">e45568c3-e22e-4830-92f5-64de955e8aee_chunk_4</data>
      <data key="d5">e45568c3-e22e-4830-92f5-64de955e8aee</data>
    </node>
