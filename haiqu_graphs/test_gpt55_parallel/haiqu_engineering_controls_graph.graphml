  <graph edgedefault="directed">
    <node id="VENTILATION SYSTEM DESIGN">
      <data key="d0">VENTILATION SYSTEM DESIGN</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A site-specific engineering control for an enclosed mechanically ventilated hospital room. The abstract proposes optimizing ventilation design to reduce airborne infectious contaminant transport and occupant infection risk without necessarily increasing total ventilation airflow rate.</data>
      <data key="d3">0.97</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2,3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="UNINTERRUPTED CONTAMINANT SOURCE-TO-EXHAUST PATH">
      <data key="d0">UNINTERRUPTED CONTAMINANT SOURCE-TO-EXHAUST PATH</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A key airflow-control design feature identified as the dominant factor affecting contaminant transmission and control in an enclosed mechanically ventilated room. The text suggests contaminants are better controlled when the path from contaminant source to exhaust is uninterrupted.</data>
      <data key="d3">0.93</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INCREASING VENTILATION AIRFLOW RATE">
      <data key="d0">INCREASING VENTILATION AIRFLOW RATE</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A conventional ventilation strategy that increases the amount of supplied or exhausted air. The abstract states that increasing airflow can improve dilution when the contaminant source is constant, but does not necessarily increase ventilation effectiveness.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIR CHANGES PER HOUR (ACH)">
      <data key="d0">AIR CHANGES PER HOUR (ACH)</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">A ventilation-rate metric commonly emphasized in studies of airborne infectious particle transmission as a dilution factor for possible infectious agents.</data>
      <data key="d3">0.82</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION AIRFLOW RATE">
      <data key="d0">VENTILATION AIRFLOW RATE</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">The quantitative airflow-rate parameter of a ventilation system. The study contrasts reliance on increasing this rate with improving contaminant control through airflow-path optimization.</data>
      <data key="d3">0.8</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE INFECTIOUS DISEASE AGENTS">
      <data key="d0">AIRBORNE INFECTIOUS DISEASE AGENTS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Broad class of infectious biological contaminants transported through room air. These agents are the target of the ventilation analysis and proposed control strategy. | Particle form of airborne infectious agents discussed in relation to transmission, dilution by ACH, particle path, and CFD-based analysis.</data>
      <data key="d3">0.88</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
      <data key="d6">AIRBORNE INFECTIOUS DISEASE PARTICLES</data>
    </node>
    <node id="OCCUPANT INFECTION RISK">
      <data key="d0">OCCUPANT INFECTION RISK</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">The primary health-related effectiveness outcome for the proposed isolation-room ventilation optimization. The abstract frames the reduction as hypothetical and based on risk assessment and CFD analysis.</data>
      <data key="d3">0.86</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE CONTAMINANT CONCENTRATION">
      <data key="d0">AIRBORNE CONTAMINANT CONCENTRATION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">An environmental effectiveness measure affected by ventilation. The abstract states that increasing airflow can dilute concentrations better when the contaminant source is constant.</data>
      <data key="d3">0.74</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="VENTILATION EFFECTIVENESS">
      <data key="d0">VENTILATION EFFECTIVENESS</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">A performance measure describing how effectively ventilation removes or controls contaminants, distinguished from simple dilution by increased airflow rate.</data>
      <data key="d3">0.78</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ISOLATION ROOM">
      <data key="d0">ISOLATION ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">The hospital room type used as the example setting for the optimized ventilation-system design and airborne infection-risk assessment.</data>
      <data key="d3">0.88</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS">
      <data key="d0">COMPUTATIONAL FLUID DYNAMICS (CFD) ANALYSIS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A modeling-based analysis performed to examine contaminant transport mechanisms, infectious particle paths, and a proposed control strategy for reducing airborne infectious disease agents.</data>
      <data key="d3">0.86</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="SITE-SPECIFIC RISK ANALYSIS">
      <data key="d0">SITE-SPECIFIC RISK ANALYSIS</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">A scientific, location-specific risk assessment used to determine ventilation-system design requirements and evaluate infection-transmission control in the room.</data>
      <data key="d3">0.82</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="ANNUAL COST OF NOSOCOMIAL INFECTIONS IN THE UNITED STATES">
      <data key="d0">ANNUAL COST OF NOSOCOMIAL INFECTIONS IN THE UNITED STATES</data>
      <data key="d1">COST_PROXY</data>
      <data key="d2">The economic burden cited in the abstract, estimated at $4 billion to $5 billion annually, motivating ventilation strategies that may reduce healthcare-associated infection risk.</data>
      <data key="d3">0.72</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_2</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="UNINTERRUPTED PATH BETWEEN CONTAMINANT SOURCE AND EXHAUST">
      <data key="d0">UNINTERRUPTED PATH BETWEEN CONTAMINANT SOURCE AND EXHAUST</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Ventilation-design principle in which contaminants move from the source toward the exhaust without being disrupted by competing air streams. The text identifies this path as the dominant factor affecting contaminant transmission and control.</data>
      <data key="d3">0.95</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="EXHAUST">
      <data key="d0">EXHAUST</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">The removal point in the ventilation system toward which airborne contaminants should be directed. Its relationship to the contaminant source defines the critical source-to-exhaust pathway described in the excerpt.</data>
      <data key="d3">0.82</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIR STREAM INTERRUPTION">
      <data key="d0">AIR STREAM INTERRUPTION</data>
      <data key="d1">ADVERSE_EFFECT</data>
      <data key="d2">Disruption of the desired source-to-exhaust contaminant pathway by an air stream. The text states that contaminants are better controlled when the path is not interrupted, implying that interruption worsens contaminant control.</data>
      <data key="d3">0.76</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIR CHANGE RATE (ACH)">
      <data key="d0">AIR CHANGE RATE (ACH)</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">Ventilation rate expressed as air changes per hour. The excerpt contrasts ACH with ventilation system design and suggests that design may be more important than ACH alone for contaminant control.</data>
      <data key="d3">0.87</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="HIGHER FLOW RATE">
      <data key="d0">HIGHER FLOW RATE</data>
      <data key="d1">DOSE_OR_RATE</data>
      <data key="d2">An increased ventilation flow condition. The text states that the risk-reducing effect of moving farther from the patient is more pronounced under higher flow rate.</data>
      <data key="d3">0.78</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="DISTANCE FROM CONTAMINANT SOURCE">
      <data key="d0">DISTANCE FROM CONTAMINANT SOURCE</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Spatial separation from the source of airborne contaminants. The excerpt describes distance as a secondary factor and states that moving away from the patient generally reduces infection risk during transient coughing exposure.</data>
      <data key="d3">0.86</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="MOVING AWAY FROM THE PATIENT">
      <data key="d0">MOVING AWAY FROM THE PATIENT</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">A practical spatial-separation measure that increases distance from the patient, who is treated as the likely contaminant source in the coughing scenario. The text reports that this generally reduces infection risk.</data>
      <data key="d3">0.84</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CONTAMINANTS">
      <data key="d0">CONTAMINANTS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Airborne infectious or potentially infectious material released from a source and transported through room airflow. The excerpt focuses on how ventilation pathways and source distance affect their transmission and control.</data>
      <data key="d3">0.84</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="RECENTLY IDENTIFIED ORGANISMS">
      <data key="d0">RECENTLY IDENTIFIED ORGANISMS</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Newly identified infectious organisms for which the exact mode of transmission remains uncertain. The excerpt notes that future research is needed to clarify their transmission modes.</data>
      <data key="d3">0.58</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="INFECTION RISK IN A TRANSIENT COUGHING SITUATION">
      <data key="d0">INFECTION RISK IN A TRANSIENT COUGHING SITUATION</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Risk outcome associated with short-duration cough-generated contaminant release. The study reports that this risk generally decreases as one moves farther from the patient, especially under higher flow rate.</data>
      <data key="d3">0.88</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CONTAMINANT TRANSMISSION AND CONTROL">
      <data key="d0">CONTAMINANT TRANSMISSION AND CONTROL</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Primary performance outcome describing how effectively airborne contaminants are transmitted, contained, or removed. The excerpt identifies the source-to-exhaust path as the dominant factor affecting this outcome.</data>
      <data key="d3">0.9</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="PATIENT ROOM">
      <data key="d0">PATIENT ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Clinical room setting referenced in the keywords and similar-article titles. It is the relevant hospital environment for ventilation design, airflow pathways, infection-risk assessment, and contaminant control.</data>
      <data key="d3">0.85</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRBORNE INFECTION ISOLATION ROOM">
      <data key="d0">AIRBORNE INFECTION ISOLATION ROOM</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Hospital isolation space designed to reduce airborne infection transmission. It is referenced in a similar article evaluating a ceiling-ventilated mock isolation room.</data>
      <data key="d3">0.73</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="EMERGENCY DEPARTMENTS">
      <data key="d0">EMERGENCY DEPARTMENTS</data>
      <data key="d1">HOSPITAL_ZONE</data>
      <data key="d2">Clinical setting referenced in a similar article evaluating ventilation performance of a negative-pressurized isolation room for emergency department use.</data>
      <data key="d3">0.86</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3,3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="CEILING-VENTILATED MOCK AIRBORNE INFECTION ISOLATION ROOM">
      <data key="d0">CEILING-VENTILATED MOCK AIRBORNE INFECTION ISOLATION ROOM</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Ceiling-ventilated isolation-room configuration referenced in a similar article assessing prevention of hospital-acquired influenza transmission to health care workers.</data>
      <data key="d3">0.72</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="AIRFLOW PATHWAYS">
      <data key="d0">AIRFLOW PATHWAYS</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Routes by which supplied air and airborne contaminants move through patient rooms. The similar article title links airflow pathways with ventilation rates and bioaerosol containment and removal.</data>
      <data key="d3">0.72</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="NEGATIVE-PRESSURIZED ISOLATION ROOM">
      <data key="d0">NEGATIVE-PRESSURIZED ISOLATION ROOM</data>
      <data key="d1">ENGINEERING_CONTROL</data>
      <data key="d2">Isolation-room ventilation control strategy that maintains negative pressure to contain airborne contaminants and reduce spread to adjacent areas. It is referenced in a similar article on emergency department isolation-room performance.</data>
      <data key="d3">0.94</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3,3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_4</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="BIOAEROSOL">
      <data key="d0">BIOAEROSOL</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Airborne biological aerosol referenced in a similar article title about containment and removal in patient rooms.</data>
      <data key="d3">0.64</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="HOSPITAL-ACQUIRED INFLUENZA">
      <data key="d0">HOSPITAL-ACQUIRED INFLUENZA</data>
      <data key="d1">AIRBORNE_PATHOGEN</data>
      <data key="d2">Influenza transmission occurring in a hospital setting, referenced as the target infectious outcome in a similar article on ceiling-ventilated airborne infection isolation rooms.</data>
      <data key="d3">0.62</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="BIOAEROSOL CONTAINMENT AND REMOVAL">
      <data key="d0">BIOAEROSOL CONTAINMENT AND REMOVAL</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Performance outcome describing the ability of ventilation rates and airflow pathways to contain and remove airborne biological aerosols from patient rooms.</data>
      <data key="d3">0.66</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="PREVENTION OF HOSPITAL-ACQUIRED INFLUENZA TRANSMISSION TO HEALTH CARE WORKERS">
      <data key="d0">PREVENTION OF HOSPITAL-ACQUIRED INFLUENZA TRANSMISSION TO HEALTH CARE WORKERS</data>
      <data key="d1">EFFECTIVENESS_MEASURE</data>
      <data key="d2">Effectiveness endpoint from a similar article describing reduction or prevention of hospital-acquired influenza transmission to health care workers.</data>
      <data key="d3">0.64</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </node>
    <node id="THIS STUDY">
      <data key="d0">THIS STUDY</data>
      <data key="d1">VALIDATION_STUDY</data>
      <data key="d2">The primary study described in the excerpt. It provides evidence that ventilation system design and the source-to-exhaust contaminant pathway strongly influence contaminant transmission, control, and infection risk.</data>
      <data key="d3">0.91</data>
      <data key="d4">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d5">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
