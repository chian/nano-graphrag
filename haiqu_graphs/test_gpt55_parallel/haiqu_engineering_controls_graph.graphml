      <data key="d8">CONTAMINANTS</data>
      <data key="d9">TARGETS</data>
      <data key="d10">The source-to-exhaust path governs how contaminants travel through the room and is described as the dominant factor affecting their transmission and control.</data>
      <data key="d11">0.94</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
    </edge>
