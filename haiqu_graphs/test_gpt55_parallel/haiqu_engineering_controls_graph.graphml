      <data key="d8">CONTAMINANT TRANSMISSION AND CONTROL</data>
      <data key="d9">REDUCES</data>
      <data key="d10">Maintaining an uninterrupted route from source to exhaust improves contaminant control and thereby reduces the potential for contaminant transmission.</data>
      <data key="d11">0.91</data>
      <data key="d12">1</data>
      <data key="d13">3fc1e87d-c54a-447e-9229-2850cf6a1b9b_chunk_3</data>
      <data key="d14">3fc1e87d-c54a-447e-9229-2850cf6a1b9b</data>
